// chezmoi:template:left-delimiter="/*#" right-delimiter="*/"
// chezmoi:modify-template
{
  /*#- includeTemplate "pick" (dict
    "stdin" .chezmoi.stdin
    "jq" `{ version }`
  ) */
  "enabled": true,
  "features": {
    "policies": false,
    "permissionGate": true
  },
  "permissionGate": {
    "requireConfirmation": true,
    "allowedPatterns": [
      {
        "pattern": "rm\\s+(-[a-zA-Z]*f[a-zA-Z]*|--force).*\\s+/tmp(/|$|\\s)",
        "regex": true,
        "description": "rm -rf in /tmp is safe"
      },
      {
        "pattern": "\\bsudo\\b",
        "regex": true,
        "description": "sudo handled by sudo-guard extension"
      }
    ],
    "patterns": [
      {
        "pattern": "docker\\s+(run|exec).*(-e|--env)",
        "description": "docker env passthrough",
        "regex": true
      },
      {
        "pattern": "(printenv|\\benv\\b\\s*$|\\benv\\b\\s*\\|)",
        "description": "dump environment variables",
        "regex": true
      },
      {
        "pattern": "(cat|less|head|tail|bat|base64|xxd|strings).*\\.env",
        "description": "read/encode env file via shell",
        "regex": true
      },
      {
        "pattern": "(curl|wget|nc|ncat).*\\$",
        "description": "HTTP exfiltration with variable expansion",
        "regex": true
      },
      {
        "pattern": "\\bsource\\b.*\\.env",
        "description": "source env file into shell",
        "regex": true
      },
      {
        "pattern": "eval.*\\$\\(",
        "description": "eval with command substitution",
        "regex": true
      }
    ],
    "autoDenyPatterns": []
  }
}
