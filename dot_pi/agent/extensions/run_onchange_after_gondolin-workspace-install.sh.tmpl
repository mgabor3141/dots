#!/usr/bin/env bash
# {{ include (joinPath (.chezmoi.sourceFile | dir) "gondolin-workspace/package.json") | sha256sum }}
set -Eeuo pipefail
trap 'echo "Error on line $LINENO: $BASH_COMMAND" >&2' ERR

cd "{{ joinPath .chezmoi.homeDir ".pi/agent/extensions/gondolin-workspace" }}"

# Only install if qemu is available (extension is a no-op without it)
if command -v qemu-system-aarch64 &>/dev/null || command -v qemu-system-x86_64 &>/dev/null; then
  npm install --no-audit --no-fund
else
  echo "gondolin-workspace: skipping npm install (QEMU not found)"
fi
