// chezmoi:template:left-delimiter="/*#" right-delimiter="*/"
// chezmoi:modify-template
{
  /*#- includeTemplate "pick" (dict
    "stdin" .chezmoi.stdin
    "jq" `{ lastChangelogVersion, enabledModels, defaultProvider, defaultModel, hideThinkingBlock, defaultThinkingLevel, compaction, warnings }`
  ) */
  "packages": [
    /*# includeTemplate "indent" (dict "n" 4 "text"
      (includeTemplate "yapp-packages" (dict "names"
        (list "pi-bash-bg") "chezmoi" .chezmoi)))
    -*/
    /*#- if stat (joinPath .chezmoi.homeDir "dev/yapp/packages/jj/package.json") */
    /*# joinPath .chezmoi.homeDir "dev/yapp/packages/jj" | printf `"%s",` */
    /*# end -*/
    "npm:pi-librarian",
    "npm:pi-github"
  ],
  "defaultProjectTrust": "always",
  "treeFilterMode": "no-tools",
  "terminal": {
    "clearOnShrink": true
  },
  "shellCommandPrefix": "export PI_ROOT=\"$(dirname \"$(readlink -f \"$(command -v pi)\")\")/..\"",
  "quietStartup": true,
  "steeringMode": "all",
  "retry": {
    "enabled": true,
    "maxRetries": 16,
    "baseDelayMs": 2000,
    "provider": {
      "maxRetryDelayMs": 0
    }
  }
}
