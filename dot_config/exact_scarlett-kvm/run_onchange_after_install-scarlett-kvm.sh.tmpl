#!/usr/bin/env bash
# Uninstall old Scarlett KVM udev rule and systemd service.
# The Scarlett is now direct-connected to the Linux PC, not on the KVM hub.
# {{ "uninstall-v1" | sha256sum }}
trap 'echo "Error on line $LINENO: $BASH_COMMAND" >&2' ERR
set -Eeuo pipefail

if [ "$(id -u)" -ne 0 ]; then
    exec sudo "$0" "$@"
fi

rm -fv /etc/udev/rules.d/99-scarlett-kvm.rules
rm -fv /etc/systemd/system/scarlett-kvm-reconnect.service

udevadm control --reload-rules
systemctl daemon-reload

echo "Scarlett KVM reconnect udev rule and service removed."
