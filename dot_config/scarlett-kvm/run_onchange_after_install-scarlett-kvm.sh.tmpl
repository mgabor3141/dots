#!/usr/bin/env bash
# {{ include (joinPath (.chezmoi.sourceFile | dir) "99-scarlett-kvm.rules") | sha256sum }}
# {{ include (joinPath (.chezmoi.sourceFile | dir) "scarlett-kvm-reconnect.service") | sha256sum }}
trap 'echo "Error on line $LINENO: $BASH_COMMAND" >&2' ERR
set -Eeuo pipefail

if [ "$(id -u)" -ne 0 ]; then
    exec sudo "$0" "$@"
fi

src="{{ joinPath (.chezmoi.targetFile | dir) }}"

cp "$src/99-scarlett-kvm.rules" /etc/udev/rules.d/99-scarlett-kvm.rules
cp "$src/scarlett-kvm-reconnect.service" /etc/systemd/system/scarlett-kvm-reconnect.service

udevadm control --reload-rules
systemctl daemon-reload

echo "Scarlett KVM reconnect udev rule and service installed."
