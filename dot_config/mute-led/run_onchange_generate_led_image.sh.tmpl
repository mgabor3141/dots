#!/bin/bash
# Generate the mic-mute LED glow indicator image.
#
# An SVG with gaussian-blur filters produces a glowing 3D pill LED strip:
# glow layers (unmasked, bleed freely) + pill body with specular/rim reflections
# (masked for horizontal edge fade). Rasterized to PNG for sketchybar (macOS).
#
# This is a run_onchange_ script: it only re-runs when the script content
# changes (chezmoi tracks the hash).
#
# Requires: rsvg-convert (librsvg) for SVG→PNG rasterization
#
# Used by:
#   - sketchybar (macOS): dot_config/sketchybar/items/executable_mic.sh
#   - mute-indicator (Linux): dot_config/mute-indicator/

set -euo pipefail

# --- Tunables ---
W=500         # canvas width (match sketchybar/items/mic.sh and mute-indicator.py)
H=30          # canvas height
PILL_H=6      # pill thickness
PILL_RX=3     # pill corner radius
PILL_MARGIN=45  # horizontal margin from canvas edge to pill

# Glow blur radii (uniform, isotropic)
GLOW_WIDE_S=6
GLOW_MID_S=4
GLOW_TIGHT_S=1.5

# Horizontal fade: pill fades in/out over this percentage from canvas edges
FADE_IN=6     # percent
FADE_OUT=94   # percent

# --- Derived values ---
PILL_Y=$(( (H - PILL_H) / 2 ))              # vertically centered
PILL_W=$(( W - 2 * PILL_MARGIN ))            # pill width

# Glow rects use the same geometry as the pill
GW_X=$PILL_MARGIN; GW_W=$PILL_W
GM_X=$PILL_MARGIN; GM_W=$PILL_W
GT_X=$PILL_MARGIN; GT_W=$PILL_W

# Specular/reflection inset from pill
INSET=3
SPEC_X=$(( PILL_MARGIN + INSET ))
SPEC_W=$(( PILL_W - 2 * INSET ))
SPEC_H=$(( PILL_H / 2 ))
REF_Y=$(( PILL_Y + PILL_H / 3 ))
REF_H=$(( PILL_H * 2 / 3 ))

target="{{ .chezmoi.targetFile | dir }}"

cat > "$target/mic_mute_led.svg" <<SVG
<svg xmlns="http://www.w3.org/2000/svg" width="$W" height="$H" viewBox="0 0 $W $H">
  <defs>
    <!-- Horizontal fade for pill edges -->
    <linearGradient id="hfade" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%"   stop-color="white" stop-opacity="0" />
      <stop offset="${FADE_IN}%"  stop-color="white" stop-opacity="1" />
      <stop offset="${FADE_OUT}%" stop-color="white" stop-opacity="1" />
      <stop offset="100%" stop-color="white" stop-opacity="0" />
    </linearGradient>
    <mask id="hmask">
      <rect width="100%" height="100%" fill="url(#hfade)" />
    </mask>

    <!-- 3D pill gradient — subtle hotspot, asymmetric vertical -->
    <linearGradient id="pill3d" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="#ff8080" />
      <stop offset="20%"  stop-color="#ffc0b0" />
      <stop offset="38%"  stop-color="#ffd8d0" />
      <stop offset="55%"  stop-color="#ff9080" />
      <stop offset="80%"  stop-color="#ff2818" />
      <stop offset="100%" stop-color="#bb0800" />
    </linearGradient>

    <!-- Top specular highlight -->
    <linearGradient id="specular" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="white" stop-opacity="0.6" />
      <stop offset="50%"  stop-color="white" stop-opacity="0.05" />
      <stop offset="100%" stop-color="white" stop-opacity="0" />
    </linearGradient>

    <!-- Bottom rim reflection -->
    <linearGradient id="bottomref" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="white" stop-opacity="0" />
      <stop offset="75%"  stop-color="white" stop-opacity="0" />
      <stop offset="100%" stop-color="white" stop-opacity="0.2" />
    </linearGradient>

    <!-- Glow filters — userSpaceOnUse to avoid clipping at canvas edges -->
    <filter id="glow-wide" filterUnits="userSpaceOnUse" x="0" y="0" width="$W" height="$H">
      <feGaussianBlur stdDeviation="$GLOW_WIDE_S" />
    </filter>
    <filter id="glow-mid" filterUnits="userSpaceOnUse" x="0" y="0" width="$W" height="$H">
      <feGaussianBlur stdDeviation="$GLOW_MID_S" />
    </filter>
    <filter id="glow-tight" filterUnits="userSpaceOnUse" x="0" y="0" width="$W" height="$H">
      <feGaussianBlur stdDeviation="$GLOW_TIGHT_S" />
    </filter>
  </defs>

  <!-- Glow layers — NOT masked, bleed freely in all directions.
       Each rect extended by its blur σ past the pill ends to keep glow uniform. -->
  <rect x="$GW_X" y="$PILL_Y" width="$GW_W" height="$PILL_H" rx="$PILL_RX" ry="$PILL_RX"
        fill="#ff0000" opacity="0.7" filter="url(#glow-wide)" />
  <rect x="$GM_X" y="$PILL_Y" width="$GM_W" height="$PILL_H" rx="$PILL_RX" ry="$PILL_RX"
        fill="#ff1008" opacity="0.85" filter="url(#glow-mid)" />
  <rect x="$GT_X" y="$PILL_Y" width="$GT_W" height="$PILL_H" rx="$PILL_RX" ry="$PILL_RX"
        fill="#ff3020" opacity="0.6" filter="url(#glow-tight)" />

  <!-- Pill + reflections — masked for horizontal fade at ends -->
  <g mask="url(#hmask)">
    <rect x="$PILL_MARGIN" y="$PILL_Y" width="$PILL_W" height="$PILL_H" rx="$PILL_RX" ry="$PILL_RX"
          fill="url(#pill3d)" />
    <rect x="$SPEC_X" y="$PILL_Y" width="$SPEC_W" height="$SPEC_H" rx="2" ry="1.5"
          fill="url(#specular)" />
    <rect x="$SPEC_X" y="$REF_Y" width="$SPEC_W" height="$REF_H" rx="2" ry="2"
          fill="url(#bottomref)" />
  </g>
</svg>
SVG

# Rasterize to PNG (needed by sketchybar on macOS)
rsvg-convert "$target/mic_mute_led.svg" -o "$target/mic_mute_led.png"
