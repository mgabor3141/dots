{{- if .headless -}}
#!/bin/bash
# abduco-version: 0.6-git-8c32909
# patches: {{ include (joinPath (.chezmoi.sourceFile | dir) "../../dot_config/customizepkg/abduco-git.files/kitty-keyboard-protocol.patch") | sha256sum }}
# patches: {{ include (joinPath (.chezmoi.sourceFile | dir) "../../dot_config/customizepkg/abduco-git.files/no-alternate-screen.patch") | sha256sum }}
set -Eeuo pipefail
trap 'echo "❌ Error on line $LINENO: $BASH_COMMAND" >&2' ERR

DEST="{{ .chezmoi.workingTree }}/bin"
PATCHES="{{ .chezmoi.sourceDir }}/dot_config/customizepkg/abduco-git.files"
mkdir -p "$DEST"

echo "Building abduco (static, via Docker)..."

docker run --rm -v "$DEST":/output -v "$PATCHES":/patches:ro alpine:latest sh -c '
    apk add --no-cache gcc musl-dev make git patch >/dev/null 2>&1 &&
    git clone --depth 1 https://github.com/martanne/abduco.git /tmp/abduco &&
    cd /tmp/abduco &&
    for p in /patches/*.patch; do
        echo "Applying $(basename "$p")..." &&
        git apply "$p" || exit 1
    done &&
    CFLAGS="-static" make &&
    cp abduco /output/abduco
'

chmod +x "$DEST/abduco"
echo "✅ abduco installed: $("$DEST/abduco" -v 2>&1)"
{{- end }}
