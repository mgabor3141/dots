[data]
managed = {{ promptBoolOnce . "managed" "managed device" }}
headless = {{ promptBoolOnce . "headless" "headless server" }}

[diff]
command = "{{ .chezmoi.sourceDir }}/.helpers/chezmoi-diff"
exclude = ["scripts"]

[data.git]
name = "{{ promptStringOnce . "git.name" "git name" }}"
email = "{{ promptStringOnce . "git.email" "git email" }}"

{{ if promptBoolOnce . "git_work_enabled" "configure a separate work git identity" -}}
[data.git_work]
name = "{{ promptStringOnce . "git_work.name" "work git name" }}"
email = "{{ promptStringOnce . "git_work.email" "work git email" }}"
repo_dir = "{{ promptStringOnce . "git_work.repo_dir" "work repo directory" | default "~/work" }}"
{{- end }}

{{ range list "json" "jsonc" "json5" -}}
[[textconv]]
pattern = "**/*.{{ . }}"
command = "biome"
args = ["format", "--stdin-file-path", "file.jsonc"]

{{ end -}}
{{ range list "css" "js" "jsx" "ts" "tsx" -}}
[[textconv]]
pattern = "**/*.{{ . }}"
command = "biome"
args = ["format", "--stdin-file-path", "file.{{ . }}"]

{{ end -}}
{{ range list "yaml" "yml" "md" "mdx" -}}
[[textconv]]
pattern = "**/*.{{ . }}"
command = "prettier"
args = ["--stdin-filepath", "file.{{ . }}"]

{{ end -}}
{{ if eq .chezmoi.os "darwin" -}}
[[textconv]]
pattern = "**/*.plist"
command = "plutil"
args = ["-convert", "xml1", "-o", "-", "-"]

{{- end -}}
