#
# ~/.bashrc for headless server system
#

# Make direnv work in non-interactive bash (editor/agent tool calls).
export BASH_ENV="$HOME/.config/direnv/bash-env.sh"

# Load secrets (API keys etc.) so SSH-invoked non-interactive shells
# see them too. sshd-spawned bash sources ~/.bashrc but not ~/.profile,
# so without this BRAVE_API_KEY and friends are missing in `ssh host 'cmd'`.
if [ -f "$HOME/.env" ]; then
  set -a
  . "$HOME/.env"
  set +a
fi

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

{{- if .container }}

# In the devbox container, default interactive shells to fish (primary shell).
# Bash still runs for explicit `bash -c '...'` invocations (agents, scripts)
# because the non-interactive guard above returns before reaching this line.
# `command -v` guard means this no-ops before `devbox global install` lands fish.
command -v fish >/dev/null && exec -l fish
{{- end }}

# Ensure ~/.local/bin is in PATH
[[ ":$PATH:" != *":$HOME/.local/bin:"* ]] && export PATH="$HOME/.local/bin:$PATH"

alias ls='ls --color=auto'
alias grep='grep --color=auto'
alias pi='gmux pi'
PS1='[\u@\h \W]\$ '

command -v direnv >/dev/null && eval "$(direnv hook bash)"
