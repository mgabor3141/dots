#
# ~/.bashrc for headless server system
#

# Make direnv work in non-interactive bash (editor/agent tool calls).
export BASH_ENV="$HOME/.config/direnv/bash-env.sh"

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

# Ensure ~/.local/bin is in PATH
[[ ":$PATH:" != *":$HOME/.local/bin:"* ]] && export PATH="$HOME/.local/bin:$PATH"

alias ls='ls --color=auto'
alias grep='grep --color=auto'
PS1='[\u@\h \W]\$ '

command -v direnv >/dev/null && eval "$(direnv hook bash)"

# Wrap long-running commands in persistent abduco sessions via `persist`.
# Detach with Ctrl-\ to return to your shell; reattach with: session-manager
if command -v persist >/dev/null 2>&1; then
    pi() { persist pi "$@"; }
fi

