#!/bin/sh
# Sunshine creates sink-sunshine-stereo and sets it as default.
# Apps follow the default there, and Sunshine captures from it.
# On stop, restore system-audio as the default.

case "$1" in
  start)
    # Nothing needed — Sunshine handles sink creation.
    # The Scarlett hardware mixer ensures local playback continues.
    ;;
  stop)
    pactl set-default-sink system-audio
    ;;
esac
