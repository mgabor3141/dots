#!/usr/bin/env bash
# session-overview — kitty grid of all active abduco sessions
#
# Opens each session as a pane in a kitty grid layout, then watches
# for new sessions and adds them automatically. The original window
# is closed — only session panes remain.
#
# Usage:
#   session-overview              Local sessions only
#   session-overview --hosts      Include remote sessions via SSH
#
# Close the tab to end everything.
#
# Requires: kitty with allow_remote_control=socket-only, listen_on,
#           and enabled_layouts including grid.
#
# Note: uses abduco -a -l (low priority) so overview panes don't
# resize the original terminal sessions.

set -Eeuo pipefail
trap 'echo "Error on line $LINENO: $BASH_COMMAND" >&2' ERR

POLL_INTERVAL=3

# ── Args ────────────────────────────────────────────────────────────────────

include_hosts=false
[[ "${1:-}" == "--hosts" || "${1:-}" == "-H" ]] && include_hosts=true

# ── Kitty checks ───────────────────────────────────────────────────────────

if ! kitty @ ls &>/dev/null; then
    echo "session-overview: kitty remote control not available" >&2
    echo "  Requires: allow_remote_control socket-only, listen_on" >&2
    echo "  These settings require a kitty restart after changing." >&2
    exit 1
fi

# Our window ID (for targeting this tab and closing self later)
self_id=$(kitty @ ls | jq -r \
    '[.[].tabs[] | select(.is_focused) | .windows[] | select(.is_focused)] | .[0].id')

# ── Tracking ────────────────────────────────────────────────────────────────

tracker=$(mktemp /tmp/session-overview.XXXXXX)

is_tracked() { grep -qxF "$1" "$tracker" 2>/dev/null; }
track()      { echo "$1" >> "$tracker"; }

# ── Session discovery ───────────────────────────────────────────────────────

# Outputs: key \t attach_cmd \t label
discover_sessions() {
    while IFS=$'\t' read -r name status process cwd; do
        [[ -z "$name" ]] && continue
        local label="$name"
        [[ -n "$cwd" ]] && label="$label  ›  ${cwd/#$HOME/\~}"
        [[ -n "$process" && "$process" != "-" ]] && label="$label  ›  $process"
        printf '%s\t%s\t%s\n' "$name" "abduco -a -l '$name'" "$label"
    done < <(session-manager --list-all-raw 2>/dev/null)

    if $include_hosts; then
        while IFS=$'\t' read -r host name status process cwd; do
            [[ -z "$host" || -z "$name" ]] && continue
            local label="$host:$name"
            [[ -n "$cwd" ]] && label="$label  ›  ${cwd/#$HOME/\~}"
            [[ -n "$process" && "$process" != "-" ]] && label="$label  ›  $process"
            printf '%s\t%s\t%s\n' "$name@$host" "ssh -t '$host' abduco -a -l '$name'" "$label"
        done < <(session-manager --list-hosts-raw 2>/dev/null || true)
    fi
}

# ── Launch panes ────────────────────────────────────────────────────────────

# First window we create — used by the watcher to target our tab
first_wid=""

add_new_sessions() {
    local added=0
    while IFS=$'\t' read -r key cmd label; do
        [[ -z "$key" ]] && continue
        is_tracked "$key" && continue
        track "$key"

        local wid
        wid=$(kitty @ launch --type=window \
            --match="id:${first_wid:-$self_id}" \
            --title="$label" --cwd=current \
            bash -c "$cmd; printf '\\n\\033[2m[session ended — press enter]\\033[0m'; read")

        [[ -z "$first_wid" ]] && first_wid="$wid"
        (( added++ )) || true
    done < <(discover_sessions)
    (( added > 0 ))
}

# ── Main ────────────────────────────────────────────────────────────────────

# Switch to grid layout so panes auto-tile
kitty @ goto-layout grid >/dev/null 2>&1 || true

# Launch initial sessions
add_new_sessions || true

if [[ -z "$first_wid" ]]; then
    echo "session-overview: no active sessions"
    rm -f "$tracker"
    exit 0
fi

# ── Background watcher ──────────────────────────────────────────────────────

(
    while true; do
        sleep "$POLL_INTERVAL"

        # Exit if our tab is gone (all windows closed)
        if ! kitty @ ls 2>/dev/null | \
             jq -e ".[].tabs[].windows[] | select(.id == $first_wid)" \
             >/dev/null 2>&1; then
            break
        fi

        # Add any new sessions
        if add_new_sessions 2>/dev/null; then
            kitty @ goto-layout --match="id:$first_wid" grid >/dev/null 2>&1 || true
        fi
    done
    rm -f "$tracker"
) &
disown

# Close the original window — session panes fill the tab
kitty @ close-window --match="id:$self_id" >/dev/null 2>&1 || exit 0
