#!/usr/bin/env bash
# session-overview — kitty split grid for all active abduco sessions
#
# Opens each session as a split pane in the current tab, then watches
# for new sessions and adds them automatically.
#
# Usage:
#   session-overview              Local sessions only
#   session-overview --hosts      Include remote sessions via SSH
#
# The current window becomes a small watcher pane showing status.
# Press Ctrl-C to stop watching (sessions keep running in their panes).
# Close the tab to end everything.
#
# Requires: kitty with allow_remote_control=socket-only, listen_on,
#           and enabled_layouts including splits.

set -Eeuo pipefail
trap 'echo "Error on line $LINENO: $BASH_COMMAND" >&2' ERR

POLL_INTERVAL=3

# ── Args ────────────────────────────────────────────────────────────────────

include_hosts=false
[[ "${1:-}" == "--hosts" || "${1:-}" == "-H" ]] && include_hosts=true

# ── Tracking ────────────────────────────────────────────────────────────────

tracker=$(mktemp)
trap 'rm -f "$tracker"' EXIT

is_tracked() { grep -qxF "$1" "$tracker" 2>/dev/null; }
track()      { echo "$1" >> "$tracker"; }

# ── Kitty checks ───────────────────────────────────────────────────────────

if ! kitty @ ls &>/dev/null; then
    echo "session-overview: kitty remote control not available" >&2
    echo "  Requires: allow_remote_control socket-only, listen_on" >&2
    echo "  These settings require a kitty restart after changing." >&2
    exit 1
fi

# ── Session discovery ───────────────────────────────────────────────────────

# Outputs: key \t attach_cmd \t label
# key is unique: "name" for local, "name@host" for remote
discover_sessions() {
    while IFS=$'\t' read -r name status process cwd; do
        [[ -z "$name" ]] && continue
        local label="$name"
        [[ -n "$cwd" ]] && label="$label  ›  ${cwd/#$HOME/\~}"
        [[ -n "$process" && "$process" != "-" ]] && label="$label  ›  $process"
        printf '%s\t%s\t%s\n' "$name" "abduco -a '$name'" "$label"
    done < <(session-manager --list-all-raw 2>/dev/null)

    if $include_hosts; then
        while IFS=$'\t' read -r host name status process cwd; do
            [[ -z "$host" || -z "$name" ]] && continue
            local label="$host:$name"
            [[ -n "$cwd" ]] && label="$label  ›  ${cwd/#$HOME/\~}"
            [[ -n "$process" && "$process" != "-" ]] && label="$label  ›  $process"
            printf '%s\t%s\t%s\n' "$name@$host" "ssh -t '$host' abduco -a '$name'" "$label"
        done < <(session-manager --list-hosts-raw 2>/dev/null || true)
    fi
}

# ── Launch / refresh ────────────────────────────────────────────────────────

# Add splits for any sessions not already tracked.
# Returns 0 if any new sessions were added.
add_new_sessions() {
    local added=0
    while IFS=$'\t' read -r key cmd label; do
        [[ -z "$key" ]] && continue
        is_tracked "$key" && continue
        track "$key"

        kitty @ launch --type=window --location=split \
            --title="$label" --cwd=current \
            bash -c "$cmd; printf '\\n\\033[2m[session ended — press enter]\\033[0m'; read" \
            >/dev/null

        (( added++ )) || true
    done < <(discover_sessions)
    return $(( added == 0 ))
}

# ── Main ────────────────────────────────────────────────────────────────────

# Switch to splits layout in current tab
kitty @ goto-layout splits >/dev/null 2>&1 || true

# Initial population
add_new_sessions || true
count=$(wc -l < "$tracker")

if (( count == 0 )); then
    echo "session-overview: no active sessions, watching for new ones..."
fi

# Minimize the watcher pane
kitty @ resize-window --axis=vertical --increment=-100 >/dev/null 2>&1 || true

# Watch loop — adds new sessions as they appear
trap 'printf "\r\033[K\033[2mstopped\033[0m\n"; exit 0' INT
printf '\033[?25l'  # hide cursor

while true; do
    count=$(wc -l < "$tracker")
    printf '\r\033[K\033[2msession-overview: %d session(s) · watching…\033[0m' "$count"
    sleep "$POLL_INTERVAL"
    if add_new_sessions; then
        count=$(wc -l < "$tracker")
        printf '\r\033[K\033[2msession-overview: %d session(s) · watching…\033[0m' "$count"
    fi
done
