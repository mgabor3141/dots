#!/usr/bin/env python3
from __future__ import annotations

"""Lightweight workspace manager for jj repositories.

grove creates isolated workspaces from any directory containing jj repos.
It works with single repos and multi-repo setups alike. Workspaces live in
.grove/<name>/ and consist of jj workspace copies (for repos) and symlinks
(for configured shared files).

Configuration lives in .grove/grove.toml (optional):
    sync = [".pi", ".envrc", "AGENTS.md"]

Usage:
    grove create <name>             Create a new workspace
    grove sync [name]               Re-sync symlinks
    grove delete [name]             Delete a workspace
    grove list                      List workspaces
    grove status                    Show status across repos and workspaces
    grove review [path]             Browse commits across repos (TUI)
"""

import argparse
import shutil
import subprocess
import sys
from pathlib import Path

GROVE_DIR = ".grove"
GROVE_CONFIG = "grove.toml"
SKIP_ITEMS = {GROVE_DIR, ".git", ".jj", ".DS_Store"}


def die(msg: str) -> None:
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)


def run(cmd: list[str], cwd: Path | None = None) -> subprocess.CompletedProcess:
    result = subprocess.run(cmd, cwd=cwd, capture_output=True, text=True)
    if result.returncode != 0:
        stderr = result.stderr.strip()
        die(f"command failed: {' '.join(cmd)}\n{stderr}")
    return result


# ── Config ───────────────────────────────────────────────────────────


def load_config(grove_dir: Path) -> dict:
    """Load grove.toml config. Returns empty dict if missing or empty."""
    config_file = grove_dir / GROVE_CONFIG
    if not config_file.exists() or config_file.stat().st_size == 0:
        return {}

    config: dict = {}
    section = config
    for line in config_file.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        if line.startswith("[") and line.endswith("]"):
            key = line[1:-1].strip()
            config[key] = {}
            section = config[key]
        elif "=" in line:
            k, v = line.split("=", 1)
            k = k.strip()
            v = v.strip()
            # Parse arrays
            if v.startswith("["):
                items = v[1:-1].split(",")
                section[k] = [
                    i.strip().strip('"').strip("'")
                    for i in items if i.strip()
                ]
            else:
                section[k] = v.strip('"').strip("'")
    return config


def get_sync_list(config: dict) -> list[str]:
    """Get list of files/dirs to symlink into workspaces."""
    return config.get("sync", [])


def write_default_config(grove_dir: Path) -> None:
    """Write a default grove.toml with commented-out options."""
    config_file = grove_dir / GROVE_CONFIG
    if config_file.exists():
        return

    config_file.write_text(
        "# Grove configuration\n"
        "# https://github.com/gmuxapp/grove\n"
        "\n"
        "# Files and directories to symlink into workspaces.\n"
        "# Paths are relative to the project root.\n"
        "# Run 'grove sync' after changing this list.\n"
        '#\n'
        '# sync = [".pi", ".envrc", "AGENTS.md", ".zed"]\n'
    )


# ── Project detection ────────────────────────────────────────────────


def find_project_root(start: Path | None = None) -> Path:
    """Walk up from start looking for .grove/ or a .jj/ directory.

    If .grove/ is found, the project root is its parent.
    Otherwise, the nearest directory containing .jj/ is the root.
    """
    d = (start or Path.cwd()).resolve()
    # First: check if we're inside a workspace (.grove/<name>/...)
    # and return the project root above .grove/
    parts = d.parts
    for i, part in enumerate(parts):
        if part == GROVE_DIR and i > 0:
            candidate = Path(*parts[:i])
            if (candidate / GROVE_DIR).is_dir():
                return candidate

    # Walk up looking for .grove/, .jj/, or a directory containing child repos
    best_jj = None
    best_multi = None
    d = (start or Path.cwd()).resolve()
    while True:
        if (d / GROVE_DIR).is_dir():
            return d
        if (d / ".jj").is_dir() and best_jj is None:
            best_jj = d
        # Check for child repos (multi-repo root)
        if best_multi is None:
            child_repos = sum(
                1 for sub in d.iterdir()
                if sub.is_dir() and not sub.name.startswith(".")
                and (sub / ".jj").is_dir()
            ) if d.is_dir() else 0
            if child_repos >= 2:
                best_multi = d
        parent = d.parent
        if parent == d:
            break
        d = parent

    if best_jj:
        return best_jj
    if best_multi:
        return best_multi

    die("not inside a project (no .jj/ or .grove/ found)")


def find_repos(project_root: Path) -> list[Path]:
    """Find all jj repo directories.

    Checks the project root itself and its immediate children.
    """
    repos = []

    # Root itself might be a repo
    if (project_root / ".jj").is_dir():
        repos.append(project_root)

    # Child directories
    for d in sorted(project_root.iterdir()):
        if d.is_dir() and not d.name.startswith(".") and (d / ".jj").is_dir():
            repos.append(d)

    return repos


def resolve_workspace(project_root: Path, name: str | None) -> Path:
    """Resolve workspace directory from name or cwd."""
    grove_dir = project_root / GROVE_DIR

    if name:
        return grove_dir / name

    cwd = Path.cwd().resolve()
    grove_resolved = grove_dir.resolve()

    # Check if cwd is inside a workspace
    try:
        rel = cwd.relative_to(grove_resolved)
        ws_name = rel.parts[0] if rel.parts else None
        if ws_name:
            return grove_dir / ws_name
    except ValueError:
        pass

    die("not inside a workspace; pass a name or cd into one")


# ── jj auto-track ───────────────────────────────────────────────────


def jj_exclude_grove(repo_dir: Path) -> None:
    """Configure jj to ignore .grove/ via snapshot.auto-track."""
    result = subprocess.run(
        ["jj", "config", "get", "--repository", "snapshot.auto-track"],
        cwd=repo_dir, capture_output=True, text=True,
    )
    current = result.stdout.strip() if result.returncode == 0 else ""

    pattern = '.grove/**'
    if pattern in current:
        return

    if not current or current == "all()":
        new_value = f'all() & ~glob:"{pattern}"'
    else:
        new_value = f'{current} & ~glob:"{pattern}"'

    # jj config set expects TOML value; the value itself is a quoted string
    escaped = new_value.replace('"', '\\"')
    run(["jj", "config", "set", "--repo",
         "snapshot.auto-track", f'"{escaped}"'],
        cwd=repo_dir)

    # Untrack any already-tracked .grove files
    subprocess.run(
        ["jj", "file", "untrack", GROVE_DIR],
        cwd=repo_dir, capture_output=True, text=True,
    )


# ── Symlinking ───────────────────────────────────────────────────────


def sync_symlinks(project_root: Path, workspace_dir: Path,
                  sync_list: list[str]) -> None:
    """Create/update symlinks for configured files."""
    if not sync_list:
        return

    for item_name in sync_list:
        source = project_root / item_name
        target = workspace_dir / item_name

        if not source.exists():
            print(f"  warning: sync item not found: {item_name}")
            continue

        _ensure_symlink(target, source)

    # Clean stale symlinks
    project_resolved = project_root.resolve()
    for item in sorted(workspace_dir.iterdir()):
        if not item.is_symlink():
            continue
        try:
            link_target = item.resolve()
            link_target.relative_to(project_resolved)
        except (ValueError, OSError):
            continue
        if not link_target.exists():
            print(f"  Removing stale symlink: {item.name}")
            item.unlink()

    print(f"  Synced symlinks ({len(sync_list)} items)")


def _ensure_symlink(link_path: Path, target: Path) -> None:
    """Create a symlink, replacing any existing one."""
    resolved = target.resolve()
    if link_path.is_symlink():
        if link_path.resolve() == resolved:
            return
        link_path.unlink()
    elif link_path.exists():
        print(f"  warning: {link_path.name} exists and is not a symlink, skipping")
        return
    link_path.parent.mkdir(parents=True, exist_ok=True)
    link_path.symlink_to(resolved)


# ── Workspace operations ────────────────────────────────────────────


def ensure_grove_dir(project_root: Path) -> Path:
    """Create .grove/ directory and config if they don't exist."""
    grove_dir = project_root / GROVE_DIR
    created = not grove_dir.exists()
    grove_dir.mkdir(exist_ok=True)
    write_default_config(grove_dir)

    if created:
        # Set up jj auto-track exclusion for each repo
        for repo in find_repos(project_root):
            jj_exclude_grove(repo)
        print(f"  Created {GROVE_DIR}/ (excluded from jj tracking)")

    return grove_dir


def create_workspace(project_root: Path, name: str,
                     skip_zed: bool = False) -> None:
    """Create a new workspace."""
    repos = find_repos(project_root)
    if not repos:
        die(f"no jj repos found in {project_root}")

    grove_dir = ensure_grove_dir(project_root)
    ws_dir = grove_dir / name

    if ws_dir.exists():
        die(f"workspace already exists: {ws_dir}")

    ws_dir.mkdir(parents=True)
    is_single_repo = len(repos) == 1 and repos[0] == project_root

    print(f"\nCreating workspace: {name}\n")

    for repo_dir in repos:
        if is_single_repo:
            repo_name = project_root.name
            jj_ws_name = name
            dest = ws_dir
        else:
            repo_name = repo_dir.name
            jj_ws_name = f"{name}-{repo_name}"
            dest = ws_dir / repo_name

        print(f"  {repo_name}: fetching and creating jj workspace...")
        subprocess.run(["jj", "git", "fetch"], cwd=repo_dir,
                       capture_output=True, text=True)
        run(["jj", "workspace", "add", "--name", jj_ws_name,
             "--revision", "trunk()", str(dest)], cwd=repo_dir)

    # Sync configured symlinks
    config = load_config(grove_dir)
    sync_list = get_sync_list(config)
    if sync_list:
        sync_symlinks(project_root, ws_dir, sync_list)

    if not skip_zed and shutil.which("zed"):
        print(f"  Opening in Zed...")
        subprocess.run(["zed", "-n", str(ws_dir)])

    print(f"\nWorkspace ready: {ws_dir}")


def sync_workspace(project_root: Path, name: str | None) -> None:
    """Re-sync symlinks for a workspace."""
    grove_dir = project_root / GROVE_DIR
    config = load_config(grove_dir)
    sync_list = get_sync_list(config)

    if not sync_list:
        print("No sync items configured in grove.toml")
        print(f"  Hint: add sync = [\".pi\", \".envrc\"] to {GROVE_DIR}/{GROVE_CONFIG}")
        return

    ws_dir = resolve_workspace(project_root, name)
    if not ws_dir.exists():
        die(f"workspace not found: {ws_dir}")

    print(f"Syncing workspace: {ws_dir.name}\n")
    sync_symlinks(project_root, ws_dir, sync_list)


def delete_workspace(project_root: Path, name: str | None) -> None:
    """Delete a workspace."""
    ws_dir = resolve_workspace(project_root, name)

    if not ws_dir.exists():
        die(f"workspace not found: {ws_dir}")

    if not name:
        confirm = input(f"Delete workspace {ws_dir.name}? [y/N] ").strip()
        if confirm.lower() != "y":
            print("Cancelled.")
            return

    repos = find_repos(project_root)
    repo_dirs = {r.name: r for r in repos}
    ws_name = ws_dir.name
    is_single_repo = len(repos) == 1 and repos[0] == project_root

    if is_single_repo:
        print(f"  Forgetting jj workspace: {ws_name}")
        subprocess.run(
            ["jj", "workspace", "forget", ws_name],
            cwd=project_root, capture_output=True, text=True,
        )
    else:
        for subdir in sorted(ws_dir.iterdir()):
            if not subdir.is_dir() or subdir.name.startswith("."):
                continue
            if subdir.name in repo_dirs and (subdir / ".jj").is_dir():
                jj_ws_name = f"{ws_name}-{subdir.name}"
                print(f"  {subdir.name}: forgetting jj workspace")
                subprocess.run(
                    ["jj", "workspace", "forget", jj_ws_name],
                    cwd=repo_dirs[subdir.name],
                    capture_output=True, text=True,
                )

    shutil.rmtree(ws_dir)
    print(f"Deleted workspace: {ws_name}")


def list_workspaces(project_root: Path) -> None:
    """List workspaces."""
    grove_dir = project_root / GROVE_DIR
    if not grove_dir.exists():
        print("No workspaces. Run 'grove create <name>' to get started.")
        return

    workspaces = sorted(
        d for d in grove_dir.iterdir()
        if d.is_dir() and d.name != GROVE_CONFIG and not d.name.startswith(".")
    )
    # Filter out non-workspace entries (like config files)
    workspaces = [
        d for d in workspaces
        if (d / ".jj").is_dir() or any(
            sub.is_dir() and (sub / ".jj").is_dir()
            for sub in d.iterdir() if sub.is_dir()
        )
    ]

    if not workspaces:
        print("No workspaces. Run 'grove create <name>' to get started.")
        return

    for ws in workspaces:
        # Check for repos inside the workspace
        sub_repos = [
            d.name for d in sorted(ws.iterdir())
            if d.is_dir() and not d.name.startswith(".")
            and (d / ".jj").is_dir()
        ]
        if (ws / ".jj").is_dir():
            # Single-repo workspace
            print(f"  {ws.name}")
        elif sub_repos:
            print(f"  {ws.name}: {', '.join(sub_repos)}")
        else:
            print(f"  {ws.name}: (empty)")


# ── Status ───────────────────────────────────────────────────────────


def grove_status(project_root: Path) -> None:
    """Show status across repos and workspaces."""
    repos = find_repos(project_root)
    grove_dir = project_root / GROVE_DIR
    config = load_config(grove_dir) if grove_dir.exists() else {}
    sync_list = get_sync_list(config)

    print(f"Project: {project_root}")
    if sync_list:
        print(f"Sync: {', '.join(sync_list)}")
    print()

    print("Repos:")
    for repo_dir in repos:
        name = repo_dir.name if repo_dir != project_root else project_root.name
        colocated = (repo_dir / ".git").is_dir()
        tag = "colocated" if colocated else "jj-only"

        # Working copy changes
        result = subprocess.run(
            ["jj", "diff", "--no-pager", "--ignore-working-copy",
             "--stat", "--summary"],
            cwd=repo_dir, capture_output=True, text=True,
        )
        changed_files = 0
        if result.returncode == 0:
            lines = [l for l in result.stdout.strip().split("\n") if l.strip()]
            changed_files = len(lines)

        # Commits ahead of trunk
        result = subprocess.run(
            ["jj", "log", "--no-pager", "--ignore-working-copy",
             "-r", "trunk()..@", "--no-graph",
             "-T", 'if(!empty, "x\n")'],
            cwd=repo_dir, capture_output=True, text=True,
        )
        commits_ahead = 0
        if result.returncode == 0:
            commits_ahead = len([
                l for l in result.stdout.strip().split("\n") if l.strip()
            ])

        parts = [f"  {name:<36s} [{tag}]"]
        status_parts = []
        if commits_ahead > 0:
            status_parts.append(
                f"{commits_ahead} commit{'s' if commits_ahead != 1 else ''} ahead"
            )
        if changed_files > 0:
            status_parts.append(
                f"{changed_files} file{'s' if changed_files != 1 else ''} changed"
            )
        if status_parts:
            parts.append("  " + ", ".join(status_parts))
        else:
            parts.append("  clean")

        print("".join(parts))

    # Workspaces
    if grove_dir.exists():
        workspaces = sorted(
            d for d in grove_dir.iterdir()
            if d.is_dir() and not d.name.startswith(".")
            and d.name != GROVE_CONFIG
        )
    else:
        workspaces = []

    print(f"\nWorkspaces: {len(workspaces)}")
    for ws_dir in workspaces:
        ws_name = ws_dir.name
        print(f"  {ws_name}")


# ── CLI ──────────────────────────────────────────────────────────────


def validate_name(name: str) -> str | None:
    """Return error message if name is invalid, None if ok."""
    if not name.strip():
        return "Cannot be empty."
    if not all(c.isalnum() or c in "-_" for c in name):
        return "Use only alphanumeric, hyphens, underscores."
    if name == GROVE_CONFIG:
        return f"Reserved name: {GROVE_CONFIG}"
    return None


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="grove",
        description="Lightweight workspace manager for jj repositories.",
    )
    sub = parser.add_subparsers(dest="command", metavar="command")

    create_p = sub.add_parser("create", help="Create a new workspace")
    create_p.add_argument("name", help="Workspace name")
    create_p.add_argument("--no-zed", action="store_true",
                          help="Don't open in Zed")

    sync_p = sub.add_parser("sync", help="Re-sync symlinks")
    sync_p.add_argument("name", nargs="?",
                        help="Workspace name (default: auto-detect from cwd)")

    del_p = sub.add_parser("delete", help="Delete a workspace")
    del_p.add_argument("name", nargs="?",
                       help="Workspace name (or auto-detect from cwd)")

    sub.add_parser("list", help="List workspaces")

    sub.add_parser("status", help="Show status across repos and workspaces")

    return parser.parse_args()


def main() -> None:
    args = parse_args()

    if not args.command:
        sys.argv.append("--help")
        parse_args()
        return

    project_root = find_project_root()

    if args.command == "create":
        err = validate_name(args.name)
        if err:
            die(err)
        create_workspace(project_root, args.name,
                         skip_zed=args.no_zed)

    elif args.command == "sync":
        sync_workspace(project_root, args.name)

    elif args.command == "delete":
        delete_workspace(project_root, args.name)

    elif args.command == "list":
        list_workspaces(project_root)

    elif args.command == "status":
        grove_status(project_root)


if __name__ == "__main__":
    main()
