#!/usr/bin/env python3
from __future__ import annotations

"""Lightweight workspace manager for jj repositories.

grove creates isolated workspaces from any directory containing jj repos.
It works with single repos and multi-repo setups alike. Workspaces live in
.grove/<name>/ and consist of jj workspace copies (for repos) and symlinks
(for configured shared files).

Configuration lives in .grove/grove.toml (optional):
    sync = [".pi", ".envrc", "AGENTS.md"]

Usage:
    grove new [name]                Create a new workspace (random tree name if omitted)
    grove refresh [name]            Fetch and rebase workspace onto trunk
    grove refresh --all             Fetch and rebase all workspaces
    grove link                      Re-sync symlinks for all workspaces
    grove delete [name]             Delete a workspace
    grove list (ls)                 List workspaces with status
    grove status                    Show project and repo overview
"""

import argparse
import os
import shlex
import shutil
import subprocess
import sys
from pathlib import Path

GROVE_DIR = ".grove"
GROVE_CONFIG = "grove.toml"
GLOBAL_CONFIG_DIR = Path(os.environ.get("XDG_CONFIG_HOME",
                                        Path.home() / ".config")) / "grove"
SKIP_ITEMS = {GROVE_DIR, ".git", ".jj", ".DS_Store"}


def short_path(p: Path) -> str:
    """Shorten a path using ~ for home directory."""
    try:
        return "~/" + str(p.relative_to(Path.home()))
    except ValueError:
        return str(p)


def die(msg: str) -> None:
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)


def run(cmd: list[str], cwd: Path | None = None) -> subprocess.CompletedProcess:
    result = subprocess.run(cmd, cwd=cwd, capture_output=True, text=True)
    if result.returncode != 0:
        stderr = result.stderr.strip()
        die(f"command failed: {' '.join(cmd)}\n{stderr}")
    return result


# ── Config ───────────────────────────────────────────────────────────


def load_config(grove_dir_or_file: Path) -> dict:
    """Load a TOML config file. Returns empty dict if missing or empty.

    Accepts either a directory (appends grove.toml) or a file path directly.
    """
    if grove_dir_or_file.is_file():
        config_file = grove_dir_or_file
    else:
        config_file = grove_dir_or_file / GROVE_CONFIG
    if not config_file.exists() or config_file.stat().st_size == 0:
        return {}

    config: dict = {}
    section = config
    lines = config_file.read_text().splitlines()
    i = 0
    while i < len(lines):
        line = lines[i].strip()
        i += 1
        if not line or line.startswith("#"):
            continue
        if line.startswith("[") and line.endswith("]"):
            key = line[1:-1].strip()
            config[key] = {}
            section = config[key]
        elif "=" in line:
            k, v = line.split("=", 1)
            k = k.strip()
            v = v.strip()
            if v.startswith('"""'):
                # Multiline string: collect until closing """
                parts = [v[3:]]
                while i < len(lines):
                    next_line = lines[i]
                    i += 1
                    if '"""' in next_line:
                        parts.append(next_line[:next_line.index('"""')])
                        break
                    parts.append(next_line)
                section[k] = "\n".join(parts).strip()
            elif v.startswith("["):
                items = v[1:-1].split(",")
                section[k] = [
                    item.strip().strip('"').strip("'")
                    for item in items if item.strip()
                ]
            else:
                section[k] = v.strip('"').strip("'")
    return config


def load_global_config() -> dict:
    """Load global config from ~/.config/grove/config.toml."""
    return load_config(GLOBAL_CONFIG_DIR / "config.toml")


def merged_config(grove_dir: Path) -> dict:
    """Load global config, then overlay project config on top."""
    global_cfg = load_global_config()
    project_cfg = load_config(grove_dir)
    merged = {**global_cfg, **project_cfg}
    return merged


def get_sync_list(config: dict) -> list[str]:
    """Get list of files/dirs to symlink into workspaces."""
    return config.get("sync", [])


def ensure_global_config() -> None:
    """Create global config on first use if it doesn't exist."""
    config_file = GLOBAL_CONFIG_DIR / "config.toml"
    if config_file.exists():
        return

    GLOBAL_CONFIG_DIR.mkdir(parents=True, exist_ok=True)

    visual = os.environ.get("VISUAL", "")
    if visual:
        editor_line = f'editor = "{visual}"\n'
    else:
        editor_line = '# editor = "code"\n'

    config_file.write_text(
        "# Grove global configuration\n"
        "# https://github.com/gmuxapp/grove\n"
        "#\n"
        "# Project-level settings go in .grove/grove.toml\n"
        "# and override anything set here.\n"
        "\n"
        "# Editor to open workspaces in after creation.\n"
        "#\n"
        f"{editor_line}"
    )


def write_default_config(grove_dir: Path) -> None:
    """Write a default grove.toml with commented-out options."""
    config_file = grove_dir / GROVE_CONFIG
    if config_file.exists():
        return

    config_file.write_text(
        "# Grove project configuration\n"
        "# https://github.com/gmuxapp/grove\n"
        "#\n"
        "# Global defaults live in ~/.config/grove/config.toml\n"
        "# Settings here override global config.\n"
        "\n"
        "# Files and directories to symlink into workspaces.\n"
        "# Paths are relative to the project root.\n"
        "# Run 'grove link' after changing this list.\n"
        '#\n'
        '# sync = [".pi", ".envrc", "AGENTS.md", ".zed"]\n'
        "\n"
        "# Commands to run in each new workspace after creation.\n"
        "# Runs as bash with set -euo pipefail. Working directory\n"
        "# is the workspace root.\n"
        "#\n"
        '# setup = """\n'
        '# npm install\n'
        '# cp .env.example .env\n'
        '# """\n'
    )


# ── Project detection ────────────────────────────────────────────────


def find_project_root(start: Path | None = None,
                      allow_create: bool = False,
                      auto_confirm: bool = False,
                      optional: bool = False) -> Path | None:
    """Walk up from start looking for .grove/ or a .jj/ directory.

    If .grove/ is found, the project root is its parent.
    If only a jj repo is found and allow_create is True, prompts
    the user to confirm before using it as the project root.
    If optional is True, returns None instead of dying when not found.
    """
    d = (start or Path.cwd()).resolve()
    # First: check if we're inside a workspace (.grove/<name>/...)
    # and return the project root above .grove/
    parts = d.parts
    for i, part in enumerate(parts):
        if part == GROVE_DIR and i > 0:
            candidate = Path(*parts[:i])
            if (candidate / GROVE_DIR).is_dir():
                return candidate

    # Walk up looking for .grove/ (established grove)
    d = (start or Path.cwd()).resolve()
    while True:
        if (d / GROVE_DIR).is_dir():
            return d
        parent = d.parent
        if parent == d:
            break
        d = parent

    if optional:
        return None

    if not allow_create:
        die("not inside a grove (no .grove/ found)\n"
            "  Run 'grove new' from a project directory to get started.")

    # No .grove/ found. Look for a project root candidate (jj repo).
    cwd = (start or Path.cwd()).resolve()
    if (cwd / ".jj").is_dir():
        candidate = cwd
    else:
        child_repos = [
            sub for sub in cwd.iterdir()
            if sub.is_dir() and not sub.name.startswith(".")
            and (sub / ".jj").is_dir()
        ]
        if child_repos:
            candidate = cwd
        else:
            die("no jj repos found in current directory")

    repos = find_repos(candidate)
    if not auto_confirm:
        display = short_path(candidate)
        print(f"No .grove/ found. Initialize grove in {display}?")
        if len(repos) > 1:
            repo_desc = ", ".join(r.name for r in repos)
            print(f"  Repos: {repo_desc}")
        confirm = input("  Continue? [Y/n] ").strip()
        if confirm.lower() == "n":
            print("Cancelled.")
            sys.exit(0)

    return candidate


def find_repos(project_root: Path) -> list[Path]:
    """Find all jj repo directories.

    Checks the project root itself and its immediate children.
    """
    repos = []
    if (project_root / ".jj").is_dir():
        repos.append(project_root)
    for d in sorted(project_root.iterdir()):
        if d.is_dir() and not d.name.startswith(".") and (d / ".jj").is_dir():
            repos.append(d)
    return repos


def find_workspaces(grove_dir: Path) -> list[Path]:
    """Find all workspace directories inside .grove/."""
    if not grove_dir.exists():
        return []
    return sorted(
        d for d in grove_dir.iterdir()
        if d.is_dir() and not d.name.startswith(".")
        and (
            (d / ".jj").is_dir()
            or any(
                sub.is_dir() and (sub / ".jj").is_dir()
                for sub in d.iterdir() if sub.is_dir()
            )
        )
    )


def resolve_workspace(project_root: Path, name: str | None) -> Path:
    """Resolve workspace directory from name or cwd."""
    grove_dir = project_root / GROVE_DIR

    if name:
        return grove_dir / name

    cwd = Path.cwd().resolve()
    grove_resolved = grove_dir.resolve()

    try:
        rel = cwd.relative_to(grove_resolved)
        ws_name = rel.parts[0] if rel.parts else None
        if ws_name:
            return grove_dir / ws_name
    except ValueError:
        pass

    die("not inside a workspace; pass a name or cd into one")


# ── jj helpers ───────────────────────────────────────────────────────


def jj_exclude_grove(repo_dir: Path) -> None:
    """Configure jj to ignore .grove/ via snapshot.auto-track."""
    result = subprocess.run(
        ["jj", "config", "get", "--repository", "snapshot.auto-track"],
        cwd=repo_dir, capture_output=True, text=True,
    )
    current = result.stdout.strip() if result.returncode == 0 else ""

    pattern = '.grove/**'
    if pattern in current:
        return

    if not current or current == "all()":
        new_value = f'all() & ~glob:"{pattern}"'
    else:
        new_value = f'{current} & ~glob:"{pattern}"'

    escaped = new_value.replace('"', '\\"')
    run(["jj", "config", "set", "--repo",
         "snapshot.auto-track", f'"{escaped}"'],
        cwd=repo_dir)

    subprocess.run(
        ["jj", "file", "untrack", GROVE_DIR],
        cwd=repo_dir, capture_output=True, text=True,
    )


def _git_exclude_grove(repo_dir: Path) -> None:
    """Add .grove to .git/info/exclude so git ignores it too."""
    git_dir = repo_dir / ".git"
    if not git_dir.is_dir():
        return

    exclude_file = git_dir / "info" / "exclude"
    exclude_file.parent.mkdir(parents=True, exist_ok=True)

    existing = exclude_file.read_text() if exclude_file.exists() else ""
    if f"/{GROVE_DIR}" in existing:
        return

    with exclude_file.open("a") as f:
        if existing and not existing.endswith("\n"):
            f.write("\n")
        f.write(f"/{GROVE_DIR}\n")


def jj_workspace_info(repo_dir: Path, ws_name: str) -> dict:
    """Get workspace info: commits ahead of trunk, diff stats, best description."""
    info: dict = {"commits_ahead": 0, "insertions": 0, "deletions": 0,
                  "description": ""}

    # Get commits ahead of trunk with descriptions and diff stats
    result = subprocess.run(
        ["jj", "log", "--no-pager", "--ignore-working-copy",
         "-r", f"trunk()..{ws_name}@",
         "--no-graph",
         "-T", 'separate("\t", change_id.shortest(), description.first_line()) ++ "\n"'],
        cwd=repo_dir, capture_output=True, text=True,
    )
    if result.returncode != 0:
        return info

    commits = []
    for line in result.stdout.strip().split("\n"):
        if not line.strip():
            continue
        parts = line.split("\t", 1)
        short_id = parts[0].strip()
        desc = parts[1].strip() if len(parts) > 1 else ""
        if desc:
            commits.append({"short_id": short_id, "description": desc})

    info["commits_ahead"] = len(commits)

    # Get total diff stats for trunk..workspace
    result = subprocess.run(
        ["jj", "diff", "--no-pager", "--ignore-working-copy",
         "-r", f"trunk()..{ws_name}@", "--stat"],
        cwd=repo_dir, capture_output=True, text=True,
    )
    if result.returncode == 0 and result.stdout.strip():
        # Last line is summary: "N files changed, X insertions(+), Y deletions(-)"
        lines = result.stdout.strip().split("\n")
        summary = lines[-1] if lines else ""
        if "insertion" in summary or "deletion" in summary:
            import re
            ins = re.search(r"(\d+) insertion", summary)
            dels = re.search(r"(\d+) deletion", summary)
            info["insertions"] = int(ins.group(1)) if ins else 0
            info["deletions"] = int(dels.group(1)) if dels else 0

    # Find the commit with the longest description (most meaningful)
    if commits:
        best = max(commits, key=lambda c: len(c["description"]))
        info["description"] = best["description"]

    return info


# ── Symlinking ───────────────────────────────────────────────────────


def sync_symlinks(project_root: Path, workspace_dir: Path,
                  sync_list: list[str]) -> None:
    """Create/update symlinks for configured files."""
    if not sync_list:
        return

    for item_name in sync_list:
        source = project_root / item_name
        target = workspace_dir / item_name

        if not source.exists():
            print(f"    warning: sync item not found: {item_name}")
            continue

        _ensure_symlink(target, source)

    # Clean stale symlinks
    project_resolved = project_root.resolve()
    for item in sorted(workspace_dir.iterdir()):
        if not item.is_symlink():
            continue
        try:
            link_target = item.resolve()
            link_target.relative_to(project_resolved)
        except (ValueError, OSError):
            continue
        if not link_target.exists():
            print(f"    Removing stale symlink: {item.name}")
            item.unlink()


def _ensure_symlink(link_path: Path, target: Path) -> None:
    """Create a symlink, replacing any existing one."""
    resolved = target.resolve()
    if link_path.is_symlink():
        if link_path.resolve() == resolved:
            return
        link_path.unlink()
    elif link_path.exists():
        print(f"    warning: {link_path.name} exists and is not a symlink, skipping")
        return
    link_path.parent.mkdir(parents=True, exist_ok=True)
    link_path.symlink_to(resolved)


# ── Workspace operations ────────────────────────────────────────────


def ensure_grove_dir(project_root: Path) -> Path:
    """Create .grove/ directory and config if they don't exist."""
    ensure_global_config()
    grove_dir = project_root / GROVE_DIR
    created = not grove_dir.exists()
    grove_dir.mkdir(exist_ok=True)
    write_default_config(grove_dir)

    if created:
        for repo in find_repos(project_root):
            jj_exclude_grove(repo)
            _git_exclude_grove(repo)

    return grove_dir


def find_incomplete_workspace(project_root: Path) -> str | None:
    """Find a workspace that has fewer repos than expected.

    Returns the workspace name if one is incomplete, None otherwise.
    """
    grove_dir = project_root / GROVE_DIR
    if not grove_dir.exists():
        return None

    repos = find_repos(project_root)
    is_single_repo = len(repos) == 1 and repos[0] == project_root
    if is_single_repo:
        return None  # single-repo workspaces can't be partially created

    repo_names = {r.name for r in repos}
    for ws_dir in find_workspaces(grove_dir):
        ws_repos = {
            d.name for d in ws_dir.iterdir()
            if d.is_dir() and not d.name.startswith(".")
            and (d / ".jj").is_dir()
        }
        if ws_repos and ws_repos < repo_names:
            return ws_dir.name

    return None


def create_workspace(project_root: Path, name: str,
                     open_editor: bool | None = None,
                     resume: bool = False,
                     run_setup: bool = True) -> None:
    """Create a new workspace, or resume an incomplete one."""
    repos = find_repos(project_root)
    if not repos:
        die(f"no jj repos found in {project_root}")

    grove_dir = ensure_grove_dir(project_root)
    ws_dir = grove_dir / name

    if ws_dir.exists() and not resume:
        die(f"workspace already exists: {ws_dir}")

    ws_dir.mkdir(parents=True, exist_ok=True)
    is_single_repo = len(repos) == 1 and repos[0] == project_root

    label = "Resuming" if resume else "Creating"
    print(f"\n{label} workspace: {name}\n")

    for repo_dir in repos:
        if is_single_repo:
            repo_name = project_root.name
            jj_ws_name = name
            dest = ws_dir
        else:
            repo_name = repo_dir.name
            jj_ws_name = f"{name}-{repo_name}"
            dest = ws_dir / repo_name

        if dest.exists() and (dest / ".jj").is_dir():
            print(f"  {repo_name}: already exists, skipping")
            continue

        print(f"  {repo_name}: fetching and creating jj workspace...")
        subprocess.run(["jj", "git", "fetch"], cwd=repo_dir,
                       capture_output=True, text=True)
        subprocess.run(["jj", "workspace", "update-stale"], cwd=repo_dir,
                       capture_output=True, text=True)
        run(["jj", "workspace", "add", "--name", jj_ws_name,
             "--revision", "trunk()", str(dest)], cwd=repo_dir)

    # Load merged config (global + project)
    config = merged_config(grove_dir)

    # Sync configured symlinks
    sync_list = get_sync_list(config)
    if sync_list:
        sync_symlinks(project_root, ws_dir, sync_list)

    # Run setup commands
    setup = config.get("setup", "")
    if setup and run_setup:
        print(f"\n  Running setup...", flush=True)
        result = subprocess.run(
            ["bash", "-euo", "pipefail", "-c", setup],
            cwd=ws_dir,
        )
        if result.returncode != 0:
            print(f"  warning: setup exited with code {result.returncode}")

    # Open editor: CLI flag > config > nothing
    editor_cmd = config.get("editor", "")
    if open_editor is False:
        editor_cmd = ""
    elif open_editor is None and not editor_cmd:
        editor_cmd = ""

    if editor_cmd:
        cmd = shlex.split(editor_cmd)
        print(f"  Opening in {cmd[0]}...")
        subprocess.Popen(cmd + [str(ws_dir)],
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    print(f"\nWorkspace ready: {GROVE_DIR}/{name}")


def link_workspaces(project_root: Path,
                    workspace_names: list[str] | None = None,
                    quiet: bool = False) -> None:
    """Re-sync symlinks for workspaces.

    If workspace_names is given, only those workspaces are linked.
    Otherwise all workspaces are linked. When quiet is True, skips
    the hint message if no sync items are configured.
    """
    grove_dir = project_root / GROVE_DIR
    config = merged_config(grove_dir)
    sync_list = get_sync_list(config)

    if not sync_list:
        if not quiet:
            print("No sync items configured in grove.toml")
            print(f"  Hint: add sync = [\".pi\", \".envrc\"] to {GROVE_DIR}/{GROVE_CONFIG}")
        return

    all_workspaces = find_workspaces(grove_dir)
    if not all_workspaces:
        if not quiet:
            print("No workspaces to link.")
        return

    if workspace_names is not None:
        targets = [ws for ws in all_workspaces if ws.name in workspace_names]
    else:
        targets = all_workspaces

    if not targets:
        return

    print(f"Linking {len(targets)} workspace{'s' if len(targets) != 1 else ''}...\n")
    for ws_dir in targets:
        print(f"  {ws_dir.name}:")
        sync_symlinks(project_root, ws_dir, sync_list)
    print(f"\nDone.")


def _reheat_workspace(repo_dir: Path, jj_ws_name: str) -> str:
    """Rebase a workspace onto trunk and clean up merged commits.

    Rebases the roots of the workspace's stack onto trunk, abandons
    empty merge commits (from trunk-into-feature merges on remotes),
    and resolves any conflicted bookmarks.

    Returns a short status string.
    """
    ws_at = f"{jj_ws_name}@"

    # Update stale workspace state before rebasing
    subprocess.run(
        ["jj", "workspace", "update-stale"],
        cwd=repo_dir, capture_output=True, text=True,
    )

    # Rebase roots of the stack onto trunk
    result = subprocess.run(
        ["jj", "rebase", "-d", "trunk()",
         "-s", f"roots(trunk()..stack({ws_at}))"],
        cwd=repo_dir, capture_output=True, text=True,
    )
    if result.returncode != 0:
        stderr = result.stderr.strip()
        return f"rebase failed: {stderr}"

    rebased = "nothing changed" not in result.stdout.lower()

    # Abandon empty merge commits left in the stack
    merges_revset = (
        f"(stack({ws_at}) ~ trunk()..{ws_at} ~ immutable())"
        f" & merges() & empty()"
    )
    count_result = subprocess.run(
        ["jj", "log", "-r", merges_revset, "--count", "--no-pager"],
        cwd=repo_dir, capture_output=True, text=True,
    )
    merge_count = 0
    if count_result.returncode == 0:
        try:
            merge_count = int(count_result.stdout.strip())
        except ValueError:
            pass

    if merge_count > 0:
        subprocess.run(
            ["jj", "abandon", "--retain-bookmarks", merges_revset],
            cwd=repo_dir, capture_output=True, text=True,
        )

        # Resolve conflicted bookmarks by keeping the copy on our stack
        bm_result = subprocess.run(
            ["jj", "log", "-r", f"trunk()..{ws_at} & bookmarks()",
             "--no-graph",
             "-T", 'local_bookmarks.map(|b| b.name() ++ "\t"'
                   ' ++ change_id.short() ++ "\n").join("")'],
            cwd=repo_dir, capture_output=True, text=True,
        )
        if bm_result.returncode == 0:
            for line in bm_result.stdout.strip().split("\n"):
                if "\t" not in line:
                    continue
                bm_name, rev = line.split("\t", 1)
                if bm_name.strip():
                    subprocess.run(
                        ["jj", "bookmark", "set", bm_name.strip(),
                         "-r", rev.strip()],
                        cwd=repo_dir, capture_output=True, text=True,
                    )

    if merge_count > 0:
        return f"rebased, cleaned {merge_count} merge commit{'s' if merge_count != 1 else ''}"
    return "rebased" if rebased else "already up to date"


def refresh_workspaces(project_root: Path, name: str | None,
                       all_workspaces: bool = False) -> None:
    """Fetch from remotes and rebase workspace(s) onto trunk.

    Fetches once per repo, then rebases each workspace's commit stack
    onto the updated trunk, cleaning up empty merge commits.

    With --all, also refreshes the root (default) workspace.
    When run from the project root without a name, implies --all.
    """
    grove_dir = project_root / GROVE_DIR
    repos = find_repos(project_root)
    if not repos:
        die(f"no jj repos found in {project_root}")

    is_single_repo = len(repos) == 1 and repos[0] == project_root

    # If no name given and we're at the project root (not inside a
    # workspace), treat as --all.
    if not all_workspaces and not name:
        if current_workspace_name(project_root) is None:
            all_workspaces = True

    # Build list of (display_name, {repo_dir: jj_workspace_name}) pairs
    targets: list[tuple[str, dict[Path, str]]] = []

    if all_workspaces:
        # Include the root (default) workspace
        if is_single_repo:
            targets.append(("(root)", {project_root: "default"}))
        else:
            targets.append(("(root)", {r: "default" for r in repos}))

        # Include all grove workspaces
        workspaces = find_workspaces(grove_dir)
        for ws in workspaces:
            if is_single_repo:
                targets.append((ws.name, {project_root: ws.name}))
            else:
                targets.append((ws.name, {
                    r: f"{ws.name}-{r.name}" for r in repos
                }))

    else:
        ws_dir = resolve_workspace(project_root, name)
        if not ws_dir.exists():
            die(f"workspace not found: {ws_dir.name}")
        if is_single_repo:
            targets.append((ws_dir.name, {project_root: ws_dir.name}))
        else:
            targets.append((ws_dir.name, {
                r: f"{ws_dir.name}-{r.name}" for r in repos
            }))

    # Fetch once per repo
    print("Fetching...\n")
    for repo_dir in repos:
        repo_label = repo_dir.name if repo_dir != project_root else project_root.name
        result = subprocess.run(
            ["jj", "git", "fetch"],
            cwd=repo_dir, capture_output=True, text=True,
        )
        if result.returncode != 0:
            print(f"  {repo_label}: fetch failed: {result.stderr.strip()}")
        else:
            print(f"  {repo_label}: fetched")

    # Rebase each workspace
    print()
    errors = 0
    ws_names = []
    for display_name, repo_map in targets:
        print(f"  {display_name}:")
        if display_name != "(root)":
            ws_names.append(display_name)
        for repo_dir, jj_ws_name in repo_map.items():
            tag = _reheat_workspace(repo_dir, jj_ws_name)
            if "failed" in tag:
                errors += 1
            if is_single_repo:
                print(f"    {tag}")
            else:
                repo_label = repo_dir.name
                print(f"    {repo_label}: {tag}")

    # Re-sync symlinks for the refreshed workspaces (not root)
    if ws_names:
        link_workspaces(project_root, workspace_names=ws_names, quiet=True)

    if errors:
        print(f"Done with {errors} error{'s' if errors != 1 else ''}.")
    else:
        count = len(targets)
        print(f"Refreshed {count} workspace{'s' if count != 1 else ''}.")


def delete_workspace(project_root: Path, name: str | None,
                     force: bool = False) -> None:
    """Delete a workspace."""
    ws_dir = resolve_workspace(project_root, name)

    if not ws_dir.exists():
        die(f"workspace not found: {ws_dir}")

    if not force:
        confirm = input(f"Delete workspace {ws_dir.name}? [y/N] ").strip()
        if confirm.lower() != "y":
            print("Cancelled.")
            return

    repos = find_repos(project_root)
    repo_dirs = {r.name: r for r in repos}
    ws_name = ws_dir.name
    is_single_repo = len(repos) == 1 and repos[0] == project_root

    if is_single_repo:
        print(f"  Forgetting jj workspace: {ws_name}")
        subprocess.run(
            ["jj", "workspace", "forget", ws_name],
            cwd=project_root, capture_output=True, text=True,
        )
    else:
        for subdir in sorted(ws_dir.iterdir()):
            if not subdir.is_dir() or subdir.name.startswith("."):
                continue
            if subdir.name in repo_dirs and (subdir / ".jj").is_dir():
                jj_ws_name = f"{ws_name}-{subdir.name}"
                print(f"  {subdir.name}: forgetting jj workspace")
                subprocess.run(
                    ["jj", "workspace", "forget", jj_ws_name],
                    cwd=repo_dirs[subdir.name],
                    capture_output=True, text=True,
                )

    shutil.rmtree(ws_dir)
    print(f"Deleted workspace: {ws_name}")


def _collect_workspace_info(project_root: Path, repos: list[Path],
                           ws_name: str) -> dict:
    """Collect aggregated info for a workspace across all repos."""
    is_single_repo = len(repos) == 1 and repos[0] == project_root

    if is_single_repo:
        return jj_workspace_info(project_root, ws_name)

    total_commits = 0
    total_ins = 0
    total_dels = 0
    best_desc = ""
    best_desc_len = 0

    for repo_dir in repos:
        jj_ws_name = f"{ws_name}-{repo_dir.name}"
        info = jj_workspace_info(repo_dir, jj_ws_name)
        total_commits += info["commits_ahead"]
        total_ins += info["insertions"]
        total_dels += info["deletions"]
        if len(info["description"]) > best_desc_len:
            best_desc = info["description"]
            best_desc_len = len(info["description"])

    return {
        "commits_ahead": total_commits,
        "insertions": total_ins,
        "deletions": total_dels,
        "description": best_desc,
    }


def list_workspaces(project_root: Path) -> None:
    """List workspaces with status info."""
    grove_dir = project_root / GROVE_DIR
    workspaces = find_workspaces(grove_dir)

    if not workspaces:
        print("No workspaces. Run 'grove new' to get started.")
        return

    repos = find_repos(project_root)
    cur = current_workspace_name(project_root)

    for ws in workspaces:
        info = _collect_workspace_info(project_root, repos, ws.name)
        _print_workspace_line(ws.name, info, current=(ws.name == cur))


def current_workspace_name(project_root: Path) -> str | None:
    """Return the name of the workspace we're currently inside, or None."""
    cwd = Path.cwd().resolve()
    grove_dir = (project_root / GROVE_DIR).resolve()
    try:
        rel = cwd.relative_to(grove_dir)
        return rel.parts[0] if rel.parts else None
    except ValueError:
        return None


def _print_workspace_line(name: str, info: dict,
                          current: bool = False) -> None:
    """Format and print a single workspace line."""
    parts = []

    commits = info["commits_ahead"]
    if commits > 0:
        parts.append(f"{commits} commit{'s' if commits != 1 else ''}")

    ins = info["insertions"]
    dels = info["deletions"]
    if ins > 0 or dels > 0:
        diff_parts = []
        if ins > 0:
            diff_parts.append(f"+{ins}")
        if dels > 0:
            diff_parts.append(f"-{dels}")
        parts.append(" ".join(diff_parts))

    status = ", ".join(parts) if parts else "clean"
    desc = info.get("description", "")

    marker = "▸ " if current else "  "
    if desc:
        print(f"{marker}{name:<16s} {status:<28s} {desc}")
    else:
        print(f"{marker}{name:<16s} {status}")


# ── Status ───────────────────────────────────────────────────────────


def grove_status(project_root: Path | None) -> None:
    """Show project and repo overview."""
    if project_root is None:
        # Try to find repos in cwd even without .grove/
        cwd = Path.cwd().resolve()
        repos = []
        if (cwd / ".jj").is_dir():
            repos.append(cwd)
        for d in sorted(cwd.iterdir()):
            if d.is_dir() and not d.name.startswith(".") and (d / ".jj").is_dir():
                repos.append(d)

        if not repos:
            die("no jj repos found")

        print(f"Project: {cwd}")
        print(f"Grove: not initialized (run 'grove new' to get started)\n")
        _print_repo_status(repos, cwd)
        return

    repos = find_repos(project_root)
    grove_dir = project_root / GROVE_DIR
    config = load_config(grove_dir) if grove_dir.exists() else {}
    sync_list = get_sync_list(config)

    print(f"Project: {project_root}")
    if sync_list:
        print(f"Sync: {', '.join(sync_list)}")
    print()

    _print_repo_status(repos, project_root)

    # Workspaces
    workspaces = find_workspaces(grove_dir) if grove_dir.exists() else []
    print(f"\nWorkspaces: {len(workspaces)}")
    if workspaces:
        cur = current_workspace_name(project_root)
        for ws in workspaces:
            info = _collect_workspace_info(project_root, repos, ws.name)
            _print_workspace_line(ws.name, info, current=(ws.name == cur))


def _print_repo_status(repos: list[Path], project_root: Path) -> None:
    """Print status lines for each repo."""
    print("Repos:")
    for repo_dir in repos:
        name = repo_dir.name if repo_dir != project_root else project_root.name
        colocated = (repo_dir / ".git").is_dir()
        tag = "colocated" if colocated else "jj-only"

        result = subprocess.run(
            ["jj", "diff", "--no-pager", "--ignore-working-copy",
             "--stat", "--summary"],
            cwd=repo_dir, capture_output=True, text=True,
        )
        changed_files = 0
        if result.returncode == 0:
            lines = [l for l in result.stdout.strip().split("\n") if l.strip()]
            changed_files = len(lines)

        result = subprocess.run(
            ["jj", "log", "--no-pager", "--ignore-working-copy",
             "-r", "trunk()..@", "--no-graph",
             "-T", 'if(!empty, "x\n")'],
            cwd=repo_dir, capture_output=True, text=True,
        )
        commits_ahead = 0
        if result.returncode == 0:
            commits_ahead = len([
                l for l in result.stdout.strip().split("\n") if l.strip()
            ])

        parts = [f"  {name:<36s} [{tag}]"]
        status_parts = []
        if commits_ahead > 0:
            status_parts.append(
                f"{commits_ahead} commit{'s' if commits_ahead != 1 else ''} ahead"
            )
        if changed_files > 0:
            status_parts.append(
                f"{changed_files} file{'s' if changed_files != 1 else ''} changed"
            )
        if status_parts:
            parts.append("  " + ", ".join(status_parts))
        else:
            parts.append("  clean")

        print("".join(parts))


# ── Name generation ──────────────────────────────────────────────────

# One tree per letter of the alphabet (V and X have no good candidates).
TREE_NAMES = [
    "ash", "birch", "cedar", "dogwood", "elm", "fig", "ginkgo",
    "hazel", "ironwood", "juniper", "kauri", "larch", "maple",
    "nutmeg", "oak", "pine", "quince", "rowan", "spruce", "teak",
    "upas", "willow", "yew", "zelkova",
]


def pick_workspace_name(grove_dir: Path) -> str:
    """Pick a random unused tree name for a workspace."""
    import random

    existing = set()
    if grove_dir.exists():
        existing = {d.name for d in grove_dir.iterdir() if d.is_dir()}

    available = [n for n in TREE_NAMES if n not in existing]
    if not available:
        i = 1
        while f"ws-{i}" in existing:
            i += 1
        return f"ws-{i}"

    return random.choice(available)


# ── CLI ──────────────────────────────────────────────────────────────


def validate_name(name: str) -> str | None:
    """Return error message if name is invalid, None if ok."""
    if not name.strip():
        return "Cannot be empty."
    if not all(c.isalnum() or c in "-_" for c in name):
        return "Use only alphanumeric, hyphens, underscores."
    if name == GROVE_CONFIG:
        return f"Reserved name: {GROVE_CONFIG}"
    return None


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="grove",
        description="Lightweight workspace manager for jj repositories.",
    )
    sub = parser.add_subparsers(dest="command", metavar="command")

    new_p = sub.add_parser("new", help="Create a new workspace")
    new_p.add_argument("name", nargs="?",
                       help="Workspace name (default: random tree name)")
    editor_group = new_p.add_mutually_exclusive_group()
    editor_group.add_argument("--editor", action="store_true", default=None,
                              help="Open in editor")
    editor_group.add_argument("--no-editor", action="store_true",
                              help="Don't open in editor")
    new_p.add_argument("--no-setup", action="store_true",
                       help="Skip setup commands")
    new_p.add_argument("-y", "--yes", action="store_true",
                       help="Skip confirmation when initializing .grove/")

    sub.add_parser("link", help="Re-sync symlinks for all workspaces")

    refresh_p = sub.add_parser("refresh", help="Fetch and rebase workspace(s) onto trunk")
    refresh_p.add_argument("name", nargs="?",
                           help="Workspace name (or auto-detect from cwd)")
    refresh_p.add_argument("-a", "--all", action="store_true",
                           help="Refresh all workspaces")

    del_p = sub.add_parser("delete", aliases=["rm"],
                           help="Delete a workspace")
    del_p.add_argument("name", nargs="?",
                       help="Workspace name (or auto-detect from cwd)")
    del_p.add_argument("-f", "--force", action="store_true",
                       help="Skip confirmation")

    sub.add_parser("list", aliases=["ls"],
                   help="List workspaces with status")

    sub.add_parser("status", help="Show project and repo overview")

    return parser.parse_args()


def main() -> None:
    args = parse_args()

    if not args.command:
        sys.argv.append("--help")
        parse_args()
        return

    if args.command == "new":
        project_root = find_project_root(
            allow_create=True,
            auto_confirm=args.yes,
        )

        # Check for an incomplete workspace to resume
        resume = False
        name = args.name
        if not name:
            incomplete = find_incomplete_workspace(project_root)
            if incomplete:
                confirm = input(
                    f"Incomplete workspace '{incomplete}' found. "
                    f"Resume? [Y/n] "
                ).strip()
                if confirm.lower() != "n":
                    name = incomplete
                    resume = True
            if not name:
                grove_dir = project_root / GROVE_DIR
                name = pick_workspace_name(grove_dir)

        err = validate_name(name)
        if err:
            die(err)
        if args.no_editor:
            open_editor = False
        elif args.editor:
            open_editor = True
        else:
            open_editor = None
        create_workspace(project_root, name, open_editor=open_editor,
                         resume=resume, run_setup=not args.no_setup)

    elif args.command == "link":
        project_root = find_project_root()
        link_workspaces(project_root)

    elif args.command == "refresh":
        project_root = find_project_root()
        refresh_workspaces(project_root, args.name,
                           all_workspaces=args.all)

    elif args.command in ("delete", "rm"):
        project_root = find_project_root()
        delete_workspace(project_root, args.name, force=args.force)

    elif args.command in ("list", "ls"):
        project_root = find_project_root()
        list_workspaces(project_root)

    elif args.command == "status":
        project_root = find_project_root(optional=True)
        grove_status(project_root)


if __name__ == "__main__":
    main()
