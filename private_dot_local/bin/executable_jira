#!/usr/bin/env bash
# Wrapper around jira-cli that loads the API token from the macOS keychain.
# Lives ahead of /opt/homebrew/bin in PATH so every shell / agent / cron
# job hits it without per-shell setup.
set -euo pipefail

real_jira=/opt/homebrew/bin/jira
if [[ ! -x "$real_jira" ]]; then
  real_jira=$(PATH=${PATH#"$HOME/.local/bin:"} command -v jira) || {
    echo "jira: real binary not found (install ankitpokhrel/jira-cli)" >&2
    exit 127
  }
fi

if [[ -z "${JIRA_API_TOKEN:-}" ]]; then
  JIRA_API_TOKEN=$(security find-generic-password -a "$USER" -s jira-cli -w 2>/dev/null) || {
    echo "jira: no token in keychain (service=jira-cli)" >&2
    exit 1
  }
  export JIRA_API_TOKEN
fi

exec "$real_jira" "$@"
