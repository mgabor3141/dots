#!/usr/bin/env python3.13
"""Create workspaces from jj repos with moon task runner integration."""

import argparse
import curses
import json
import shutil
import subprocess
import sys
import textwrap
import tomllib
from pathlib import Path

CONFIG_PATH = Path("~/.config/workspaces/config.toml").expanduser()


def die(msg: str) -> None:
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)


def load_config() -> dict:
    if not CONFIG_PATH.exists():
        die(f"config not found: {CONFIG_PATH}")
    with open(CONFIG_PATH, "rb") as f:
        return tomllib.load(f)


def get_groups(repos: list[dict]) -> dict[str, list[int]]:
    """Return {group_name: [repo_indices]} from repos' groups fields."""
    groups: dict[str, list[int]] = {}
    for i, repo in enumerate(repos):
        for g in repo.get("groups", []):
            groups.setdefault(g, []).append(i)
    return dict(sorted(groups.items()))


def validate_name(name: str) -> str | None:
    """Return error message if name is invalid, None if ok."""
    if not name.strip():
        return "Cannot be empty."
    if not all(c.isalnum() or c in "-_" for c in name):
        return "Use only alphanumeric, hyphens, underscores."
    return None


# ── TUI ─────────────────────────────────────────────────────────────────


def tui_input(stdscr, prompt: str, validator=None) -> str:
    """Single-line text input with validation."""
    curses.curs_set(1)
    curses.use_default_colors()
    stdscr.clear()
    buf = ""
    error = ""

    while True:
        stdscr.clear()
        stdscr.addstr(0, 0, prompt, curses.A_BOLD)
        stdscr.addstr(1, 0, "> " + buf)
        if error:
            stdscr.addstr(3, 0, error, curses.A_DIM)
        stdscr.refresh()

        ch = stdscr.get_wch()
        if ch == "\n":
            if validator:
                err = validator(buf)
                if err:
                    error = err
                    continue
            if buf.strip():
                return buf.strip()
            error = "Cannot be empty."
        elif ch in ("\x7f", "\b", curses.KEY_BACKSPACE):
            buf = buf[:-1]
            error = ""
        elif ch == "\x1b":  # ESC
            return ""
        elif isinstance(ch, str) and ch.isprintable():
            buf += ch
            error = ""


# Row types for the unified list
ROW_GROUP_HEADER = "group"
ROW_REPO = "repo"


def build_rows(repos: list[dict]) -> list[tuple[str, str, list[int] | int]]:
    """Build a flat list of rows: group headers + repo items, grouped by group.

    Returns [(type, label, payload), ...] where:
      - group header: (ROW_GROUP_HEADER, group_name, [repo_indices])
      - repo item:    (ROW_REPO, repo_name, repo_index)

    Repos not in any group go under "ungrouped".
    """
    groups = get_groups(repos)
    grouped_indices: set[int] = set()
    rows: list[tuple] = []

    for group_name, indices in groups.items():
        rows.append((ROW_GROUP_HEADER, group_name, indices))
        for i in indices:
            rows.append((ROW_REPO, repos[i]["name"], i))
            grouped_indices.add(i)

    # Ungrouped repos
    ungrouped = [i for i in range(len(repos)) if i not in grouped_indices]
    if ungrouped:
        rows.append((ROW_GROUP_HEADER, "ungrouped", ungrouped))
        for i in ungrouped:
            rows.append((ROW_REPO, repos[i]["name"], i))

    return rows


def tui_select_repos(stdscr, repos: list[dict]) -> list[dict] | None:
    """Unified TUI: grouped list with group headers as select-all toggles."""
    curses.curs_set(0)
    curses.use_default_colors()

    if curses.has_colors():
        curses.init_pair(1, curses.COLOR_GREEN, -1)   # selected
        curses.init_pair(2, curses.COLOR_WHITE, -1)    # unselected
        curses.init_pair(3, curses.COLOR_CYAN, -1)     # group header
        curses.init_pair(4, curses.COLOR_YELLOW, -1)   # cursor

    rows = build_rows(repos)
    selected: set[int] = set()
    cursor = 0

    while True:
        stdscr.clear()
        stdscr.addstr(0, 0, "Select repos", curses.A_BOLD)
        stdscr.addstr(1, 0, "↑↓ navigate  space toggle  enter confirm  a all  n none  q quit", curses.A_DIM)

        for row_idx, (rtype, label, payload) in enumerate(rows):
            y = row_idx + 3
            is_cur = row_idx == cursor

            if rtype == ROW_GROUP_HEADER:
                group_indices = payload
                all_sel = all(i in selected for i in group_indices)
                any_sel = any(i in selected for i in group_indices)

                if all_sel:
                    marker = "●"
                elif any_sel:
                    marker = "◐"
                else:
                    marker = "○"

                pointer = "▸" if is_cur else " "
                count = f"{sum(1 for i in group_indices if i in selected)}/{len(group_indices)}"
                attr = curses.color_pair(3) | curses.A_BOLD
                stdscr.addstr(y, 0, f" {pointer} {marker} {label} ({count})", attr)

            else:  # ROW_REPO
                repo_idx = payload
                is_sel = repo_idx in selected

                if is_sel:
                    marker = "●"
                    name_attr = curses.color_pair(1)
                else:
                    marker = "○"
                    name_attr = curses.color_pair(2)

                if is_cur:
                    pointer = "▸"
                    name_attr |= curses.A_BOLD
                else:
                    pointer = " "

                stdscr.addstr(y, 0, f" {pointer}   {marker} {label}", name_attr)

        count_y = len(rows) + 4
        stdscr.addstr(count_y, 0, f"  {len(selected)}/{len(repos)} selected", curses.A_DIM)

        stdscr.refresh()
        key = stdscr.getch()

        if key in (curses.KEY_UP, ord("k")):
            cursor = max(0, cursor - 1)
        elif key in (curses.KEY_DOWN, ord("j")):
            cursor = min(len(rows) - 1, cursor + 1)
        elif key == ord(" "):
            rtype, _, payload = rows[cursor]
            if rtype == ROW_GROUP_HEADER:
                group_indices = payload
                if all(i in selected for i in group_indices):
                    selected -= set(group_indices)
                else:
                    selected |= set(group_indices)
            else:
                selected.symmetric_difference_update({payload})
        elif key == ord("\n"):
            if not selected:
                stdscr.addstr(count_y + 1, 0, "  Select at least one repo.", curses.A_BOLD)
                stdscr.refresh()
                stdscr.getch()
                continue
            return [repos[i] for i in sorted(selected)]
        elif key == ord("a"):
            selected = set(range(len(repos)))
        elif key == ord("n"):
            selected = set()
        elif key == ord("q"):
            return None


# ── Moon integration ─────────────────────────────────────────────────


def generate_moon_config(workspace_dir: Path, selected_repos: list[dict]) -> None:
    """Generate .moon/workspace.yml at root and moon.yml per project with tasks.

    Per-project moon.yml is ignored by jj via workspace-scoped snapshot.auto-track.
    """
    moon_dir = workspace_dir / ".moon"
    moon_dir.mkdir(parents=True, exist_ok=True)

    # .moon/workspace.yml — project mapping
    lines = ["projects:"]
    for repo in selected_repos:
        lines.append(f'  {repo["name"]}: "{repo["name"]}"')
    (moon_dir / "workspace.yml").write_text("\n".join(lines) + "\n")

    # Per-project moon.yml with tasks + jj ignore
    for repo in selected_repos:
        tasks = repo.get("tasks", {})
        if not tasks:
            continue

        repo_dir = workspace_dir / repo["name"]

        # Generate moon.yml
        moon_yml_lines = ["tasks:"]
        for task_name, task_config in tasks.items():
            moon_yml_lines.append(f"  {task_name}:")
            moon_yml_lines.append(f'    command: "{task_config["command"]}"')
            if "deps" in task_config:
                moon_yml_lines.append("    deps:")
                for dep in task_config["deps"]:
                    moon_yml_lines.append(f"      - {dep}")
        (repo_dir / "moon.yml").write_text("\n".join(moon_yml_lines) + "\n")

        # Tell jj to ignore moon.yml in this workspace
        subprocess.run(
            [
                "jj", "config", "set", "--workspace",
                "snapshot.auto-track",
                '"all() & ~glob:\\"moon.yml\\""',
            ],
            cwd=repo_dir,
            capture_output=True,
            text=True,
        )


def generate_zed_tasks(workspace_dir: Path, selected_repos: list[dict]) -> None:
    """Generate .zed/tasks.json with moon run commands for all tasks."""
    all_task_names: set[str] = set()
    for repo in selected_repos:
        for task_name in repo.get("tasks", {}):
            all_task_names.add(task_name)

    zed_tasks = []

    # Workspace management
    ws_name = workspace_dir.name
    zed_tasks.append({
        "label": "workspace: update configs",
        "command": "workspace update",
        "use_new_terminal": False,
        "allow_concurrent_runs": False,
        "reveal": "always",
        "hide": "on_success",
    })
    zed_tasks.append({
        "label": "workspace: delete",
        "command": "workspace delete",
        "use_new_terminal": False,
        "allow_concurrent_runs": False,
        "reveal": "always",
        "hide": "never",
    })

    if not all_task_names:
        zed_dir = workspace_dir / ".zed"
        zed_dir.mkdir(parents=True, exist_ok=True)
        (zed_dir / "tasks.json").write_text(json.dumps(zed_tasks, indent=2) + "\n")
        return

    # Global tasks (run across all projects)
    for task_name in sorted(all_task_names):
        zed_tasks.append({
            "label": f"all: {task_name}",
            "command": f"moon run :{task_name}",
            "use_new_terminal": False,
            "allow_concurrent_runs": False,
            "reveal": "always",
            "hide": "on_success" if task_name != "dev" else "never",
        })

    # Per-project tasks
    for repo in selected_repos:
        for task_name in repo.get("tasks", {}):
            zed_tasks.append({
                "label": f"{repo['name']}: {task_name}",
                "command": f"moon run {repo['name']}:{task_name}",
                "use_new_terminal": False,
                "allow_concurrent_runs": False,
                "reveal": "always",
                "hide": "on_success" if task_name != "dev" else "never",
            })

    zed_dir = workspace_dir / ".zed"
    zed_dir.mkdir(parents=True, exist_ok=True)
    (zed_dir / "tasks.json").write_text(json.dumps(zed_tasks, indent=2) + "\n")


# ── Core logic ───────────────────────────────────────────────────────


def run(cmd: list[str], cwd: Path | None = None) -> subprocess.CompletedProcess:
    result = subprocess.run(cmd, cwd=cwd, capture_output=True, text=True)
    if result.returncode != 0:
        stderr = result.stderr.strip()
        die(f"command failed: {' '.join(cmd)}\n{stderr}")
    return result


def create_workspace(config: dict, name: str, selected_repos: list[dict],
                     skip_install: bool = False, skip_zed: bool = False) -> None:
    workspace_root = Path(config["workspace_root"]).expanduser()
    workspace_dir = workspace_root / name

    if workspace_dir.exists():
        die(f"workspace already exists: {workspace_dir}")

    workspace_dir.mkdir(parents=True)
    print(f"\nCreating workspace: {workspace_dir}\n")

    for repo in selected_repos:
        repo_name = repo["name"]
        local_path = Path(repo["local_path"]).expanduser()
        revision = repo.get("revision", "trunk()")
        dest = workspace_dir / repo_name

        if not local_path.exists():
            die(f"repo not found: {local_path}")

        print(f"  {repo_name}: creating jj workspace...")
        run(["jj", "workspace", "add", "--revision", revision, str(dest)], cwd=local_path)

    regenerate_configs(config, workspace_dir, selected_repos)

    # Open workspace folder in Zed (before install so it's ready while deps install)
    if not skip_zed:
        print(f"  Opening in Zed...")
        subprocess.run(["zed", "-n", str(workspace_dir)])

    # Run install tasks via moon if any project has one
    has_install = any(repo.get("tasks", {}).get("install") for repo in selected_repos)
    if has_install and not skip_install:
        print(f"\n  Running install via moon...\n")
        result = subprocess.run(
            ["moon", "run", ":install"],
            cwd=workspace_dir,
        )
        if result.returncode != 0:
            print(f"  warning: moon run :install had failures", file=sys.stderr)

    print(f"\nWorkspace ready: {workspace_dir}")
    print(f"  Run tasks:  cd {workspace_dir} && moon run :<task>")


def regenerate_configs(config: dict, workspace_dir: Path, selected_repos: list[dict]) -> None:
    """Regenerate moon, zed, and AGENTS.md configs for a workspace."""
    generate_moon_config(workspace_dir, selected_repos)
    print(f"  Generated moon config")

    # Assemble AGENTS.md
    agents_parts = [config.get("agents_md", {}).get("template", "").strip()]
    for repo in selected_repos:
        section = repo.get("agents_md", "").strip()
        if section:
            agents_parts.append(section)

    agents_content = "\n\n".join(part for part in agents_parts if part) + "\n"
    agents_path = workspace_dir / "AGENTS.md"
    agents_path.write_text(agents_content)
    print(f"  Wrote {agents_path}")

    generate_zed_tasks(workspace_dir, selected_repos)
    print(f"  Generated .zed/tasks.json")


def resolve_workspace_dir(config: dict, name: str | None) -> Path:
    """Resolve workspace directory from name or cwd."""
    workspace_root = Path(config["workspace_root"]).expanduser()

    if name:
        workspace_dir = workspace_root / name
    else:
        # Try to detect from cwd
        cwd = Path.cwd()
        if cwd.parent == workspace_root:
            workspace_dir = cwd
        elif cwd == workspace_root:
            die("run from inside a workspace directory, or pass a name")
        else:
            # Check if cwd is inside a workspace (e.g. in a repo subdir)
            for parent in cwd.parents:
                if parent.parent == workspace_root:
                    workspace_dir = parent
                    break
            else:
                die("not inside a workspace — pass a name or cd into one")

    if not workspace_dir.exists():
        die(f"workspace not found: {workspace_dir}")

    return workspace_dir


def detect_workspace_repos(config: dict, workspace_dir: Path) -> list[dict]:
    """Detect which configured repos are present in a workspace directory."""
    all_repos = config.get("repos", [])
    repo_by_name = {r["name"]: r for r in all_repos}
    selected = []
    for subdir in sorted(workspace_dir.iterdir()):
        if subdir.is_dir() and not subdir.name.startswith(".") and subdir.name in repo_by_name:
            selected.append(repo_by_name[subdir.name])
    return selected


def update_workspace(config: dict, name: str | None) -> None:
    workspace_dir = resolve_workspace_dir(config, name)
    selected_repos = detect_workspace_repos(config, workspace_dir)

    if not selected_repos:
        die(f"no configured repos found in {workspace_dir}")

    print(f"Updating workspace: {workspace_dir}\n")
    regenerate_configs(config, workspace_dir, selected_repos)
    print(f"\nWorkspace updated.")


def delete_workspace(config: dict, name: str | None) -> None:
    if name:
        workspace_root = Path(config["workspace_root"]).expanduser()
        workspace_dir = workspace_root / name
    else:
        workspace_dir = resolve_workspace_dir(config, None)
        confirm = input(f"Delete workspace {workspace_dir.name}? [y/N] ").strip()
        if confirm.lower() != "y":
            print("Cancelled.")
            return

    if not workspace_dir.exists():
        die(f"workspace not found: {workspace_dir}")

    repos = config.get("repos", [])
    repo_dirs = {r["name"]: Path(r["local_path"]).expanduser() for r in repos}

    for subdir in sorted(workspace_dir.iterdir()):
        if not subdir.is_dir() or subdir.name.startswith("."):
            continue
        if subdir.name in repo_dirs:
            local_path = repo_dirs[subdir.name]
            print(f"  {subdir.name}: forgetting jj workspace")
            result = subprocess.run(
                ["jj", "workspace", "forget", subdir.name],
                cwd=local_path,
                capture_output=True,
                text=True,
            )
            if result.returncode != 0:
                print(f"  warning: jj workspace forget failed for {subdir.name}: {result.stderr.strip()}")

    shutil.rmtree(workspace_dir)
    print(f"Deleted workspace: {workspace_dir}")


def get_original_repo(workspace_repo_dir: Path) -> Path | None:
    """Get the original repo root from a jj workspace directory.

    Workspace .jj/repo contains the path to the original repo's .jj/repo.
    """
    repo_file = workspace_repo_dir / ".jj" / "repo"
    if not repo_file.exists():
        return None
    original_jj_repo = repo_file.read_text().strip()
    return Path(original_jj_repo).parent.parent


def load_review_data(workspace_dir: Path) -> list[dict]:
    """Gather jj commit data for each repo in the workspace.

    Returns list of dicts with keys:
        name, original_dir, commits (list, oldest first),
        current_edit (change_id of default@), temp_commits (list of change_ids)

    Each commit dict has: change_id, description, empty, files, bookmarks
    """
    repos = []
    for subdir in sorted(workspace_dir.iterdir()):
        if not subdir.is_dir() or subdir.name.startswith("."):
            continue
        if not (subdir / ".jj").is_dir():
            continue

        name = subdir.name
        original = get_original_repo(subdir)
        if not original:
            continue

        # Get commits between trunk and workspace head (newest first from jj)
        log_result = subprocess.run(
            ["jj", "log", "--no-pager", "-r", f"trunk()..{name}@", "--no-graph",
             "-T", 'change_id.shortest() ++ "\t"'
                   '++ description.first_line() ++ "\t"'
                   '++ if(empty, "empty", "changed") ++ "\t"'
                   '++ bookmarks.join(",") ++ "\n"'],
            cwd=original, capture_output=True, text=True,
        )

        commits = []
        if log_result.returncode == 0:
            for line in log_result.stdout.strip().split("\n"):
                if not line.strip():
                    continue
                parts = line.split("\t", 3)
                if len(parts) < 3:
                    continue
                cid = parts[0].strip()
                desc = parts[1].strip() or "(no description)"
                status = parts[2].strip()
                bookmarks_str = parts[3].strip() if len(parts) > 3 else ""
                bookmarks = [b for b in bookmarks_str.split(",") if b] if bookmarks_str else []

                # Get changed files for this commit
                files_result = subprocess.run(
                    ["jj", "diff", "--no-pager", "-r", cid, "--name-only"],
                    cwd=original, capture_output=True, text=True,
                )
                files = []
                if files_result.returncode == 0:
                    files = [f for f in files_result.stdout.strip().split("\n") if f]
                commits.append({
                    "change_id": cid,
                    "description": desc,
                    "empty": status == "empty",
                    "files": files,
                    "bookmarks": bookmarks,
                })

        # Reverse so oldest is first (index 0 = closest to trunk)
        commits.reverse()

        # What is default@ currently pointing at?
        cur_result = subprocess.run(
            ["jj", "log", "--no-pager", "-r", "default@", "--no-graph",
             "-T", "change_id.shortest()"],
            cwd=original, capture_output=True, text=True,
        )
        current_edit = cur_result.stdout.strip() if cur_result.returncode == 0 else ""

        repos.append({
            "name": name,
            "original_dir": original,
            "commits": commits,
            "current_edit": current_edit,
            "temp_commits": [],
        })

    return repos


def collect_bookmarks(repos: list[dict]) -> dict[str, list[tuple[str, int]]]:
    """Collect bookmarks across all repos.

    Returns {bookmark_name: [(repo_name, commit_index), ...]} sorted by name.
    Only includes repos that have commits.
    """
    bookmarks: dict[str, list[tuple[str, int]]] = {}
    for repo in repos:
        for ci, commit in enumerate(repo["commits"]):
            for bm in commit["bookmarks"]:
                bookmarks.setdefault(bm, []).append((repo["name"], ci))
    return dict(sorted(bookmarks.items()))


def jj_create_temp_squash(original_dir: Path, bottom_cid: str, top_cid: str) -> str | None:
    """Create a temporary squashed commit covering a range of commits.

    The temp commit's parent is parents(bottom_cid), its tree is top_cid's tree.
    Returns the temp commit's change_id, or None on failure.
    """
    # Create new commit as child of bottom's parent
    result = subprocess.run(
        ["jj", "new", f"parents({bottom_cid})",
         "-m", f"temp: reviewing {bottom_cid}..{top_cid}"],
        cwd=original_dir, capture_output=True, text=True,
    )
    if result.returncode != 0:
        return None

    # Get the new commit's change_id (it's now default@)
    cid_result = subprocess.run(
        ["jj", "log", "--no-pager", "-r", "default@", "--no-graph",
         "-T", "change_id.shortest()"],
        cwd=original_dir, capture_output=True, text=True,
    )
    if cid_result.returncode != 0:
        return None
    temp_cid = cid_result.stdout.strip()

    # Restore tree from the top of the range
    result = subprocess.run(
        ["jj", "restore", "--from", top_cid],
        cwd=original_dir, capture_output=True, text=True,
    )
    if result.returncode != 0:
        # Clean up the empty temp commit
        subprocess.run(["jj", "abandon", temp_cid],
                       cwd=original_dir, capture_output=True, text=True)
        return None

    return temp_cid


def jj_abandon_temp_commits(repos: list[dict]) -> None:
    """Abandon all temporary squash commits across repos."""
    for repo in repos:
        for temp_cid in repo["temp_commits"]:
            subprocess.run(
                ["jj", "abandon", temp_cid],
                cwd=repo["original_dir"], capture_output=True, text=True,
            )
        repo["temp_commits"].clear()





# ── Review: open Zed ────────────────────────────────────────────────


def review_open(config: dict, name: str | None) -> None:
    """Open all original repos from a workspace in a single Zed window."""
    workspace_dir = resolve_workspace_dir(config, name)

    original_dirs = []
    for subdir in sorted(workspace_dir.iterdir()):
        if not subdir.is_dir() or subdir.name.startswith("."):
            continue
        if not (subdir / ".jj").is_dir():
            continue
        original = get_original_repo(subdir)
        if original:
            original_dirs.append(str(original))

    if not original_dirs:
        die(f"no jj repos found in {workspace_dir}")

    print(f"Opening {len(original_dirs)} repo(s) in Zed...")
    subprocess.run(["zed", "-n"] + original_dirs)
    print(f"\nNow run `workspace review` in the Zed terminal to browse and switch commits.")


# ── Review: TUI controller ──────────────────────────────────────────


def jj_edit(original_dir: Path, change_id: str) -> bool:
    """Run jj edit in the original repo. Returns True on success."""
    result = subprocess.run(
        ["jj", "edit", change_id],
        cwd=original_dir, capture_output=True, text=True,
    )
    return result.returncode == 0


def apply_edit_or_range(repo: dict, row: int, visual_anchor: int | None) -> str:
    """Apply jj edit for a single commit or a squashed range.

    Returns a status message string.
    """
    original = repo["original_dir"]
    commits = repo["commits"]

    if visual_anchor is None:
        # Single commit
        commit = commits[row]
        ok = jj_edit(original, commit["change_id"])
        if ok:
            repo["current_edit"] = commit["change_id"]
            return f"✓ jj edit {commit['change_id']} in {repo['name']}"
        return f"✗ jj edit failed for {repo['name']}"

    # Range: oldest is lower index, newest is higher index
    lo = min(row, visual_anchor)
    hi = max(row, visual_anchor)
    bottom_cid = commits[lo]["change_id"]  # oldest (closest to trunk)
    top_cid = commits[hi]["change_id"]     # newest (closest to head)

    if lo == hi:
        # Degenerate range — single commit
        ok = jj_edit(original, bottom_cid)
        if ok:
            repo["current_edit"] = bottom_cid
            return f"✓ jj edit {bottom_cid} in {repo['name']}"
        return f"✗ jj edit failed for {repo['name']}"

    temp_cid = jj_create_temp_squash(original, bottom_cid, top_cid)
    if temp_cid:
        repo["temp_commits"].append(temp_cid)
        repo["current_edit"] = temp_cid
        return f"✓ squash {bottom_cid}..{top_cid} → {temp_cid} in {repo['name']}"
    return f"✗ squash failed for {repo['name']}"


def apply_bookmark(repos_with_commits: list[dict], bookmark: str,
                   bookmark_map: dict[str, list[tuple[str, int]]]) -> str:
    """Navigate to a bookmark across all repos that have it.

    For single-commit bookmarks, does a plain jj edit.
    For bookmarks at the top of a multi-commit stack, squashes trunk..bookmark.
    Returns a status message.
    """
    entries = bookmark_map.get(bookmark, [])
    if not entries:
        return f"✗ bookmark {bookmark} not found"

    repo_by_name = {r["name"]: r for r in repos_with_commits}
    results = []

    for repo_name, commit_idx in entries:
        repo = repo_by_name.get(repo_name)
        if not repo:
            continue

        # The bookmark is on commits[commit_idx].
        # Range is from index 0 (oldest, closest to trunk) to commit_idx.
        if commit_idx == 0:
            # Single commit or first commit — plain edit
            cid = repo["commits"][commit_idx]["change_id"]
            ok = jj_edit(repo["original_dir"], cid)
            if ok:
                repo["current_edit"] = cid
                results.append(f"{repo_name}:{cid}")
            else:
                results.append(f"{repo_name}:✗")
        else:
            # Squash from oldest (0) to bookmark commit
            bottom_cid = repo["commits"][0]["change_id"]
            top_cid = repo["commits"][commit_idx]["change_id"]
            temp_cid = jj_create_temp_squash(repo["original_dir"], bottom_cid, top_cid)
            if temp_cid:
                repo["temp_commits"].append(temp_cid)
                repo["current_edit"] = temp_cid
                results.append(f"{repo_name}:{temp_cid}")
            else:
                results.append(f"{repo_name}:✗")

    return f"✓ bookmark {bookmark} → {', '.join(results)}"


def tui_review(stdscr, repos: list[dict], workspace_name: str) -> None:
    """TUI controller for reviewing workspace commits across repos."""
    curses.curs_set(0)
    curses.use_default_colors()

    if curses.has_colors():
        curses.init_pair(1, curses.COLOR_GREEN, -1)    # active/changed
        curses.init_pair(2, curses.COLOR_WHITE, -1)     # normal
        curses.init_pair(3, curses.COLOR_CYAN, -1)      # header/label
        curses.init_pair(4, curses.COLOR_YELLOW, -1)    # selected tab
        curses.init_pair(5, curses.COLOR_MAGENTA, -1)   # file paths
        curses.init_pair(6, curses.COLOR_RED, -1)       # visual range

    repos_with_commits = [r for r in repos if r["commits"]]
    all_repos = repos

    col = 0      # selected repo column
    row = 0      # selected commit row
    visual_anchor: int | None = None  # None = not in visual mode
    status_msg = ""
    bookmark_mode = False
    bookmark_filter = ""
    bookmark_cursor = 0

    def safe_addstr(y, x, text, attr=0):
        max_y, max_x = stdscr.getmaxyx()
        if y < 0 or y >= max_y or x >= max_x:
            return
        text = text[:max(0, max_x - x)]
        if text:
            try:
                stdscr.addstr(y, x, text, attr)
            except curses.error:
                pass

    def full_refresh():
        nonlocal repos_with_commits, all_repos, col, row, visual_anchor
        ws_dir = Path(f"~/workspaces/{workspace_name}").expanduser()
        # Preserve temp_commits across refresh
        old_temps = {r["name"]: r["temp_commits"] for r in all_repos}
        new_repos = load_review_data(ws_dir)
        for r in new_repos:
            r["temp_commits"] = old_temps.get(r["name"], [])
        all_repos[:] = new_repos
        repos_with_commits[:] = [r for r in new_repos if r["commits"]]
        if col >= len(repos_with_commits):
            col = max(0, len(repos_with_commits) - 1)
        if repos_with_commits and row >= len(repos_with_commits[col]["commits"]):
            row = max(0, len(repos_with_commits[col]["commits"]) - 1)
        visual_anchor = None

    def get_filtered_bookmarks() -> list[tuple[str, list[tuple[str, int]]]]:
        bm = collect_bookmarks(repos_with_commits)
        if not bookmark_filter:
            return list(bm.items())
        filt = bookmark_filter.lower()
        return [(name, entries) for name, entries in bm.items()
                if filt in name.lower()]

    while True:
        stdscr.clear()
        max_y, max_x = stdscr.getmaxyx()

        # ── Title bar ──
        title = f" review: {workspace_name} "
        safe_addstr(0, 0, title, curses.A_BOLD | curses.A_REVERSE)

        # ── Active diffs header ──
        safe_addstr(2, 0, " ACTIVE DIFFS", curses.A_BOLD | curses.color_pair(3))

        header_y = 3
        active_count = 0
        for repo in all_repos:
            if not repo["commits"]:
                continue
            cur = repo["current_edit"]
            desc = "(at trunk)"
            active = False
            for c in repo["commits"]:
                if c["change_id"] == cur:
                    desc = c["description"]
                    active = True
                    break
            # Also check if current_edit is a temp commit
            if not active and cur in repo["temp_commits"]:
                desc = "(squashed range)"
                active = True

            if not active:
                continue

            attr = curses.color_pair(1)
            line = f"  ● {repo['name']:<24s} {desc}"
            safe_addstr(header_y + active_count, 0, line[:max_x - 1], attr)
            active_count += 1

        if active_count == 0:
            safe_addstr(header_y, 0, "  (no active diffs)", curses.A_DIM)
            active_count = 1

        # ── Bookmark picker overlay ──
        if bookmark_mode:
            filtered = get_filtered_bookmarks()
            if bookmark_cursor >= len(filtered):
                bookmark_cursor = max(0, len(filtered) - 1)

            overlay_y = header_y + active_count + 1
            safe_addstr(overlay_y, 0, " BOOKMARKS (type to filter, enter to select, esc to cancel)",
                        curses.A_BOLD | curses.color_pair(3))
            overlay_y += 1
            safe_addstr(overlay_y, 0, f" > {bookmark_filter}█", curses.A_BOLD)
            overlay_y += 1
            safe_addstr(overlay_y, 0, "─" * max_x, curses.A_DIM)
            overlay_y += 1

            for bi, (bm_name, bm_entries) in enumerate(filtered):
                if overlay_y >= max_y - 2:
                    break
                is_cur = bi == bookmark_cursor
                repo_names = ", ".join(rn for rn, _ in bm_entries)
                pointer = "▸" if is_cur else " "
                attr = curses.A_BOLD if is_cur else 0
                line = f" {pointer} {bm_name}  ({repo_names})"
                safe_addstr(overlay_y, 0, line[:max_x - 1], attr | curses.color_pair(2))
                overlay_y += 1

            if not filtered:
                safe_addstr(overlay_y, 0, "   (no matching bookmarks)", curses.A_DIM)

            safe_addstr(max_y - 1, 0, " type:filter  ↑↓:navigate  enter:select  esc:cancel",
                        curses.A_DIM | curses.A_REVERSE)
            stdscr.refresh()

            key = stdscr.getch()
            if key == 27:  # ESC
                bookmark_mode = False
                bookmark_filter = ""
                bookmark_cursor = 0
            elif key in (curses.KEY_UP,):
                if bookmark_cursor > 0:
                    bookmark_cursor -= 1
            elif key in (curses.KEY_DOWN,):
                if bookmark_cursor < len(filtered) - 1:
                    bookmark_cursor += 1
            elif key in (curses.KEY_BACKSPACE, 127, ord("\b")):
                bookmark_filter = bookmark_filter[:-1]
                bookmark_cursor = 0
            elif key in (ord("\n"), curses.KEY_ENTER):
                if filtered:
                    bm_name, _ = filtered[bookmark_cursor]
                    bm_map = collect_bookmarks(repos_with_commits)
                    status_msg = apply_bookmark(repos_with_commits, bm_name, bm_map)
                bookmark_mode = False
                bookmark_filter = ""
                bookmark_cursor = 0
            elif 32 <= key < 127:
                bookmark_filter += chr(key)
                bookmark_cursor = 0
            continue

        # ── Repo tab bar ──
        tab_y = header_y + active_count + 1
        safe_addstr(tab_y, 0, "─" * max_x, curses.A_DIM)
        tab_y += 1

        if repos_with_commits:
            tab_x = 1
            for i, repo in enumerate(repos_with_commits):
                label = f" {repo['name']} "
                if i == col:
                    attr = curses.A_BOLD | curses.A_REVERSE | curses.color_pair(4)
                else:
                    attr = curses.color_pair(2)
                safe_addstr(tab_y, tab_x, label, attr)
                tab_x += len(label) + 1

            # ── Commit list ──
            list_y = tab_y + 1
            safe_addstr(list_y, 0, "─" * max_x, curses.A_DIM)
            list_y += 1

            repo = repos_with_commits[col]
            commits = repo["commits"]

            if row >= len(commits):
                row = max(0, len(commits) - 1)

            # Compute visual range
            vis_lo = vis_hi = None
            if visual_anchor is not None:
                vis_lo = min(row, visual_anchor)
                vis_hi = max(row, visual_anchor)

            y = list_y
            for ci, commit in enumerate(commits):
                if y >= max_y - 2:
                    break

                is_cursor = ci == row
                is_active = commit["change_id"] == repo["current_edit"]
                in_range = vis_lo is not None and vis_lo <= ci <= vis_hi

                if in_range:
                    attr = curses.color_pair(6) | curses.A_BOLD
                    marker = "▮" if is_active else "▯"
                elif is_active:
                    marker = "●"
                    attr = curses.color_pair(1)
                else:
                    marker = "○"
                    attr = curses.color_pair(2)

                pointer = "▸" if is_cursor else " "
                if is_cursor:
                    attr |= curses.A_BOLD

                cid = commit["change_id"]
                desc = commit["description"]
                bm_tag = ""
                if commit["bookmarks"]:
                    bm_tag = " ⊘ " + ",".join(commit["bookmarks"])

                line = f" {pointer}{marker} {desc}"
                tag = f"{bm_tag} [{cid}]"

                available = max_x - 2
                if len(line) + len(tag) + 1 <= available:
                    padding = available - len(line) - len(tag)
                    line = line + " " * padding + tag
                else:
                    line = line[:available - len(tag) - 1] + "… " + tag

                safe_addstr(y, 0, line[:max_x - 1], attr)
                y += 1

                # Expand files under cursor
                if is_cursor and commit["files"]:
                    for fpath in commit["files"]:
                        if y >= max_y - 2:
                            break
                        display = f"     {fpath}"
                        fattr = curses.color_pair(5) | curses.A_DIM
                        if in_range:
                            fattr = curses.color_pair(6) | curses.A_DIM
                        safe_addstr(y, 0, display[:max_x - 1], fattr)
                        y += 1
        else:
            tab_y += 1
            safe_addstr(tab_y, 1, "(no repos with commits)", curses.A_DIM)

        # ── Help bar ──
        if visual_anchor is not None:
            help_line = " VISUAL: j/k:extend  space/enter:apply range  v/esc:cancel"
        else:
            help_line = " h/l:repos  j/k:commits  space/enter:edit  v:range  b:bookmarks  r:refresh  q:quit"
        if status_msg:
            help_line = f" {status_msg}"
            status_msg = ""
        safe_addstr(max_y - 1, 0, help_line[:max_x - 1], curses.A_DIM | curses.A_REVERSE)

        stdscr.refresh()
        key = stdscr.getch()

        if key == ord("q"):
            return
        elif key in (ord("h"), curses.KEY_LEFT):
            if visual_anchor is None and repos_with_commits and col > 0:
                col -= 1
                row = 0
        elif key in (ord("l"), curses.KEY_RIGHT):
            if visual_anchor is None and repos_with_commits and col < len(repos_with_commits) - 1:
                col += 1
                row = 0
        elif key in (ord("k"), curses.KEY_UP):
            if row > 0:
                row -= 1
        elif key in (ord("j"), curses.KEY_DOWN):
            if repos_with_commits and row < len(repos_with_commits[col]["commits"]) - 1:
                row += 1
        elif key == ord("v"):
            if visual_anchor is None:
                visual_anchor = row
            else:
                visual_anchor = None
        elif key in (ord(" "), ord("\n"), curses.KEY_ENTER):
            if repos_with_commits:
                status_msg = apply_edit_or_range(
                    repos_with_commits[col], row, visual_anchor)
                visual_anchor = None
        elif key == ord("b"):
            bookmark_mode = True
            bookmark_filter = ""
            bookmark_cursor = 0
        elif key == ord("r"):
            status_msg = "refreshing..."
            stdscr.clear()
            safe_addstr(max_y // 2, max_x // 2 - 7, "Refreshing...", curses.A_BOLD)
            stdscr.refresh()
            full_refresh()
            status_msg = "✓ refreshed"


def review_tui(config: dict, name: str | None) -> None:
    """Launch the review TUI controller for a workspace."""
    workspace_dir = resolve_workspace_dir(config, name)
    repos = load_review_data(workspace_dir)

    if not repos:
        die(f"no jj repos found in {workspace_dir}")

    try:
        curses.wrapper(tui_review, repos, workspace_dir.name)
    finally:
        # Clean up temp commits on exit
        jj_abandon_temp_commits(repos)


def list_workspaces(config: dict) -> None:
    workspace_root = Path(config["workspace_root"]).expanduser()
    if not workspace_root.exists():
        print("No workspaces directory.")
        return

    workspaces = sorted(d for d in workspace_root.iterdir() if d.is_dir())
    if not workspaces:
        print("No workspaces.")
        return

    for ws in workspaces:
        repos = [d.name for d in sorted(ws.iterdir()) if d.is_dir() and not d.name.startswith(".")]
        print(f"  {ws.name}: {', '.join(repos) if repos else '(empty)'}")


# ── CLI ──────────────────────────────────────────────────────────────


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="workspace",
        description="Create and manage multi-repo workspaces with jj and moon.",
    )
    sub = parser.add_subparsers(dest="command", metavar="command")

    # create
    create_p = sub.add_parser("create", help="Create a new workspace")
    create_p.add_argument("name", nargs="?", help="Workspace name")
    create_p.add_argument(
        "-g", "--group", action="append", dest="groups", default=[],
        help="Select all repos in this group (repeatable)",
    )
    create_p.add_argument(
        "-r", "--repo", action="append", dest="repos", default=[],
        help="Select a specific repo by name (repeatable)",
    )
    create_p.add_argument(
        "--no-install", action="store_true",
        help="Skip running install tasks",
    )
    create_p.add_argument(
        "--no-zed", action="store_true",
        help="Don't open in Zed",
    )

    # update
    update_p = sub.add_parser("update", help="Regenerate configs from current config.toml")
    update_p.add_argument("name", nargs="?", help="Workspace name (or auto-detect from cwd)")

    # delete
    del_p = sub.add_parser("delete", help="Delete a workspace")
    del_p.add_argument("name", nargs="?", help="Workspace name (or auto-detect from cwd, with confirmation)")

    # review-open
    ro_p = sub.add_parser("review-open", help="Open original repos in Zed for reviewing workspace changes")
    ro_p.add_argument("name", nargs="?", help="Workspace name (or auto-detect from cwd)")

    # review
    rev_p = sub.add_parser("review", help="TUI controller for browsing and switching workspace commits")
    rev_p.add_argument("name", nargs="?", help="Workspace name (or auto-detect from cwd)")

    # list
    sub.add_parser("list", help="List existing workspaces")

    args = parser.parse_args()

    # Default to create when no subcommand
    if args.command is None:
        args.command = "create"
        args.name = None
        args.groups = []
        args.repos = []
        args.no_install = False
        args.no_zed = False

    return args


def resolve_repos_from_args(
    all_repos: list[dict],
    group_names: list[str],
    repo_names: list[str],
) -> list[dict]:
    """Resolve repos from --group and --repo flags."""
    groups = get_groups(all_repos)
    selected_indices: set[int] = set()

    for g in group_names:
        if g not in groups:
            die(f"unknown group: {g} (available: {', '.join(groups)})")
        selected_indices |= set(groups[g])

    repo_name_map = {r["name"]: i for i, r in enumerate(all_repos)}
    for r in repo_names:
        if r not in repo_name_map:
            die(f"unknown repo: {r} (available: {', '.join(repo_name_map)})")
        selected_indices.add(repo_name_map[r])

    return [all_repos[i] for i in sorted(selected_indices)]


def main() -> None:
    config = load_config()
    args = parse_args()

    if args.command == "create":
        all_repos = config.get("repos", [])
        if not all_repos:
            die("no repos configured in config.toml")

        # Resolve name
        name = args.name
        if not name:
            name = curses.wrapper(tui_input, "Workspace name:", validate_name)
            if not name:
                print("Cancelled.")
                sys.exit(0)
        else:
            err = validate_name(name)
            if err:
                die(err)

        workspace_root = Path(config["workspace_root"]).expanduser()
        if (workspace_root / name).exists():
            die(f"workspace already exists: {workspace_root / name}")

        # Resolve repo selection
        if args.groups or args.repos:
            selected = resolve_repos_from_args(all_repos, args.groups, args.repos)
            if not selected:
                die("no repos matched the given groups/repos")
        else:
            selected = curses.wrapper(tui_select_repos, all_repos)
            if not selected:
                print("Cancelled.")
                sys.exit(0)

        create_workspace(config, name, selected,
                         skip_install=args.no_install,
                         skip_zed=args.no_zed)

    elif args.command == "update":
        update_workspace(config, args.name)
    elif args.command == "delete":
        delete_workspace(config, args.name)
    elif args.command == "review-open":
        review_open(config, args.name)
    elif args.command == "review":
        review_tui(config, args.name)
    elif args.command == "list":
        list_workspaces(config)


if __name__ == "__main__":
    main()
