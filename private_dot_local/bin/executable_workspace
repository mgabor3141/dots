#!/usr/bin/env python3
"""Create workspaces from jj repos in a grove (a collection of related repositories).

A grove is a directory containing one or more jj repos alongside shared config
files (AGENTS.md, .moon/, .scripts/, .zed/, etc.). Workspaces are created in
.workspaces/<name>/ with jj workspace copies of each repo and symlinks to the
shared files.

Usage:
    workspace init                  Mark current directory as a grove
    workspace create <name>         Create a new workspace
    workspace sync [name]           Re-sync symlinks from grove root
    workspace delete [name]         Delete a workspace
    workspace list                  List workspaces in current grove
    workspace review [name]         TUI for browsing workspace commits
"""

import argparse
import curses
import shutil
import subprocess
import sys
from pathlib import Path


def die(msg: str) -> None:
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)


def run(cmd: list[str], cwd: Path | None = None) -> subprocess.CompletedProcess:
    result = subprocess.run(cmd, cwd=cwd, capture_output=True, text=True)
    if result.returncode != 0:
        stderr = result.stderr.strip()
        die(f"command failed: {' '.join(cmd)}\n{stderr}")
    return result


# ── Grove detection ──────────────────────────────────────────────────


def find_grove_root(start: Path | None = None) -> Path:
    """Walk up from start (default cwd) looking for .grove marker."""
    d = (start or Path.cwd()).resolve()
    while True:
        if (d / ".grove").exists():
            return d
        parent = d.parent
        if parent == d:
            die("not inside a grove (no .grove marker found)\n"
                "  Run 'workspace init' in the grove root first.")
        d = parent


def find_repos(grove_root: Path) -> list[Path]:
    """Find all repo directories (containing .jj/) in the grove root."""
    repos = []
    for d in sorted(grove_root.iterdir()):
        if d.is_dir() and not d.name.startswith(".") and (d / ".jj").is_dir():
            repos.append(d)
    return repos


def resolve_workspace_dir(grove_root: Path, name: str | None) -> Path:
    """Resolve workspace directory from name or cwd."""
    ws_root = grove_root / ".workspaces"

    if name:
        return ws_root / name

    cwd = Path.cwd().resolve()
    ws_root_resolved = ws_root.resolve()

    if cwd.parent == ws_root_resolved:
        return cwd

    for parent in cwd.parents:
        if parent.parent == ws_root_resolved:
            return parent

    die("not inside a workspace — pass a name or cd into one")


# ── Symlinking ───────────────────────────────────────────────────────


# Items at grove root that are never symlinked into workspaces.
SKIP_ITEMS = {".grove", ".workspaces", ".git", ".jj"}


def sync_symlinks(grove_root: Path, workspace_dir: Path) -> None:
    """Create/update symlinks from grove root into workspace.

    Everything in the grove root is symlinked except:
    - .grove, .workspaces, .git, .jj (infrastructure)
    - Repo directories (these get jj workspaces instead)
    - .moon/ is handled specially: contents are symlinked but cache/ stays local
    """
    repo_names = {r.name for r in find_repos(grove_root)}

    for item in sorted(grove_root.iterdir()):
        if item.name in SKIP_ITEMS or item.name in repo_names:
            continue

        target = workspace_dir / item.name

        if item.name == ".moon":
            _sync_moon_dir(item, target)
        else:
            _ensure_symlink(target, item)

    print(f"  Synced symlinks")


def _ensure_symlink(link_path: Path, target: Path) -> None:
    """Create a symlink, replacing any existing one."""
    resolved = target.resolve()
    if link_path.is_symlink():
        if link_path.resolve() == resolved:
            return
        link_path.unlink()
    elif link_path.exists():
        # Real file/dir exists — don't clobber it
        print(f"  warning: {link_path.name} exists and is not a symlink, skipping")
        return
    link_path.symlink_to(resolved)


def _sync_moon_dir(moon_src: Path, moon_dst: Path) -> None:
    """Symlink .moon/ contents except cache/ (which stays workspace-local)."""
    moon_dst.mkdir(exist_ok=True)

    for item in sorted(moon_src.iterdir()):
        if item.name == "cache":
            continue
        _ensure_symlink(moon_dst / item.name, item)


# ── Workspace operations ────────────────────────────────────────────


def init_grove() -> None:
    """Mark current directory as a grove root."""
    cwd = Path.cwd()
    marker = cwd / ".grove"

    if marker.exists():
        print(f"Already a grove: {cwd}")
        return

    repos = find_repos(cwd)
    marker.touch()
    (cwd / ".workspaces").mkdir(exist_ok=True)

    print(f"Initialized grove: {cwd}")
    if repos:
        print(f"  Found repos: {', '.join(r.name for r in repos)}")
    else:
        print(f"  No repos found yet — clone some jj repos here.")


def create_workspace(grove_root: Path, name: str,
                     skip_install: bool = False, skip_zed: bool = False) -> None:
    repos = find_repos(grove_root)
    if not repos:
        die(f"no repos found in {grove_root}")

    ws_root = grove_root / ".workspaces"
    ws_root.mkdir(exist_ok=True)
    ws_dir = ws_root / name

    if ws_dir.exists():
        die(f"workspace already exists: {ws_dir}")

    ws_dir.mkdir(parents=True)
    print(f"\nCreating workspace: {ws_dir}\n")

    # Create jj workspaces for each repo
    for repo_dir in repos:
        repo_name = repo_dir.name
        jj_ws_name = f"{name}-{repo_name}"
        dest = ws_dir / repo_name

        print(f"  {repo_name}: fetching and creating jj workspace...")
        subprocess.run(["jj", "git", "fetch"], cwd=repo_dir,
                       capture_output=True, text=True)
        run(["jj", "workspace", "add", "--name", jj_ws_name,
             "--revision", "trunk()", str(dest)], cwd=repo_dir)

    # Symlink shared files from grove root
    sync_symlinks(grove_root, ws_dir)

    # Open in Zed
    if not skip_zed:
        print(f"  Opening in Zed...")
        subprocess.run(["zed", "-n", str(ws_dir)])

    # Run workspace-install via moon
    if not skip_install and (grove_root / ".moon").is_dir():
        print(f"\n  Running moon run :workspace-install...\n")
        result = subprocess.run(
            ["moon", "run", ":workspace-install"],
            cwd=ws_dir,
        )
        if result.returncode != 0:
            print(f"  warning: workspace-install had failures", file=sys.stderr)

    print(f"\nWorkspace ready: {ws_dir}")


def sync_workspace(grove_root: Path, name: str | None) -> None:
    """Re-sync symlinks for an existing workspace."""
    ws_dir = resolve_workspace_dir(grove_root, name)
    if not ws_dir.exists():
        die(f"workspace not found: {ws_dir}")

    print(f"Syncing workspace: {ws_dir}\n")
    sync_symlinks(grove_root, ws_dir)
    print(f"\nWorkspace synced.")


def delete_workspace(grove_root: Path, name: str | None) -> None:
    if name:
        ws_dir = grove_root / ".workspaces" / name
    else:
        ws_dir = resolve_workspace_dir(grove_root, None)
        confirm = input(f"Delete workspace {ws_dir.name}? [y/N] ").strip()
        if confirm.lower() != "y":
            print("Cancelled.")
            return

    if not ws_dir.exists():
        die(f"workspace not found: {ws_dir}")

    repo_dirs = {r.name: r for r in find_repos(grove_root)}
    ws_name = ws_dir.name

    for subdir in sorted(ws_dir.iterdir()):
        if not subdir.is_dir() or subdir.name.startswith("."):
            continue
        if subdir.name in repo_dirs and (subdir / ".jj").is_dir():
            jj_ws_name = f"{ws_name}-{subdir.name}"
            print(f"  {subdir.name}: forgetting jj workspace")
            result = subprocess.run(
                ["jj", "workspace", "forget", jj_ws_name],
                cwd=repo_dirs[subdir.name],
                capture_output=True, text=True,
            )
            if result.returncode != 0:
                print(f"  warning: forget failed for {subdir.name}: "
                      f"{result.stderr.strip()}")

    shutil.rmtree(ws_dir)
    print(f"Deleted workspace: {ws_dir}")


def list_workspaces(grove_root: Path) -> None:
    ws_root = grove_root / ".workspaces"
    if not ws_root.exists():
        print("No workspaces.")
        return

    workspaces = sorted(d for d in ws_root.iterdir() if d.is_dir())
    if not workspaces:
        print("No workspaces.")
        return

    for ws in workspaces:
        repos = [d.name for d in sorted(ws.iterdir())
                 if d.is_dir() and not d.name.startswith(".")]
        print(f"  {ws.name}: {', '.join(repos) if repos else '(empty)'}")


# ── Review TUI ───────────────────────────────────────────────────────


def get_original_repo(workspace_repo_dir: Path) -> Path | None:
    """Get the original repo root from a jj workspace directory."""
    repo_file = workspace_repo_dir / ".jj" / "repo"
    if not repo_file.exists():
        return None
    original_jj_repo = repo_file.read_text().strip()
    return Path(original_jj_repo).parent.parent


def find_jj_root(start: Path | None = None) -> Path | None:
    """Walk up from start (default cwd) looking for a .jj directory."""
    d = (start or Path.cwd()).resolve()
    while True:
        if (d / ".jj").is_dir():
            return d
        parent = d.parent
        if parent == d:
            return None
        d = parent


def load_review_data(workspace_dir: Path, standalone: bool = False) -> list[dict]:
    """Gather jj commit data for each repo in the workspace."""
    if standalone:
        dirs = [(workspace_dir.name, workspace_dir, workspace_dir, "@")]
    else:
        dirs = []
        ws_name = workspace_dir.name
        for subdir in sorted(workspace_dir.iterdir()):
            if not subdir.is_dir() or subdir.name.startswith("."):
                continue
            if not (subdir / ".jj").is_dir():
                continue
            original = get_original_repo(subdir)
            if not original:
                continue
            jj_ws_name = f"{ws_name}-{subdir.name}"
            detect_result = subprocess.run(
                ["jj", "log", "--no-pager", "--ignore-working-copy",
                 "-r", f"{jj_ws_name}@", "--no-graph", "-T", "change_id"],
                cwd=original, capture_output=True, text=True,
            )
            if detect_result.returncode != 0 or not detect_result.stdout.strip():
                jj_ws_name = subdir.name
            dirs.append((subdir.name, subdir, original, f"{jj_ws_name}@"))

    repos = []
    for name, _subdir, original, head_revset in dirs:
        log_result = subprocess.run(
            ["jj", "log", "--no-pager", "--ignore-working-copy",
             "-r", f"trunk()..{head_revset}", "--no-graph",
             "-T", 'change_id ++ "\t"'
                   '++ change_id.shortest() ++ "\t"'
                   '++ description.first_line() ++ "\t"'
                   '++ if(empty, "empty", "changed") ++ "\t"'
                   '++ bookmarks.join(",") ++ "\n"'],
            cwd=original, capture_output=True, text=True,
        )

        commits = []
        if log_result.returncode == 0:
            for line in log_result.stdout.strip().split("\n"):
                if not line.strip():
                    continue
                parts = line.split("\t", 4)
                if len(parts) < 4:
                    continue
                full_cid = parts[0].strip()
                short_cid = parts[1].strip()
                desc = parts[2].strip() or "(no description)"
                status = parts[3].strip()
                bookmarks_str = parts[4].strip() if len(parts) > 4 else ""
                bookmarks = [b for b in bookmarks_str.split(",") if b] if bookmarks_str else []

                files_result = subprocess.run(
                    ["jj", "diff", "--no-pager", "--ignore-working-copy",
                     "-r", full_cid, "--name-only"],
                    cwd=original, capture_output=True, text=True,
                )
                files = []
                if files_result.returncode == 0:
                    files = [f for f in files_result.stdout.strip().split("\n") if f]
                commits.append({
                    "change_id": full_cid,
                    "short_id": short_cid,
                    "description": desc,
                    "empty": status == "empty",
                    "files": files,
                    "bookmarks": bookmarks,
                })

        commits = [c for c in reversed(commits) if not c["empty"]]

        cur_result = subprocess.run(
            ["jj", "log", "--no-pager", "--ignore-working-copy",
             "-r", "default@", "--no-graph",
             "-T", 'change_id ++ "\t" ++ description.first_line()'],
            cwd=original, capture_output=True, text=True,
        )
        current_edit = ""
        if cur_result.returncode == 0:
            parts = cur_result.stdout.strip().split("\t", 1)
            current_edit = parts[0]
            cur_desc = parts[1] if len(parts) > 1 else ""
            if cur_desc.startswith("temp: reviewing"):
                jj_update_stale(original)
                subprocess.run(
                    ["jj", "abandon", current_edit],
                    cwd=original, capture_output=True, text=True,
                )
                current_edit = ""

        repos.append({
            "name": name,
            "original_dir": original,
            "commits": commits,
            "current_edit": current_edit,
            "temp_commit": None,
            "active_range": None,
        })

    return repos


def jj_update_stale(original_dir: Path) -> None:
    """Fix stale working copy if needed."""
    subprocess.run(
        ["jj", "workspace", "update-stale"],
        cwd=original_dir, capture_output=True, text=True,
    )


def jj_edit(original_dir: Path, change_id: str) -> bool:
    """Run jj edit in the original repo. Returns True on success."""
    jj_update_stale(original_dir)
    result = subprocess.run(
        ["jj", "edit", change_id],
        cwd=original_dir, capture_output=True, text=True,
    )
    return result.returncode == 0


def jj_create_temp_squash(original_dir: Path, bottom_cid: str, top_cid: str) -> str | None:
    """Create a temporary squashed commit covering a range of commits."""
    jj_update_stale(original_dir)

    result = subprocess.run(
        ["jj", "new", f"parents({bottom_cid})",
         "-m", f"temp: reviewing {bottom_cid}..{top_cid}"],
        cwd=original_dir, capture_output=True, text=True,
    )
    if result.returncode != 0:
        return None

    cid_result = subprocess.run(
        ["jj", "log", "--no-pager", "-r", "default@", "--no-graph",
         "-T", "change_id"],
        cwd=original_dir, capture_output=True, text=True,
    )
    if cid_result.returncode != 0:
        return None
    temp_cid = cid_result.stdout.strip()

    result = subprocess.run(
        ["jj", "restore", "--from", top_cid],
        cwd=original_dir, capture_output=True, text=True,
    )
    if result.returncode != 0:
        subprocess.run(["jj", "abandon", temp_cid],
                       cwd=original_dir, capture_output=True, text=True)
        return None

    return temp_cid


def jj_resolve_successor(original_dir: Path, full_cid: str) -> str | None:
    """Try to find the successor of a change via evolog."""
    result = subprocess.run(
        ["jj", "log", "--no-pager", "--ignore-working-copy",
         "-r", full_cid, "--no-graph", "-T", "change_id"],
        cwd=original_dir, capture_output=True, text=True,
    )
    if result.returncode == 0 and result.stdout.strip():
        return result.stdout.strip()
    return None


def jj_abandon_temp(repo: dict) -> None:
    """Abandon the active temp commit for a repo, if any."""
    if repo.get("temp_commit"):
        jj_update_stale(repo["original_dir"])
        subprocess.run(
            ["jj", "abandon", repo["temp_commit"]],
            cwd=repo["original_dir"], capture_output=True, text=True,
        )
        repo["temp_commit"] = None


def jj_abandon_all_temps(repos: list[dict]) -> None:
    """Abandon all active temp commits across repos."""
    for repo in repos:
        jj_abandon_temp(repo)


def auto_select_full_ranges(repos: list[dict]) -> None:
    """Auto-select the full commit range for repos with commits but no active range."""
    for repo in repos:
        if repo["active_range"] is not None or not repo["commits"]:
            continue
        commits = repo["commits"]
        if len(commits) == 1:
            cid = commits[0]["change_id"]
            if jj_edit(repo["original_dir"], cid):
                repo["current_edit"] = cid
                repo["active_range"] = cid
        else:
            bottom_cid = commits[0]["change_id"]
            top_cid = commits[-1]["change_id"]
            temp_cid = jj_create_temp_squash(repo["original_dir"], bottom_cid, top_cid)
            if temp_cid:
                repo["temp_commit"] = temp_cid
                repo["current_edit"] = temp_cid
                repo["active_range"] = (bottom_cid, top_cid)


def collect_bookmarks(repos: list[dict]) -> dict[str, list[tuple[str, int]]]:
    """Collect bookmarks across all repos."""
    bookmarks: dict[str, list[tuple[str, int]]] = {}
    for repo in repos:
        for ci, commit in enumerate(repo["commits"]):
            for bm in commit["bookmarks"]:
                bookmarks.setdefault(bm, []).append((repo["name"], ci))
    return dict(sorted(bookmarks.items()))


def apply_edit_or_range(repo: dict, row: int, visual_anchor: int | None) -> str:
    """Apply jj edit for a single commit or a squashed range."""
    jj_abandon_temp(repo)
    original = repo["original_dir"]
    commits = repo["commits"]

    if visual_anchor is None:
        commit = commits[row]
        ok = jj_edit(original, commit["change_id"])
        if ok:
            repo["current_edit"] = commit["change_id"]
            repo["active_range"] = commit["change_id"]
            return f"✓ jj edit {commit['short_id']} in {repo['name']}"
        return f"✗ jj edit failed for {repo['name']}"

    lo = min(row, visual_anchor)
    hi = max(row, visual_anchor)
    bottom = commits[lo]
    top = commits[hi]

    if lo == hi:
        ok = jj_edit(original, bottom["change_id"])
        if ok:
            repo["current_edit"] = bottom["change_id"]
            repo["active_range"] = bottom["change_id"]
            return f"✓ jj edit {bottom['short_id']} in {repo['name']}"
        return f"✗ jj edit failed for {repo['name']}"

    temp_cid = jj_create_temp_squash(original, bottom["change_id"], top["change_id"])
    if temp_cid:
        repo["temp_commit"] = temp_cid
        repo["current_edit"] = temp_cid
        repo["active_range"] = (bottom["change_id"], top["change_id"])
        return f"✓ squash {bottom['short_id']}..{top['short_id']} in {repo['name']}"
    return f"✗ squash failed for {repo['name']}"


def apply_bookmark(repos_with_commits: list[dict], bookmark: str,
                   bookmark_map: dict[str, list[tuple[str, int]]]) -> str:
    """Navigate to a bookmark across all repos that have it."""
    entries = bookmark_map.get(bookmark, [])
    if not entries:
        return f"✗ bookmark {bookmark} not found"

    repo_by_name = {r["name"]: r for r in repos_with_commits}
    results = []

    for repo_name, commit_idx in entries:
        repo = repo_by_name.get(repo_name)
        if not repo:
            continue

        jj_abandon_temp(repo)

        if commit_idx == 0:
            cid = repo["commits"][commit_idx]["change_id"]
            ok = jj_edit(repo["original_dir"], cid)
            if ok:
                repo["current_edit"] = cid
                repo["active_range"] = cid
                results.append(f"{repo_name}:{cid}")
            else:
                results.append(f"{repo_name}:✗")
        else:
            bottom_cid = repo["commits"][0]["change_id"]
            top_cid = repo["commits"][commit_idx]["change_id"]
            temp_cid = jj_create_temp_squash(repo["original_dir"], bottom_cid, top_cid)
            if temp_cid:
                repo["temp_commit"] = temp_cid
                repo["current_edit"] = temp_cid
                repo["active_range"] = (bottom_cid, top_cid)
                results.append(f"{repo_name}:{temp_cid}")
            else:
                results.append(f"{repo_name}:✗")

    return f"✓ bookmark {bookmark} → {', '.join(results)}"


def tui_review(stdscr, repos: list[dict], workspace_name: str,
               reload_fn=None) -> None:
    """TUI controller for reviewing workspace commits across repos."""
    curses.curs_set(0)
    curses.use_default_colors()

    if curses.has_colors():
        curses.init_pair(1, curses.COLOR_GREEN, -1)
        curses.init_pair(2, curses.COLOR_WHITE, -1)
        curses.init_pair(3, curses.COLOR_CYAN, -1)
        curses.init_pair(4, curses.COLOR_YELLOW, -1)
        curses.init_pair(5, curses.COLOR_MAGENTA, -1)
        curses.init_pair(6, curses.COLOR_RED, -1)

    repos_with_commits = [r for r in repos if r["commits"]]
    all_repos = repos

    col = 0
    row = 0
    visual_anchor: int | None = None
    status_msg = ""
    bookmark_mode = False
    bookmark_filter = ""
    bookmark_cursor = 0

    def safe_addstr(y, x, text, attr=0):
        max_y, max_x = stdscr.getmaxyx()
        if y < 0 or y >= max_y or x >= max_x:
            return
        text = text[:max(0, max_x - x)]
        if text:
            try:
                stdscr.addstr(y, x, text, attr)
            except curses.error:
                pass

    def full_refresh():
        nonlocal repos_with_commits, all_repos, col, row, visual_anchor

        saved_ranges: dict[str, str | tuple[str, str] | None] = {}
        for r in all_repos:
            saved_ranges[r["name"]] = r.get("active_range")

        jj_abandon_all_temps(all_repos)
        new_repos = reload_fn()
        all_repos[:] = new_repos
        repos_with_commits[:] = [r for r in new_repos if r["commits"]]
        if col >= len(repos_with_commits):
            col = max(0, len(repos_with_commits) - 1)
        if repos_with_commits and row >= len(repos_with_commits[col]["commits"]):
            row = max(0, len(repos_with_commits[col]["commits"]) - 1)
        visual_anchor = None

        for repo in all_repos:
            ar = saved_ranges.get(repo["name"])
            if ar is None:
                continue
            cids = {c["change_id"] for c in repo["commits"]}

            def resolve(cid: str) -> str | None:
                if cid in cids:
                    return cid
                succ = jj_resolve_successor(repo["original_dir"], cid)
                return succ if succ and succ in cids else None

            if isinstance(ar, tuple):
                bottom = resolve(ar[0])
                top = resolve(ar[1])
                if bottom and top:
                    if bottom == top:
                        jj_edit(repo["original_dir"], bottom)
                        repo["current_edit"] = bottom
                        repo["active_range"] = bottom
                    else:
                        temp_cid = jj_create_temp_squash(
                            repo["original_dir"], bottom, top)
                        if temp_cid:
                            repo["temp_commit"] = temp_cid
                            repo["current_edit"] = temp_cid
                            repo["active_range"] = (bottom, top)
            else:
                resolved = resolve(ar)
                if resolved:
                    jj_edit(repo["original_dir"], resolved)
                    repo["current_edit"] = resolved
                    repo["active_range"] = resolved

        auto_select_full_ranges(all_repos)
        repos_with_commits[:] = [r for r in all_repos if r["commits"]]

    def get_filtered_bookmarks() -> list[tuple[str, list[tuple[str, int]]]]:
        bm = collect_bookmarks(repos_with_commits)
        if not bookmark_filter:
            return list(bm.items())
        filt = bookmark_filter.lower()
        return [(name, entries) for name, entries in bm.items()
                if filt in name.lower()]

    while True:
        stdscr.clear()
        max_y, max_x = stdscr.getmaxyx()

        title = f" review: {workspace_name} "
        safe_addstr(0, 0, title, curses.A_BOLD | curses.A_REVERSE)

        safe_addstr(2, 0, " ACTIVE DIFFS", curses.A_BOLD | curses.color_pair(3))

        header_y = 3
        active_count = 0
        for repo in all_repos:
            if not repo["commits"]:
                continue
            ar = repo.get("active_range")
            if ar is None:
                continue

            if isinstance(ar, tuple):
                bottom_desc = top_desc = "?"
                for c in repo["commits"]:
                    if c["change_id"] == ar[0]:
                        bottom_desc = c["short_id"]
                    if c["change_id"] == ar[1]:
                        top_desc = c["short_id"]
                desc = f"{bottom_desc}..{top_desc} (squashed range)"
            else:
                desc = "(at trunk)"
                for c in repo["commits"]:
                    if c["change_id"] == ar:
                        desc = c["description"]
                        break

            attr = curses.color_pair(1)
            line = f"  ● {repo['name']:<24s} {desc}"
            safe_addstr(header_y + active_count, 0, line[:max_x - 1], attr)
            active_count += 1

        if active_count == 0:
            safe_addstr(header_y, 0, "  (no active diffs)", curses.A_DIM)
            active_count = 1

        # Bookmark picker overlay
        if bookmark_mode:
            filtered = get_filtered_bookmarks()
            if bookmark_cursor >= len(filtered):
                bookmark_cursor = max(0, len(filtered) - 1)

            overlay_y = header_y + active_count + 1
            safe_addstr(overlay_y, 0, " BOOKMARKS (type to filter, enter to select, esc to cancel)",
                        curses.A_BOLD | curses.color_pair(3))
            overlay_y += 1
            safe_addstr(overlay_y, 0, f" > {bookmark_filter}█", curses.A_BOLD)
            overlay_y += 1
            safe_addstr(overlay_y, 0, "─" * max_x, curses.A_DIM)
            overlay_y += 1

            for bi, (bm_name, bm_entries) in enumerate(filtered):
                if overlay_y >= max_y - 2:
                    break
                is_cur = bi == bookmark_cursor
                repo_names = ", ".join(rn for rn, _ in bm_entries)
                pointer = "▸" if is_cur else " "
                attr = curses.A_BOLD if is_cur else 0
                line = f" {pointer} {bm_name}  ({repo_names})"
                safe_addstr(overlay_y, 0, line[:max_x - 1], attr | curses.color_pair(2))
                overlay_y += 1

            if not filtered:
                safe_addstr(overlay_y, 0, "   (no matching bookmarks)", curses.A_DIM)

            safe_addstr(max_y - 1, 0, " type:filter  ↑↓:navigate  enter:select  esc:cancel",
                        curses.A_DIM | curses.A_REVERSE)
            stdscr.refresh()

            key = stdscr.getch()
            if key == 27:
                bookmark_mode = False
                bookmark_filter = ""
                bookmark_cursor = 0
            elif key in (curses.KEY_UP,):
                if bookmark_cursor > 0:
                    bookmark_cursor -= 1
            elif key in (curses.KEY_DOWN,):
                if bookmark_cursor < len(filtered) - 1:
                    bookmark_cursor += 1
            elif key in (curses.KEY_BACKSPACE, 127, ord("\b")):
                bookmark_filter = bookmark_filter[:-1]
                bookmark_cursor = 0
            elif key in (ord("\n"), curses.KEY_ENTER):
                if filtered:
                    bm_name, _ = filtered[bookmark_cursor]
                    bm_map = collect_bookmarks(repos_with_commits)
                    status_msg = apply_bookmark(repos_with_commits, bm_name, bm_map)
                bookmark_mode = False
                bookmark_filter = ""
                bookmark_cursor = 0
            elif 32 <= key < 127:
                bookmark_filter += chr(key)
                bookmark_cursor = 0
            continue

        # Repo tab bar
        list_y = header_y + active_count + 1
        safe_addstr(list_y, 0, "─" * max_x, curses.A_DIM)
        list_y += 1

        if repos_with_commits:
            if len(repos_with_commits) > 1:
                tab_x = 1
                for i, repo in enumerate(repos_with_commits):
                    label = f" {repo['name']} "
                    if i == col:
                        attr = curses.A_BOLD | curses.A_REVERSE | curses.color_pair(4)
                    else:
                        attr = curses.color_pair(2)
                    safe_addstr(list_y, tab_x, label, attr)
                    tab_x += len(label) + 1
                list_y += 1

            repo = repos_with_commits[col]
            commits = repo["commits"]

            if row >= len(commits):
                row = max(0, len(commits) - 1)

            ar = repo.get("active_range")
            if ar is None:
                active_set = set()
            elif isinstance(ar, tuple):
                bottom_idx = next((i for i, c in enumerate(commits) if c["change_id"] == ar[0]), None)
                top_idx = next((i for i, c in enumerate(commits) if c["change_id"] == ar[1]), None)
                if bottom_idx is not None and top_idx is not None:
                    active_set = {commits[i]["change_id"] for i in range(bottom_idx, top_idx + 1)}
                else:
                    active_set = set()
            else:
                active_set = {ar}

            vis_lo = vis_hi = None
            if visual_anchor is not None:
                vis_lo = min(row, visual_anchor)
                vis_hi = max(row, visual_anchor)

            y = list_y
            for ci, commit in enumerate(commits):
                if y >= max_y - 2:
                    break

                is_cursor = ci == row
                cid = commit["change_id"]
                is_active = cid in active_set
                in_range = vis_lo is not None and vis_lo <= ci <= vis_hi

                if in_range:
                    attr = curses.color_pair(6) | curses.A_BOLD
                    marker = "▮" if is_active else "▯"
                elif is_active:
                    marker = "●"
                    attr = curses.color_pair(1)
                else:
                    marker = "○"
                    attr = curses.color_pair(2)

                pointer = "▸" if is_cursor else " "
                if is_cursor:
                    attr |= curses.A_BOLD

                short = commit["short_id"]
                desc = commit["description"]
                bm_tag = ""
                if commit["bookmarks"]:
                    bm_tag = " ⊘ " + ",".join(commit["bookmarks"])

                line = f" {pointer}{marker} {desc}"
                tag = f"{bm_tag} [{short}]"

                available = max_x - 2
                if len(line) + len(tag) + 1 <= available:
                    padding = available - len(line) - len(tag)
                    line = line + " " * padding + tag
                else:
                    line = line[:available - len(tag) - 1] + "… " + tag

                safe_addstr(y, 0, line[:max_x - 1], attr)
                y += 1

                if is_cursor and commit["files"]:
                    for fpath in commit["files"]:
                        if y >= max_y - 2:
                            break
                        display = f"     {fpath}"
                        fattr = curses.color_pair(5) | curses.A_DIM
                        if in_range:
                            fattr = curses.color_pair(6) | curses.A_DIM
                        safe_addstr(y, 0, display[:max_x - 1], fattr)
                        y += 1
        else:
            safe_addstr(list_y + 1, 1, "(no repos with commits)", curses.A_DIM)

        # Help bar
        if visual_anchor is not None:
            help_line = " VISUAL: j/k:extend  space/enter:apply range  v/esc:cancel"
        else:
            help_line = " h/l:repos  j/k:commits  space/enter:edit  v:range  a:all  b:bookmarks  r:refresh  q:quit"
        if status_msg:
            help_line = f" {status_msg}"
            status_msg = ""
        safe_addstr(max_y - 1, 0, help_line[:max_x - 1], curses.A_DIM | curses.A_REVERSE)

        stdscr.refresh()
        key = stdscr.getch()

        if key in (ord("q"), 27):
            return
        elif key in (ord("h"), curses.KEY_LEFT):
            if visual_anchor is None and repos_with_commits and col > 0:
                col -= 1
                row = 0
        elif key in (ord("l"), curses.KEY_RIGHT):
            if visual_anchor is None and repos_with_commits and col < len(repos_with_commits) - 1:
                col += 1
                row = 0
        elif key in (ord("k"), curses.KEY_UP):
            if row > 0:
                row -= 1
        elif key in (ord("j"), curses.KEY_DOWN):
            if repos_with_commits and row < len(repos_with_commits[col]["commits"]) - 1:
                row += 1
        elif key == ord("v"):
            if visual_anchor is None:
                visual_anchor = row
            else:
                visual_anchor = None
        elif key in (ord(" "), ord("\n"), curses.KEY_ENTER):
            if repos_with_commits:
                status_msg = apply_edit_or_range(
                    repos_with_commits[col], row, visual_anchor)
                visual_anchor = None
        elif key == ord("a"):
            if repos_with_commits:
                repo = repos_with_commits[col]
                commits = repo["commits"]
                if commits:
                    jj_abandon_temp(repo)
                    if len(commits) == 1:
                        cid = commits[0]["change_id"]
                        if jj_edit(repo["original_dir"], cid):
                            repo["current_edit"] = cid
                            repo["active_range"] = cid
                            status_msg = f"✓ selected all in {repo['name']}"
                    else:
                        bottom_cid = commits[0]["change_id"]
                        top_cid = commits[-1]["change_id"]
                        temp_cid = jj_create_temp_squash(repo["original_dir"], bottom_cid, top_cid)
                        if temp_cid:
                            repo["temp_commit"] = temp_cid
                            repo["current_edit"] = temp_cid
                            repo["active_range"] = (bottom_cid, top_cid)
                            status_msg = f"✓ selected all in {repo['name']}"
        elif key == ord("b"):
            bookmark_mode = True
            bookmark_filter = ""
            bookmark_cursor = 0
        elif key == ord("r"):
            status_msg = "refreshing..."
            stdscr.clear()
            safe_addstr(max_y // 2, max_x // 2 - 7, "Refreshing...", curses.A_BOLD)
            stdscr.refresh()
            full_refresh()
            status_msg = "✓ refreshed"


def review_tui(grove_root: Path | None, name: str | None,
               standalone_dir: Path | None = None) -> None:
    """Launch the review TUI controller."""
    if standalone_dir:
        repos = load_review_data(standalone_dir, standalone=True)
        display_name = standalone_dir.name
        reload_fn = lambda: load_review_data(standalone_dir, standalone=True)
    else:
        workspace_dir = resolve_workspace_dir(grove_root, name)
        if not workspace_dir.exists():
            die(f"workspace not found: {workspace_dir}")
        repos = load_review_data(workspace_dir)
        display_name = workspace_dir.name
        reload_fn = lambda: load_review_data(workspace_dir)

    if not repos:
        die("no jj repos found")

    auto_select_full_ranges(repos)

    try:
        curses.wrapper(tui_review, repos, display_name, reload_fn)
    except KeyboardInterrupt:
        pass
    finally:
        jj_abandon_all_temps(repos)


# ── CLI ──────────────────────────────────────────────────────────────


def validate_name(name: str) -> str | None:
    """Return error message if name is invalid, None if ok."""
    if not name.strip():
        return "Cannot be empty."
    if not all(c.isalnum() or c in "-_" for c in name):
        return "Use only alphanumeric, hyphens, underscores."
    return None


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="workspace",
        description="Create and manage workspaces in a grove of jj repos.",
    )
    sub = parser.add_subparsers(dest="command", metavar="command")

    # init
    sub.add_parser("init", help="Initialize current directory as a grove")

    # create
    create_p = sub.add_parser("create", help="Create a new workspace")
    create_p.add_argument("name", help="Workspace name")
    create_p.add_argument("--no-install", action="store_true",
                          help="Skip running workspace-install")
    create_p.add_argument("--no-zed", action="store_true",
                          help="Don't open in Zed")

    # sync
    sync_p = sub.add_parser("sync", help="Re-sync symlinks from grove root")
    sync_p.add_argument("name", nargs="?",
                        help="Workspace name (or auto-detect from cwd)")

    # delete
    del_p = sub.add_parser("delete", help="Delete a workspace")
    del_p.add_argument("name", nargs="?",
                       help="Workspace name (or auto-detect from cwd)")

    # list
    sub.add_parser("list", help="List workspaces in current grove")

    # review
    rev_p = sub.add_parser("review", help="TUI for browsing workspace commits")
    rev_p.add_argument("name", nargs="?",
                       help="Workspace name (or auto-detect from cwd)")

    return parser.parse_args()


def main() -> None:
    args = parse_args()

    if not args.command:
        # No subcommand — show help
        parse_args.__wrapped__ = True  # type: ignore
        sys.argv.append("--help")
        parse_args()
        return

    if args.command == "init":
        init_grove()
        return

    if args.command == "review":
        # Review supports standalone mode (single repo, no grove)
        if args.name:
            grove_root = find_grove_root()
            review_tui(grove_root, args.name)
        else:
            jj_root = find_jj_root()
            if jj_root:
                # Check if we're in a grove workspace or standalone repo
                try:
                    grove_root = find_grove_root()
                    review_tui(grove_root, None)
                except SystemExit:
                    review_tui(None, None, standalone_dir=jj_root)
            else:
                grove_root = find_grove_root()
                review_tui(grove_root, None)
        return

    # All other commands need a grove
    grove_root = find_grove_root()

    if args.command == "create":
        err = validate_name(args.name)
        if err:
            die(err)
        create_workspace(grove_root, args.name,
                         skip_install=args.no_install,
                         skip_zed=args.no_zed)

    elif args.command == "sync":
        sync_workspace(grove_root, args.name)

    elif args.command == "delete":
        delete_workspace(grove_root, args.name)

    elif args.command == "list":
        list_workspaces(grove_root)


if __name__ == "__main__":
    main()
