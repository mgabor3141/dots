#!/usr/bin/env bash
# SUDO_ASKPASS helper — shows a GUI password dialog.
# sudo uses this automatically when there's no TTY (e.g. from a non-interactive
# shell or agent). Over SSH (where a TTY exists), sudo prompts normally.

# Never pop up a GUI from an SSH session — the user can't see it.
# SSH_CONNECTION is set by sshd and propagates through to askpass.
if [ -n "$SSH_CONNECTION" ]; then
    exit 1
fi

# If WAYLAND_DISPLAY/DISPLAY aren't set, try to find a local compositor socket.
# This handles background processes (systemd services, agents) that lost the env
# var but are running on the local machine.
if [ -z "$WAYLAND_DISPLAY" ] && [ -z "$DISPLAY" ]; then
    XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
    for sock in "$XDG_RUNTIME_DIR"/wayland-*; do
        if [ -S "$sock" ]; then
            export WAYLAND_DISPLAY="$(basename "$sock")"
            export XDG_RUNTIME_DIR
            break
        fi
    done
    # Still nothing — no display available
    if [ -z "$WAYLAND_DISPLAY" ]; then
        exit 1
    fi
fi

# Extract the command being run from sudo's /proc/cmdline.
# Our PPID is the sudo process; its cmdline has the full invocation.
cmd=""
if [ -r "/proc/$PPID/cmdline" ]; then
    # Strip the -A flag since it's just an implementation detail
    cmd=$(tr '\0' ' ' < "/proc/$PPID/cmdline" | sed 's/ -A / /')
    if [ ${#cmd} -gt 200 ]; then
        cmd="${cmd:0:200}…"
    fi
fi

if [ -n "$cmd" ]; then
    exec zenity --entry --hide-text --title="sudo" \
        --text="$cmd" \
        --timeout=60 --width=500 2>/dev/null
else
    exec zenity --password --title="sudo" --timeout=60 2>/dev/null
fi
