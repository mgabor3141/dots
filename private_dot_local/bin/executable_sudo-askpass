#!/usr/bin/env bash
# SUDO_ASKPASS helper — shows a GUI password dialog.
# sudo uses this automatically when there's no TTY (e.g. from a non-interactive
# shell or agent). Over SSH (where a TTY exists), sudo prompts normally.
#
# sudo sanitizes the environment before calling askpass, stripping most
# variables. We reconstruct what's needed to connect to a Wayland display.

# XDG_RUNTIME_DIR is required for Wayland socket access
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"

# If WAYLAND_DISPLAY isn't set, try to find a running compositor's socket.
# This handles SSH sessions where the env var isn't forwarded.
if [ -z "$WAYLAND_DISPLAY" ] && [ -z "$DISPLAY" ]; then
    for sock in "$XDG_RUNTIME_DIR"/wayland-*; do
        if [ -S "$sock" ]; then
            export WAYLAND_DISPLAY="$(basename "$sock")"
            break
        fi
    done
    # Still nothing — no display available (truly headless)
    if [ -z "$WAYLAND_DISPLAY" ] && [ -z "$DISPLAY" ]; then
        exit 1
    fi
fi
# Build the dialog — use --entry --hide-text instead of --password
# because --password doesn't support --text
title="sudo"
if [ -n "$SUDO_ASKPASS_COMMAND" ]; then
    # Truncate long commands
    cmd="$SUDO_ASKPASS_COMMAND"
    if [ ${#cmd} -gt 200 ]; then
        cmd="${cmd:0:200}…"
    fi
    exec zenity --entry --hide-text --title="$title" \
        --text="Command:\n$cmd\n\nPassword:" \
        --timeout=60 2>/dev/null
else
    exec zenity --password --title="$title" --timeout=60 2>/dev/null
fi
