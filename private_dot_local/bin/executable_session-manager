#!/usr/bin/env bash
# session-manager — browse and attach to persistent abduco sessions
#
# Sessions are created by wrapper commands (e.g., `persist pi "fix bugs"`)
# that run long-running processes inside abduco. This tool is the UI for
# listing, attaching to, and killing those sessions.
#
# Usage:
#   session-manager              Show local sessions (fzf picker)
#   session-manager --hosts      Show sessions across all SSH hosts
#
# Detach from a session with Ctrl-\ (abduco default).
#
# Environment:
#   ABDUCO_SESSION=1   Set inside managed sessions to prevent nesting

set -Eeuo pipefail
trap 'echo "Error on line $LINENO: $BASH_COMMAND" >&2' ERR

# ── Config ──────────────────────────────────────────────────────────────────

HOSTNAME="$(hostname 2>/dev/null || echo unknown)"
SSH_TIMEOUT=3
IS_REMOTE=false; [[ -n "${SSH_CONNECTION:-}" ]] && IS_REMOTE=true

shorten() { echo "${1/#$HOME/\~}"; }

sock_for() { echo "$HOME/.abduco/${1}@${HOSTNAME}"; }

# ── Session discovery (via abduco native listing) ───────────────────────────

# Cache abduco output (one call for all queries).
# Format per line: [*| ] <day>\t<date>\t<pid>\t<name>
_ABDUCO_CACHE=""
_ABDUCO_CACHED=false
abduco_cache() {
    $_ABDUCO_CACHED && return
    _ABDUCO_CACHED=true
    _ABDUCO_CACHE="$(abduco 2>&1 || true)"
}

# For an abduco server PID, walk the process tree to find the deepest
# descendant's name — that's the "interesting" process the user cares about.
get_process_info() {
    local abduco_pid="$1"
    local pid child process=""
    pid="$(pgrep -P "$abduco_pid" 2>/dev/null | head -1 || true)"
    [[ -n "$pid" ]] || return 0
    # Walk down the process tree to find the leaf
    while true; do
        child="$(pgrep -P "$pid" 2>/dev/null | head -1 || true)"
        [[ -n "$child" ]] || break
        pid="$child"
    done
    process="$(ps -o comm= -p "$pid" 2>/dev/null || true)"
    echo "$pid $process"
}

# Get CWD of a process via /proc.
get_cwd() {
    readlink "/proc/$1/cwd" 2>/dev/null || true
}

# Parse abduco listing.  Output: name \t status \t process \t cwd
parse_sessions() {
    abduco_cache
    echo "$_ABDUCO_CACHE" | while IFS= read -r line; do
        [[ "$line" == Active* ]] && continue
        [[ -z "$line" ]] && continue

        local attached=false
        [[ "${line:0:1}" == "*" ]] && attached=true

        local pid name
        pid="$(awk -F'\t' '{gsub(/^ +/,"",$3); print $3}' <<<"$line")"
        name="$(awk -F'\t' '{print $4}' <<<"$line")"

        local status="detached"
        $attached && status="attached"

        local proc_info leaf_pid="" process="" cwd=""
        proc_info="$(get_process_info "$pid")"
        if [[ -n "$proc_info" ]]; then
            leaf_pid="${proc_info%% *}"
            process="${proc_info#* }"
            cwd="$(get_cwd "$leaf_pid")"
        fi

        printf '%s\t%s\t%s\t%s\n' "$name" "$status" "${process:--}" "$cwd"
    done
}

# List all sessions.  Output: name \t status \t process \t cwd
list_all() {
    parse_sessions
}

# ── SSH host discovery ──────────────────────────────────────────────────────

# Parse ~/.ssh/config for Host entries (skip wildcards, patterns).
list_ssh_hosts() {
    local config="$HOME/.ssh/config"
    [[ -f "$config" ]] || return 0
    awk '/^[Hh]ost[[:space:]]/ {
        for (i = 2; i <= NF; i++) {
            if ($i !~ /[*?!]/) print $i
        }
    }' "$config"
}

# Query a remote host for sessions.  Output: host \t name \t status \t process \t cwd
query_remote_host() {
    local host="$1"
    local output
    output="$(ssh -o ConnectTimeout="$SSH_TIMEOUT" \
                  -o BatchMode=yes \
                  -o StrictHostKeyChecking=accept-new \
                  "$host" \
                  'bash -lc "command -v session-manager >/dev/null 2>&1 && session-manager --list-all-raw"' \
              2>/dev/null)" || return 0
    [[ -z "$output" ]] && return 0
    while IFS=$'\t' read -r name status process cwd; do
        [[ -z "$name" ]] && continue
        printf '%s\t%s\t%s\t%s\t%s\n' "$host" "$name" "$status" "$process" "$cwd"
    done <<<"$output"
}

# Query remote hosts in parallel.  Output: host \t name \t status \t process \t cwd
query_remote_hosts() {
    local tmpdir
    tmpdir="$(mktemp -d)"

    local -a hosts=()
    while IFS= read -r host; do
        hosts+=("$host")
        query_remote_host "$host" > "$tmpdir/remote_${host}" &
    done < <(list_ssh_hosts)

    wait

    for host in "${hosts[@]+"${hosts[@]}"}"; do
        cat "$tmpdir/remote_${host}" 2>/dev/null || true
    done

    rm -rf "$tmpdir"
}

# ── Session lifecycle ───────────────────────────────────────────────────────

# Attach to a session.  Returns when detached (Ctrl-\) or session ends.
attach() {
    local name="$1"
    _ATTACHED_SESSION="$name"

    # Gather session info for post-attach context.
    local _leaf_pid="" _process=""
    abduco_cache
    local _pid
    _pid="$(echo "$_ABDUCO_CACHE" | awk -F'\t' -v n="$name" '$4 == n {gsub(/^ +/,"",$3); print $3}')"
    if [[ -n "$_pid" ]]; then
        local _pi
        _pi="$(get_process_info "$_pid")"
        _leaf_pid="${_pi%% *}"
        _process="${_pi#* }"
    fi

    # Background fixup: nudge pty size so TUI apps redraw correctly
    _post_attach "$_leaf_pid" &

    abduco -a "$name" 2>/dev/null || true
}

# Run in background after abduco attaches.  Sends SIGWINCH so TUI apps
# redraw at the correct dimensions.
_post_attach() {
    local leaf_pid="${1:-}"
    [[ -n "$leaf_pid" ]] || return 0
    sleep 0.1
    kill -WINCH "$leaf_pid" 2>/dev/null || true
}

# Returns true if the last attached session is still alive (was detached).
session_alive() {
    [[ -n "${_ATTACHED_SESSION:-}" ]] && [[ -S "$(sock_for "$_ATTACHED_SESSION")" ]]
}

# Remote session lifecycle (over SSH)
remote_attach() {
    local host="${1:-}" name="${2:-}"
    [[ -z "$host" || -z "$name" ]] && return 1
    exec ssh -t "$host" "bash -lc 'abduco -a \"$name\"'"
}

# ── fzf formatting ──────────────────────────────────────────────────────────

# Indicator logic:
#   green ●  = attached       green ○  = detached (process running)
#   dim ○    = detached idle

# All view:  ● pi:1 › ~/.config/foo › node   or  ○ pi:1 › ~/project
fmt_all() {
    local name="$1" status="$2" process="${3:-}" cwd="${4:-}"
    [[ "$process" == "-" ]] && process=""
    local dot
    _dot_for "$status" "$process"
    local label="\033[1m${name}\033[0m"
    [[ -n "$cwd" ]] && label="$label \033[2m›\033[0m $(shorten "$cwd")"
    [[ -n "$process" ]] && label="$label \033[2m›\033[0m $process"
    printf '%s\t%b %b' "$name" "$dot" "$label"
}

# Hosts view:  ● unraid › pi:1 › ~/docker › node
fmt_hosts() {
    local host="$1" name="$2" status="$3" process="${4:-}" cwd="${5:-}"
    [[ "$process" == "-" ]] && process=""
    local dot
    _dot_for "$status" "$process"
    local label="\033[1;35m${host}\033[0m \033[2m›\033[0m ${name}"
    [[ -n "$cwd" ]] && label="$label \033[2m›\033[0m $(shorten "${cwd:-?}")"
    [[ -n "$process" ]] && label="$label \033[2m›\033[0m $process"
    printf '%s@%s\t%b %b' "$name" "$host" "$dot" "$label"
}

_dot_for() {
    local status="$1" process="$2"
    if [[ "$status" == "attached" ]]; then
        dot="\033[32m●\033[0m"
    elif [[ -n "$process" ]]; then
        dot="\033[32m○\033[0m"
    else
        dot="\033[2m○\033[0m"
    fi
}

# Extract the session name from fzf output (first tab-delimited field)
extract_name() {
    awk -F'\t' '{print $1}' <<<"${1:-}"
}

# ── Kill helpers ────────────────────────────────────────────────────────────

kill_session() {
    local name="${1:-}"
    [[ -z "$name" ]] && return 0
    local sock
    sock="$(sock_for "$name")"
    [[ -S "$sock" ]] && rm -f "$sock"
}

kill_session_full() {
    local name="${1:-}"
    [[ -z "$name" ]] && return 0
    kill_session "$name"
    abduco_cache
    local pid
    pid="$(echo "$_ABDUCO_CACHE" | awk -F'\t' -v n="$name" '$4 == n {gsub(/^ +/,"",$3); print $3}')"
    if [[ -n "$pid" ]]; then
        kill "$pid" 2>/dev/null || true
    fi
}

kill_session_any() {
    local key="${1:-}"
    [[ -z "$key" ]] && return 0
    local name="${key%%@*}"
    local host="${key##*@}"
    if [[ "$host" == "$HOSTNAME" ]]; then
        kill_session "$name"
    else
        ssh -o ConnectTimeout="$SSH_TIMEOUT" -o BatchMode=yes \
            "$host" "bash -lc \"session-manager --kill-session '$name'\"" 2>/dev/null || true
    fi
}

# ── List commands for fzf reload ────────────────────────────────────────────

list_all_fmt() {
    _ABDUCO_CACHED=false
    local found=false
    while IFS=$'\t' read -r name status process cwd; do
        [[ -z "$name" ]] && continue
        printf '%b\n' "$(fmt_all "$name" "$status" "$process" "$cwd")"
        found=true
    done < <(list_all)
    $found || printf '\t  \033[2mno sessions\033[0m\n'
}

list_hosts_fmt() {
    _ABDUCO_CACHED=false
    local found=false
    while IFS= read -r host; do
        found=true
    done < <(list_ssh_hosts)
    while IFS=$'\t' read -r host name status process cwd; do
        [[ -z "$host" ]] && continue
        printf '%b\n' "$(fmt_hosts "$host" "$name" "$status" "$process" "$cwd")"
        found=true
    done < <(query_remote_hosts)
    $found || printf '\t  \033[2mno remote hosts configured in ~/.ssh/config\033[0m\n'
}

# ── Pickers ─────────────────────────────────────────────────────────────────

pick_local() {
    local self="$0"
    local header
    header="$(printf '\033[1;32mSessions\033[0m'
             $IS_REMOTE || printf '  \033[2mctrl-a › hosts\033[0m'
             printf '\n\033[36menter\033[0m attach  \033[33mctrl-x\033[0m kill')"

    local -a fzf_args=(
        --ansi --header="$header"
        --delimiter='\t' --with-nth=2
        --no-sort --reverse --height=16
        --bind "ctrl-x:execute-silent($self --kill-session {1})+reload-sync($self --list-all-fmt)+transform(echo pos\(\$FZF_POS\))"
    )
    $IS_REMOTE || fzf_args+=(--expect=ctrl-a)

    local chosen
    chosen="$(list_all_fmt | fzf "${fzf_args[@]}")" || true

    [[ -z "$chosen" ]] && return

    local key="" line=""
    if $IS_REMOTE; then
        # No --expect: fzf outputs just the selected line
        line="$(head -1 <<<"$chosen")"
    else
        key="$(head -1 <<<"$chosen")"
        line="$(sed -n '2p' <<<"$chosen")"
    fi

    case "$key" in
        ctrl-a) pick_hosts; return ;;
    esac

    if [[ -n "$line" ]]; then
        local name
        name="$(extract_name "$line")"
        [[ -n "$name" ]] && attach "$name"
    fi
}

pick_hosts() {
    local self="$0"
    local header
    header="$(printf '\033[1;35mRemote sessions\033[0m  \033[2mctrl-a › local\033[0m\n'
             printf '\033[36menter\033[0m attach  \033[33mctrl-x\033[0m kill')"
    local chosen

    chosen="$(printf '\t  \033[2mloading…\033[0m\n' \
        | fzf --ansi --header="$header" \
              --delimiter='\t' --with-nth=2 \
              --expect=ctrl-a \
              --no-sort --reverse --height=16 \
              --bind "load:reload($self --list-hosts-fmt)+unbind(load)" \
              --bind "ctrl-x:execute-silent($self --kill-session-any {1})+reload-sync($self --list-hosts-fmt)+transform(echo pos\(\$FZF_POS\))")" || true

    [[ -z "$chosen" ]] && return

    local key line
    key="$(head -1 <<<"$chosen")"
    line="$(sed -n '2p' <<<"$chosen")"

    case "$key" in
        ctrl-a) pick_local; return ;;
    esac

    if [[ -n "$line" ]]; then
        local session_key
        session_key="$(extract_name "$line")"
        local sname="${session_key%%@*}"
        local shost="${session_key##*@}"
        remote_attach "$shost" "$sname"
    fi
}

# ── SSH agent ───────────────────────────────────────────────────────────────

fixup_ssh_agent() {
    if [[ -n "${SSH_AUTH_SOCK:-}" && "$SSH_AUTH_SOCK" != "$HOME/.ssh/agent.sock" ]]; then
        ln -sf "$SSH_AUTH_SOCK" "$HOME/.ssh/agent.sock" 2>/dev/null || true
    fi
}

# ── Main ────────────────────────────────────────────────────────────────────

main() {
    local mode="local"

    while (( $# )); do
        case "$1" in
            -H|--hosts)  mode="hosts"; shift ;;
            -h|--help)
                cat <<-'EOF'
				Usage: session-manager [options]

				  session-manager              Browse local sessions
				  session-manager --hosts      Browse remote sessions

				Sessions are created by wrapper commands (e.g., persist).
				Detach with Ctrl-\ to return to your shell.
				EOF
                exit 0 ;;
            # Internal commands (used by fzf --bind and remote SSH)
            --kill-session)       [[ -n "${2:-}" ]] && kill_session "$2"; exit ;;
            --kill-session-any)   [[ -n "${2:-}" ]] && kill_session_any "$2"; exit ;;
            --list-all-fmt)       list_all_fmt; exit ;;
            --list-all-raw)       _ABDUCO_CACHED=false; parse_sessions; exit ;;
            --list-hosts-raw)     _ABDUCO_CACHED=false; query_remote_hosts; exit ;;
            --list-hosts-fmt)     list_hosts_fmt; exit ;;
            *) echo "session-manager: unknown option: $1" >&2; exit 1 ;;
        esac
    done

    fixup_ssh_agent

    while true; do
        _ABDUCO_CACHED=false

        case "$mode" in
            local) pick_local ;;
            hosts)
                if $IS_REMOTE; then
                    echo "session-manager: hosts view disabled over SSH" >&2
                    exit 1
                fi
                pick_hosts ;;
        esac

        # After attach returns: session alive → detached → show picker again
        if session_alive; then
            mode="local"
            continue
        fi
        break
    done
}

main "$@"
