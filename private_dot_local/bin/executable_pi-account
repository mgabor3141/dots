#!/usr/bin/env bash
trap 'echo "Error on line $LINENO: $BASH_COMMAND" >&2' ERR
set -Eeuo pipefail

AUTH_DIR="$HOME/.pi/agent"
AUTH_FILE="$AUTH_DIR/auth.json"
PROFILES_FILE="$AUTH_DIR/anthropic-profiles.json"

ensure_files() {
    mkdir -p "$AUTH_DIR"
    [[ -f "$AUTH_FILE" ]] || echo '{}' > "$AUTH_FILE"
    if [[ ! -f "$PROFILES_FILE" ]]; then
        echo '{}' > "$PROFILES_FILE"
        chmod 600 "$PROFILES_FILE"
    fi
}

current_anthropic() {
    jq -c '.anthropic // empty' "$AUTH_FILE"
}

profiles() {
    jq -r 'keys[]' "$PROFILES_FILE"
}

cmd_save() {
    local label="$1"
    ensure_files
    local current
    current="$(current_anthropic)"
    if [[ -z "$current" ]]; then
        echo "No anthropic credentials in auth.json to save." >&2
        exit 1
    fi
    jq --arg l "$label" --argjson v "$current" '.[$l] = $v' "$PROFILES_FILE" > "$PROFILES_FILE.tmp"
    mv "$PROFILES_FILE.tmp" "$PROFILES_FILE"
    chmod 600 "$PROFILES_FILE"
    echo "Saved current anthropic credentials as '$label'."
}

cmd_use() {
    local label="$1"
    ensure_files
    local profile
    profile="$(jq -c --arg l "$label" '.[$l] // empty' "$PROFILES_FILE")"
    if [[ -z "$profile" ]]; then
        echo "No profile named '$label'. Available:" >&2
        profiles >&2
        exit 1
    fi
    jq --argjson v "$profile" '.anthropic = $v' "$AUTH_FILE" > "$AUTH_FILE.tmp"
    mv "$AUTH_FILE.tmp" "$AUTH_FILE"
    chmod 600 "$AUTH_FILE"
    echo "Switched anthropic credentials to '$label'."
}

cmd_list() {
    ensure_files
    local current
    current="$(current_anthropic)"
    if [[ -z "$(profiles)" ]]; then
        echo "No saved profiles."
        return
    fi
    while IFS= read -r label; do
        local saved
        saved="$(jq -c --arg l "$label" '.[$l]' "$PROFILES_FILE")"
        if [[ "$saved" == "$current" ]]; then
            echo "* $label"
        else
            echo "  $label"
        fi
    done < <(profiles)
}

cmd_rm() {
    local label="$1"
    ensure_files
    if [[ "$(jq --arg l "$label" 'has($l)' "$PROFILES_FILE")" != "true" ]]; then
        echo "No profile named '$label'." >&2
        exit 1
    fi
    jq --arg l "$label" 'del(.[$l])' "$PROFILES_FILE" > "$PROFILES_FILE.tmp"
    mv "$PROFILES_FILE.tmp" "$PROFILES_FILE"
    chmod 600 "$PROFILES_FILE"
    echo "Removed profile '$label'."
}

usage() {
    cat <<EOF
Usage: pi-account <command> [args]

Commands:
  save <label>   Save current anthropic credentials under <label>
  use <label>    Switch anthropic credentials to <label>
  list           Show saved profiles (* = active)
  rm <label>     Remove a saved profile
EOF
}

case "${1:-}" in
    save)  [[ -n "${2:-}" ]] || { usage >&2; exit 1; }; cmd_save "$2" ;;
    use)   [[ -n "${2:-}" ]] || { usage >&2; exit 1; }; cmd_use "$2" ;;
    list)  cmd_list ;;
    rm)    [[ -n "${2:-}" ]] || { usage >&2; exit 1; }; cmd_rm "$2" ;;
    *)     usage; exit 1 ;;
esac
