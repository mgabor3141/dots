#!/usr/bin/env bash
#
# pr-status — Show status of your recent PRs across multiple GitHub repos.
#
# Auto-discovers repos from subdirectories (or CWD). Groups PRs by ticket ID,
# shows review state, CI status, and deployment status (preprod/prod) when
# detectable from CI commit statuses or branch models.
#
# Usage:
#   pr-status [options]
#
# Options:
#   --days N       Look back N days (default: 30)
#   --author USER  GitHub username (default: @me)
#   --no-deploy    Skip deployment checks (faster)
#   --slack        Output Slack-formatted markdown
#   --help         Show this help
#
set -euo pipefail

DAYS=30
AUTHOR="@me"
CHECK_DEPLOY=true
SLACK=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --days)      DAYS="$2"; shift 2 ;;
        --author)    AUTHOR="$2"; shift 2 ;;
        --no-deploy) CHECK_DEPLOY=false; shift ;;
        --slack)     SLACK=true; shift ;;
        --help|-h)   sed -n '3,18p' "$0" | sed -E 's/^# ?//'; exit 0 ;;
        *)           echo "Unknown option: $1" >&2; exit 1 ;;
    esac
done

SINCE=$(date -u -v-"${DAYS}d" +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || date -u -d "-${DAYS} days" +"%Y-%m-%dT%H:%M:%SZ")

TMPDIR=$(mktemp -d)
trap 'rm -rf "$TMPDIR"' EXIT

# ============================================================
# Repo discovery: find git repos in CWD or subdirectories
# ============================================================

discover_repos() {
    # Each line: repo_name\tgit_dir\towner/repo
    # Check CWD first (regular git repo or jj workspace)
    if [[ -d ".git" ]] || [[ -d ".jj" ]] || git rev-parse --git-dir &>/dev/null; then
        emit_repo "."
        return
    fi
    # Check subdirectories
    for dir in */; do
        [[ -d "$dir" ]] || continue
        dir="${dir%/}"
        emit_repo "$dir" || true
    done
}

emit_repo() {
    local dir="$1"
    local git_dir=""

    # Direct .git directory
    if [[ -d "${dir}/.git" ]]; then
        git_dir="${dir}/.git"
    # Colocated jj+git: .git is a file pointing elsewhere
    elif [[ -f "${dir}/.git" ]]; then
        git_dir=$(GIT_DIR= git -C "$dir" rev-parse --git-dir 2>/dev/null) || return
    # jj workspace: follow .jj/repo -> main repo -> store/git_target
    elif [[ -d "${dir}/.jj" ]]; then
        local repo_path="${dir}/.jj/repo"
        # .jj/repo can be a symlink, directory, or a file containing a path
        if [[ -f "$repo_path" && ! -d "$repo_path" ]]; then
            repo_path=$(cat "$repo_path")
        fi
        local git_target_file="${repo_path}/store/git_target"
        if [[ -f "$git_target_file" ]]; then
            local rel_target
            rel_target=$(cat "$git_target_file")
            local store_dir
            store_dir=$(cd "$(dirname "$git_target_file")" && pwd)
            # Resolve the relative path (which points to a .git dir, not something you cd into)
            git_dir=$(cd "$store_dir" && realpath "$rel_target" 2>/dev/null) || return
            [[ -d "$git_dir" ]] || return
        elif [[ -d "${repo_path}/store" ]]; then
            # Main jj repo (not a workspace), check for colocated .git
            local jj_root
            jj_root=$(dirname "$(dirname "$repo_path")")
            if [[ -d "${jj_root}/.git" ]]; then
                git_dir="${jj_root}/.git"
            else
                return
            fi
        else
            return
        fi
    else
        return
    fi

    # Extract owner/repo from remote URL
    local remote_url
    remote_url=$(GIT_DIR="$git_dir" git remote get-url origin 2>/dev/null) || return
    local owner_repo
    owner_repo=$(echo "$remote_url" | sed -E 's|.*github\.com[:/]||; s|\.git$||')

    local repo_name
    repo_name=$(echo "$owner_repo" | sed 's|.*/||')

    echo "${repo_name}	${git_dir}	${owner_repo}"
}

# Discover repos
mapfile -t REPO_LINES < <(discover_repos)

if [[ ${#REPO_LINES[@]} -eq 0 ]]; then
    echo "No git repos found in current directory or subdirectories." >&2
    exit 1
fi

# Parse into arrays
REPO_NAMES=()
REPO_GIT_DIRS=()
REPO_OWNER_REPOS=()
for line in "${REPO_LINES[@]}"; do
    IFS=$'\t' read -r name git_dir owner_repo <<< "$line"
    REPO_NAMES+=("$name")
    REPO_GIT_DIRS+=("$git_dir")
    REPO_OWNER_REPOS+=("$owner_repo")
done

# Write repo metadata as JSON for the Python renderer
python3 -c "
import json, sys
names = sys.argv[1].split('\x1f')
git_dirs = sys.argv[2].split('\x1f')
owner_repos = sys.argv[3].split('\x1f')
repos = []
for n, g, o in zip(names, git_dirs, owner_repos):
    repos.append({'name': n, 'git_dir': g, 'owner_repo': o})
json.dump(repos, open('$TMPDIR/_repos.json', 'w'))
" "$(IFS=$'\x1f'; echo "${REPO_NAMES[*]}")" "$(IFS=$'\x1f'; echo "${REPO_GIT_DIRS[*]}")" "$(IFS=$'\x1f'; echo "${REPO_OWNER_REPOS[*]}")"

T_START=$SECONDS
printf '\033[2mFetching PRs across %d repos...\033[0m\n' "${#REPO_NAMES[@]}" >&2

# ============================================================
# Phase 1: Fetch PRs from all repos in parallel
# ============================================================

for i in "${!REPO_NAMES[@]}"; do
    repo="${REPO_NAMES[$i]}"
    git_dir="${REPO_GIT_DIRS[$i]}"
    (
        GIT_DIR="$git_dir" gh pr list \
            --author "$AUTHOR" --state all --limit 50 \
            --json number,title,state,isDraft,createdAt,mergedAt,mergeCommit,headRefName,baseRefName,author,reviews,reviewRequests,statusCheckRollup,url \
            2>/dev/null | python3 -c "
import sys, json
since = '$SINCE'
prs = json.load(sys.stdin)
filtered = []
for pr in prs:
    created = pr.get('createdAt', '')
    merged = pr.get('mergedAt', '')
    if created >= since or (merged and merged >= since):
        pr['_repo'] = '$repo'
        filtered.append(pr)
json.dump(filtered, sys.stdout)
" > "$TMPDIR/${repo}.json"
    ) &
done

wait
T_PHASE1=$((SECONDS - T_START))

# ============================================================
# Phase 2: Detect deployment status per repo
# ============================================================
#
# Strategy per repo (auto-detected):
# 1. CI status contexts: walk back from HEAD on the default branch, look for
#    commit statuses containing "promote" or "deploy" paired with "prod"/"preprod"/"staging".
#    If found, use ancestry checks.
# 2. Branch model: if origin/release and origin/develop exist, use branch tips.
# 3. Fallback: merged = deployed.

T_PHASE2_START=$SECONDS
if [[ "$CHECK_DEPLOY" == true ]]; then
    printf '\033[2mChecking deployment status...\033[0m\n' >&2

    for i in "${!REPO_NAMES[@]}"; do
        repo="${REPO_NAMES[$i]}"
        git_dir="${REPO_GIT_DIRS[$i]}"
        owner_repo="${REPO_OWNER_REPOS[$i]}"
        (
            warnings_file="$TMPDIR/${repo}-warnings.txt"
            out_file="$TMPDIR/${repo}-deploy.json"
            prs_file="$TMPDIR/${repo}.json"

            # Detect default branch
            default_branch=$(GIT_DIR="$git_dir" git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||') || true
            if [[ -z "$default_branch" ]]; then
                for candidate in main master develop; do
                    if GIT_DIR="$git_dir" git rev-parse "origin/${candidate}" &>/dev/null; then
                        default_branch="$candidate"
                        break
                    fi
                done
            fi
            [[ -z "$default_branch" ]] && { echo '{}' > "$out_file"; exit 0; }

            # Check for develop/release branch model first (no API calls needed)
            if GIT_DIR="$git_dir" git rev-parse origin/release &>/dev/null && \
               GIT_DIR="$git_dir" git rev-parse origin/develop &>/dev/null; then
                last_prod=$(GIT_DIR="$git_dir" git rev-parse origin/release 2>/dev/null) || true
                last_preprod=$(GIT_DIR="$git_dir" git rev-parse origin/develop 2>/dev/null) || true
            else
                # Single GraphQL query: fetch commit statuses for recent commits
                # on the default branch, then find deploy markers in the results.
                owner="${owner_repo%%/*}"
                repo_name="${owner_repo##*/}"

                IFS='|' read -r last_preprod last_prod < <(GIT_DIR="$git_dir" gh api graphql -f query="
                    query {
                      repository(owner: \"${owner}\", name: \"${repo_name}\") {
                        object(expression: \"${default_branch}\") {
                          ... on Commit {
                            history(first: 30) {
                              nodes {
                                oid
                                status {
                                  contexts {
                                    context
                                    state
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }" 2>/dev/null | python3 -c "
import sys, json, re

data = json.load(sys.stdin)
nodes = data.get('data', {}).get('repository', {}).get('object', {}).get('history', {}).get('nodes', [])

# Collect all unique context names across all commits
all_contexts = set()
for node in nodes:
    status = node.get('status') or {}
    for ctx in status.get('contexts', []):
        all_contexts.add(ctx.get('context', ''))

# Discover prod/preprod deploy context names
prod_ctx = None
preprod_ctx = None
for ctx in sorted(all_contexts):
    if re.search(r'promot|deploy', ctx, re.I):
        if re.search(r'prod', ctx, re.I) and not re.search(r'pre-?prod|staging', ctx, re.I):
            if not prod_ctx:
                prod_ctx = ctx
        if re.search(r'pre-?prod|staging', ctx, re.I):
            if not preprod_ctx:
                preprod_ctx = ctx

if not prod_ctx and not preprod_ctx:
    print('NONE|NONE')
    sys.exit(0)

# Walk commits to find most recent promoted to each env
last_preprod = ''
last_prod = ''
for node in nodes:
    oid = node['oid']
    status = node.get('status') or {}
    by_ctx = {c['context']: c['state'] for c in status.get('contexts', [])}
    if prod_ctx and not last_prod and by_ctx.get(prod_ctx) == 'SUCCESS':
        last_prod = oid
    if preprod_ctx and not last_preprod and by_ctx.get(preprod_ctx) == 'SUCCESS':
        last_preprod = oid
    if (last_prod or not prod_ctx) and (last_preprod or not preprod_ctx):
        break

print(f'{last_preprod}|{last_prod}')
" || echo "|") || true

                # Handle "NONE|NONE" from no-pipeline case
                if [[ "$last_preprod" == "NONE" ]]; then
                    python3 -c "
import json
prs = json.load(open('$prs_file'))
merged = [p for p in prs if p['state'] == 'MERGED' and p.get('mergeCommit')]
deploy_info = {p['number']: {'status': 'prod'} for p in merged}
json.dump(deploy_info, open('$out_file', 'w'))
"
                    exit 0
                fi

                if [[ -z "$last_preprod" ]]; then
                    echo "could not find last preprod deploy in recent history" >> "$warnings_file"
                fi
                if [[ -z "$last_prod" ]]; then
                    echo "could not find last prod deploy in recent history" >> "$warnings_file"
                fi
            fi

            # Check each merged PR via git merge-base --is-ancestor
            python3 -c "
import json, subprocess, sys, os

git_dir, prs_file, out_file, warnings_file = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]
last_preprod, last_prod = sys.argv[5], sys.argv[6]
env_vars = {**os.environ, 'GIT_DIR': git_dir}

prs = json.load(open(prs_file))
merged = [p for p in prs if p['state'] == 'MERGED' and p.get('mergeCommit')]
if not merged:
    json.dump({}, open(out_file, 'w'))
    sys.exit(0)

def is_ancestor(commit, of):
    if not of:
        return False
    try:
        subprocess.check_call(
            ['git', 'merge-base', '--is-ancestor', commit, of],
            env=env_vars, stderr=subprocess.DEVNULL, stdout=subprocess.DEVNULL, timeout=5
        )
        return True
    except:
        return False

deploy_info = {}
warnings = []
for pr in merged:
    sha = pr['mergeCommit']['oid']
    num = pr['number']
    if last_prod and is_ancestor(sha, last_prod):
        deploy_info[num] = {'status': 'prod'}
    elif last_preprod and is_ancestor(sha, last_preprod):
        deploy_info[num] = {'status': 'preprod'}
    elif not last_preprod and not last_prod:
        deploy_info[num] = {'status': 'unknown'}
    else:
        deploy_info[num] = {'status': 'merged'}
        base = pr.get('baseRefName', '')
        if base not in ('develop', 'main', 'master', ''):
            warnings.append(f'#{num}: merged into {base}')

json.dump(deploy_info, open(out_file, 'w'))
if warnings:
    with open(warnings_file, 'a') as f:
        f.write('\n'.join(warnings) + '\n')
" "$git_dir" "$prs_file" "$out_file" "$warnings_file" "$last_preprod" "$last_prod"
        ) &
    done

    wait

    # Print any warnings
    for repo in "${REPO_NAMES[@]}"; do
        wf="$TMPDIR/${repo}-warnings.txt"
        if [[ -f "$wf" ]]; then
            while IFS= read -r line; do
                printf '\033[0;33m  ⚠ %s: %s\033[0m\n' "$repo" "$line" >&2
            done < "$wf"
        fi
    done
fi
T_PHASE2=$((SECONDS - T_PHASE2_START))

printf '\033[2mDone (PRs: %ds, deploy: %ds)\033[0m\n' "$T_PHASE1" "$T_PHASE2" >&2

# ============================================================
# Phase 3: Merge everything and render output
# ============================================================

python3 -c '
import json, os, re, sys
from collections import OrderedDict

tmpdir = sys.argv[1]
check_deploy = sys.argv[2] == "true"
slack_mode = sys.argv[3] == "true" if len(sys.argv) > 3 else False

# Colors
BOLD = "\033[1m"
DIM = "\033[2m"
NC = "\033[0m"
RED = "\033[0;31m"
GREEN = "\033[0;32m"
YELLOW = "\033[0;33m"
BLUE = "\033[0;34m"
MAGENTA = "\033[0;35m"
CYAN = "\033[0;36m"

PALETTE = [CYAN, GREEN, MAGENTA, BLUE, YELLOW, RED]

# Load repo metadata
repos_meta = json.load(open(os.path.join(tmpdir, "_repos.json")))
repo_names = [r["name"] for r in repos_meta]

# Auto-generate short names and colors
MAX_REPO_NAME = 16

def shorten_repo_name(name):
    """Shorten long repo names by abbreviating leading segments to initials.
    e.g. freetrade-firebase-functions -> f-f-functions"""
    if len(name) <= MAX_REPO_NAME:
        return name
    sep = "-" if "-" in name else "_" if "_" in name else None
    if not sep:
        return name[:MAX_REPO_NAME - 1] + "…"
    parts = name.split(sep)
    if len(parts) < 2:
        return name[:MAX_REPO_NAME - 1] + "…"
    # Abbreviate segments from the left until it fits, keep last segment full
    for i in range(len(parts) - 1):
        parts[i] = parts[i][0] if parts[i] else parts[i]
        candidate = sep.join(parts)
        if len(candidate) <= MAX_REPO_NAME:
            return candidate
    return sep.join(parts)

REPO_SHORT = {}
REPO_COLORS = {}
for i, r in enumerate(repos_meta):
    name = r["name"]
    REPO_SHORT[name] = shorten_repo_name(name)
    REPO_COLORS[name] = PALETTE[i % len(PALETTE)]

# Compute max short name length for alignment
max_repo_len = max((len(v) for v in REPO_SHORT.values()), default=10) + 1

# Load all PRs
all_prs = []
for repo in repo_names:
    path = os.path.join(tmpdir, f"{repo}.json")
    if os.path.exists(path):
        try:
            prs = json.load(open(path))
            all_prs.extend(prs)
        except:
            pass

# Load deploy info
deploy_info = {}
for repo in repo_names:
    path = os.path.join(tmpdir, f"{repo}-deploy.json")
    if os.path.exists(path):
        try:
            info = json.load(open(path))
            deploy_info[repo] = {int(k): v for k, v in info.items()}
        except:
            pass

def get_review_info(pr):
    """Build per-reviewer summary with combined icons. Excludes PR author."""
    reviews = pr.get("reviews", []) or []
    requests = pr.get("reviewRequests", []) or []
    pr_author = (pr.get("author") or {}).get("login", "")

    reviewer_states = {}
    for r in reviews:
        author = (r.get("author") or {}).get("login", "")
        state = r.get("state", "")
        if not author or author == pr_author or author == "copilot-pull-request-reviewer":
            continue
        if author not in reviewer_states:
            reviewer_states[author] = set()
        if state in ("APPROVED", "CHANGES_REQUESTED", "COMMENTED"):
            reviewer_states[author].add(state)

    pending_set = set()
    for rr in requests:
        login = rr.get("login", "") or rr.get("name", "")
        if login and login != pr_author:
            pending_set.add(login)
            if login not in reviewer_states:
                reviewer_states[login] = set()

    reviewer_entries = []
    has_approval = False
    has_changes = False
    for login, states in reviewer_states.items():
        icons = []
        if "APPROVED" in states:
            icons.append(f"{GREEN}✅{NC}")
            has_approval = True
        if "CHANGES_REQUESTED" in states:
            icons.append(f"{RED}🔴{NC}")
            has_changes = True
        if "COMMENTED" in states:
            icons.append("💬")
        if login in pending_set:
            icons.append(f"{DIM}⏳{NC}")
        if icons:
            reviewer_entries.append(" ".join(icons) + " " + login)

    return {
        "entries": reviewer_entries,
        "has_approval": has_approval,
        "has_changes": has_changes,
        "has_pending": len(pending_set) > 0,
        "has_comments": any("COMMENTED" in s or "CHANGES_REQUESTED" in s for s in reviewer_states.values()),
    }

def get_ci_status(pr):
    """Summarize CI check status."""
    checks = pr.get("statusCheckRollup", []) or []
    checks = [c for c in checks if c.get("name")]
    if not checks:
        return None, []
    failed = [c["name"] for c in checks if c.get("conclusion") == "FAILURE"]
    pending = [c["name"] for c in checks if c.get("status") not in ("COMPLETED",) and c.get("name")]
    if failed:
        return "fail", failed
    if pending:
        return "pending", pending
    return "pass", []

def get_deploy_status(pr):
    """Determine deployment status for a merged PR."""
    repo = pr["_repo"]
    num = pr["number"]
    info = deploy_info.get(repo, {}).get(num, {})
    status = info.get("status", "unknown")
    if status == "prod":
        return "prod", None
    elif status == "preprod":
        return "preprod", None
    elif status == "unknown":
        return "unknown", "deploy status unavailable"
    else:
        return "merged", None

def format_status(pr):
    """Build the status string for a PR."""
    state = pr.get("state", "")
    is_draft = pr.get("isDraft", False)

    ri = None
    detail = ""
    color = ""
    if state == "CLOSED":
        emoji, label, color = "🚫", "closed", DIM
    elif state == "MERGED":
        if not check_deploy:
            emoji, label, color = "✅", "merged", GREEN
        else:
            deploy, detail = get_deploy_status(pr)
            if deploy == "prod":
                emoji, label, color = "✅", "prod", GREEN
            elif deploy == "preprod":
                emoji, label, color = "⬆️", "preprod", YELLOW
            elif deploy == "unknown":
                emoji, label, color = "❓", "merged", DIM
            else:
                emoji, label, color = "📦", "merged", BLUE
    else:
        ri = get_review_info(pr)
        if is_draft:
            emoji, label, color = "📝", "draft", DIM
        elif ri["has_changes"]:
            emoji, label, color = "🔴", "changes", RED
        elif ri["has_approval"]:
            emoji, label, color = "✅", "approved", GREEN
        elif ri["has_pending"]:
            emoji, label, color = "👀", "review", YELLOW
        elif ri["has_comments"]:
            emoji, label, color = "✏️", "revise", CYAN
        else:
            emoji, label, color = "👀", "review", YELLOW

    review_str = ""
    review_str_plain = ""
    if ri:
        entries = ri["entries"]
        if entries:
            review_str = "  ".join(entries)
        plain_entries = []
        for e in entries:
            plain_entries.append(re.sub(r"\033\[[^m]*m", "", e))
        if plain_entries:
            review_str_plain = "  ".join(plain_entries)

    ci, ci_detail = get_ci_status(pr)
    ci_str = ""
    ci_str_plain = ""
    if ci == "fail":
        names = ", ".join(ci_detail[:2])
        ci_str = f"{RED}CI:{NC} {names}"
        ci_str_plain = f"CI: {names}"
    elif ci == "pending":
        ci_str = f"{YELLOW}CI pending{NC}"
        ci_str_plain = "CI pending"

    parts = [p for p in [review_str, ci_str] if p]
    parts_plain = [p for p in [review_str_plain, ci_str_plain] if p]

    padded = label.ljust(9)
    if color:
        term_status = f"{color}{emoji}  {padded}{NC}"
    else:
        term_status = f"{emoji}  {padded}"

    return {
        "emoji": emoji,
        "label": label,
        "term_status": term_status,
        "detail": "  ".join(parts),
        "detail_plain": "  ".join(parts_plain),
    }

# Ticket extraction: first occurrence of JIRA-style ID in the title
TICKET_RE = re.compile(r"([A-Z]{2,}-\d+)", re.IGNORECASE)

def extract_ticket(title):
    m = TICKET_RE.search(title)
    if m:
        return m.group(1).upper()
    return None

def strip_ticket(title):
    """Remove ticket IDs and clean up leftover punctuation."""
    title = TICKET_RE.sub("", title)
    title = re.sub(r"\(\)\s*", "", title)
    title = re.sub(r"\[\]\s*", "", title)
    return title.strip().lstrip(":").strip()

# --- Group PRs by ticket ---
groups = OrderedDict()
ungrouped = []
active_prs = [pr for pr in all_prs if pr.get("state") != "CLOSED"]

for pr in active_prs:
    ticket = extract_ticket(pr.get("title", ""))
    if ticket:
        if ticket not in groups:
            groups[ticket] = []
        groups[ticket].append(pr)
    else:
        ungrouped.append(pr)

# Sort: open features first, then by recency
open_groups = [(t, p) for t, p in groups.items() if any(pr["state"] == "OPEN" for pr in p)]
done_groups = [(t, p) for t, p in groups.items() if not any(pr["state"] == "OPEN" for pr in p)]
open_groups.sort(key=lambda kv: max(pr.get("createdAt", "") for pr in kv[1]), reverse=True)
done_groups.sort(key=lambda kv: max(pr.get("mergedAt") or pr.get("createdAt", "") for pr in kv[1]), reverse=True)
sorted_groups = open_groups + done_groups

ungrouped.sort(key=lambda p: p.get("mergedAt") or p.get("createdAt", ""), reverse=True)

# --- Render ---

# Repo sort order: alphabetical by short name
repo_order = {name: i for i, name in enumerate(sorted(repo_names))}

def render_pr(pr):
    repo = pr["_repo"]
    repo_short = REPO_SHORT.get(repo, repo)
    repo_color = REPO_COLORS.get(repo, "")
    num = pr["number"]
    title_short = pr["title"]
    title_short = strip_ticket(title_short)
    if len(title_short) > 60:
        title_short = title_short[:57] + "..."

    s = format_status(pr)
    url = pr.get("url", "")
    s_emoji = s["emoji"]
    s_label = s["label"].ljust(9)
    s_term = s["term_status"]
    s_detail = s["detail"]
    s_detail_plain = s["detail_plain"]
    repo_pad = repo_short.ljust(max_repo_len)

    if slack_mode:
        line = f"{s_emoji} `{s_label}| {repo_pad}|`  {title_short}  [#{num}]({url})"
        if s_detail_plain:
            line += f"  {s_detail_plain}"
    else:
        pr_link = f"\033]8;;{url}\033\\#{num}\033]8;;\033\\"
        line = f"  {s_term}  {repo_color}{repo_pad}{NC}  {DIM}{title_short}{NC}  {pr_link}"
        if s_detail:
            line += f"  {s_detail}"
    print(line)

def render_header(ticket, title):
    if slack_mode:
        print(f"\n*{ticket}: {title}*")
    else:
        print(f"\n{BOLD}{ticket}: {title}{NC}")

for ticket, prs in sorted_groups:
    prs.sort(key=lambda p: (repo_order.get(p["_repo"], 99), 0 if p["state"] == "OPEN" else 1))

    top_repo = prs[0]["_repo"]
    top_repo_prs = [p for p in prs if p["_repo"] == top_repo]
    top_repo_prs.sort(key=lambda p: p.get("createdAt") or p.get("mergedAt", ""))
    best = top_repo_prs[0]["title"]
    best = strip_ticket(best)
    if len(best) > 70:
        best = best[:67] + "..."

    render_header(ticket, best)
    for pr in prs:
        render_pr(pr)

if ungrouped:
    if slack_mode:
        print(f"\n*Other*")
    else:
        print(f"\n{BOLD}Other{NC}")
    for pr in ungrouped:
        render_pr(pr)

' "$TMPDIR" "$CHECK_DEPLOY" "$SLACK"
