#!/usr/bin/env python3
"""
pr-status — Show status of your recent PRs across GitHub.

Discovers PRs globally using GitHub search, then enriches only the matching PRs
with per-repo detail. Groups PRs by ticket ID, shows review state, CI status,
and deployment status (preprod/prod) when detectable from branch models or CI
commit statuses.

Usage:
    pr-status [options]

Options:
    --days N         Look back N days (default: 30)
    --author USER    GitHub username (default: @me)
    --no-deploy      Skip deployment checks (faster)
    --slack          Output Slack-formatted markdown
    --watch [SECS]   Re-run every SECS seconds (default: 60), notify on changes
    --help           Show this help

Dependencies: python3 (3.8+), gh (GitHub CLI)
"""

from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import signal
import subprocess
import sys
import time
from collections import OrderedDict
from concurrent.futures import ThreadPoolExecutor, as_completed
from dataclasses import dataclass, field
from datetime import datetime, timedelta, timezone
from typing import Optional

# ============================================================
# Colors and formatting
# ============================================================

BOLD = "\033[1m"
DIM = "\033[2m"
NC = "\033[0m"
RED = "\033[0;31m"
GREEN = "\033[0;32m"
YELLOW = "\033[0;33m"
BLUE = "\033[0;34m"
MAGENTA = "\033[0;35m"
CYAN = "\033[0;36m"
PALETTE = [CYAN, GREEN, MAGENTA, BLUE, YELLOW, RED]


def osc8(url: str, label: str) -> str:
    return f"\033]8;;{url}\033\\{label}\033]8;;\033\\"


# ============================================================
# External command helpers
# ============================================================


def run(cmd: list[str], env: Optional[dict] = None, timeout: int = 30) -> Optional[str]:
    """Run a command, return stdout or None on failure."""
    try:
        r = subprocess.run(
            cmd, capture_output=True, text=True, timeout=timeout,
            env={**os.environ, **(env or {})},
        )
        return r.stdout.strip() if r.returncode == 0 else None
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return None


def gh_graphql(query: str) -> Optional[dict]:
    """Run a GraphQL query via gh api."""
    result = run(
        ["gh", "api", "graphql", "-f", f"query={query}"],
        timeout=30,
    )
    if result:
        try:
            return json.loads(result)
        except json.JSONDecodeError:
            return None
    return None


# ============================================================
# Global discovery and deploy inference
# ============================================================


@dataclass
class Repo:
    name: str  # unique key, owner/name
    owner_repo: str
    short_name: str = ""
    color: str = ""


MAX_REPO_NAME = 16
SEARCH_FIELDS = (
    "number,title,state,isDraft,createdAt,updatedAt,closedAt,url,repository,author"
)
PR_FIELDS = (
    "number,title,state,isDraft,createdAt,updatedAt,mergedAt,mergeCommit,"
    "headRefName,baseRefName,author,reviews,reviewRequests,"
    "statusCheckRollup,url"
)


def shorten_repo_name(name: str) -> str:
    """Shorten long repo names by abbreviating leading segments to initials.
    e.g. freetrade-firebase-functions -> f-f-functions"""
    if len(name) <= MAX_REPO_NAME:
        return name
    sep = "-" if "-" in name else "_" if "_" in name else None
    if not sep:
        return name[: MAX_REPO_NAME - 1] + "…"
    parts = name.split(sep)
    if len(parts) < 2:
        return name[: MAX_REPO_NAME - 1] + "…"
    for i in range(len(parts) - 1):
        parts[i] = parts[i][0] if parts[i] else parts[i]
        if len(sep.join(parts)) <= MAX_REPO_NAME:
            return sep.join(parts)
    return sep.join(parts)


def assign_display_attrs(repos: list[Repo]) -> None:
    """Assign short names and colors to repos."""
    for i, repo in enumerate(sorted(repos, key=lambda r: r.owner_repo.lower())):
        base_name = repo.owner_repo.split("/", 1)[-1]
        repo.short_name = shorten_repo_name(base_name)
        repo.color = PALETTE[i % len(PALETTE)]


def build_repo_index(prs: list[dict]) -> list[Repo]:
    seen: dict[str, Repo] = {}
    for pr in prs:
        owner_repo = pr["_repo"]
        seen.setdefault(owner_repo, Repo(name=owner_repo, owner_repo=owner_repo))
    repos = list(seen.values())
    assign_display_attrs(repos)
    return repos


def parse_search_results(raw: Optional[str], source: str) -> list[dict]:
    if not raw:
        return []

    try:
        prs = json.loads(raw)
    except json.JSONDecodeError:
        return []

    items = []
    for pr in prs:
        repo = (pr.get("repository") or {}).get("nameWithOwner", "")
        if not repo:
            continue
        pr["_repo"] = repo
        pr["_sources"] = [source]
        items.append(pr)
    return items


def search_prs(args: list[str], source: str) -> list[dict]:
    result = run(
        ["gh", "search", "prs", "--limit", "100", "--json", SEARCH_FIELDS, *args],
        timeout=30,
    )
    return parse_search_results(result, source)


def discover_prs(author: str, since: str) -> list[dict]:
    """Discover relevant PRs globally, without local repo context."""
    since_day = since[:10]
    buckets = [
        search_prs(["--author", author, "--state", "open"], "authored_open"),
        search_prs(["--review-requested", author, "--state", "open"], "review_requested"),
        search_prs([f"author:{author} is:merged merged:>={since_day}"], "authored_merged"),
    ]

    merged: dict[tuple[str, int], dict] = {}
    for bucket in buckets:
        for pr in bucket:
            key = (pr["_repo"], pr["number"])
            existing = merged.get(key)
            if existing:
                sources = set(existing.get("_sources") or [])
                sources.update(pr.get("_sources") or [])
                existing["_sources"] = sorted(sources)
                if pr.get("updatedAt", "") > existing.get("updatedAt", ""):
                    existing.update({k: v for k, v in pr.items() if not k.startswith("_")})
            else:
                merged[key] = pr

    return sorted(
        merged.values(),
        key=lambda pr: pr.get("updatedAt") or pr.get("createdAt", ""),
        reverse=True,
    )


def enrich_pr(pr_stub: dict) -> Optional[dict]:
    """Fetch the rich PR details needed for rendering and notifications."""
    result = run(
        [
            "gh", "pr", "view", str(pr_stub["number"]),
            "--repo", pr_stub["_repo"],
            "--json", PR_FIELDS,
        ],
        timeout=30,
    )
    if not result:
        return None

    try:
        pr = json.loads(result)
    except json.JSONDecodeError:
        return None

    pr["_repo"] = pr_stub["_repo"]
    pr["_sources"] = list(pr_stub.get("_sources") or [])
    return pr


def fetch_repo_deploy_data(repo: Repo) -> tuple[Optional[dict], list[str]]:
    owner, name = repo.owner_repo.split("/", 1)
    query = """
    query {
      repository(owner: "%s", name: "%s") {
        defaultBranchRef {
          name
          target {
            ... on Commit {
              history(first: 30) {
                nodes {
                  oid
                  status {
                    contexts {
                      context
                      state
                    }
                  }
                }
              }
            }
          }
        }
        release: ref(qualifiedName: "refs/heads/release") {
          target {
            ... on Commit {
              oid
            }
          }
        }
        develop: ref(qualifiedName: "refs/heads/develop") {
          target {
            ... on Commit {
              oid
            }
          }
        }
      }
    }
    """ % (owner, name)

    data = gh_graphql(query)
    if not data:
        return None, ["GraphQL query failed"]

    repo_data = data.get("data", {}).get("repository")
    if not repo_data:
        return None, ["repository lookup failed"]

    return repo_data, []


def find_deploy_markers_graphql(repo_data: dict) -> tuple[Optional[str], Optional[str], list[str]]:
    """Find last preprod/prod deployed commits from default-branch status contexts."""
    nodes = (
        ((repo_data.get("defaultBranchRef") or {}).get("target") or {})
        .get("history", {})
        .get("nodes", [])
    )
    if not nodes:
        return None, None, ["no commits found on default branch"]

    all_contexts: set[str] = set()
    for node in nodes:
        for ctx in (node.get("status") or {}).get("contexts", []):
            all_contexts.add(ctx.get("context", ""))

    prod_ctx = None
    preprod_ctx = None
    for ctx in sorted(all_contexts):
        if re.search(r"promot|deploy", ctx, re.I):
            if re.search(r"prod", ctx, re.I) and not re.search(r"pre-?prod|staging", ctx, re.I):
                if not prod_ctx:
                    prod_ctx = ctx
            if re.search(r"pre-?prod|staging", ctx, re.I):
                if not preprod_ctx:
                    preprod_ctx = ctx

    if not prod_ctx and not preprod_ctx:
        return None, None, []

    last_preprod = None
    last_prod = None
    for node in nodes:
        oid = node["oid"]
        by_ctx = {
            c["context"]: c["state"]
            for c in (node.get("status") or {}).get("contexts", [])
        }
        if prod_ctx and not last_prod and by_ctx.get(prod_ctx) == "SUCCESS":
            last_prod = oid
        if preprod_ctx and not last_preprod and by_ctx.get(preprod_ctx) == "SUCCESS":
            last_preprod = oid
        if (last_prod or not prod_ctx) and (last_preprod or not preprod_ctx):
            break

    warnings = []
    if preprod_ctx and not last_preprod:
        warnings.append("could not find last preprod deploy in recent history")
    if prod_ctx and not last_prod:
        warnings.append("could not find last prod deploy in recent history")

    return last_preprod, last_prod, warnings


def compare_contains(repo: Repo, base: str, head: str) -> bool:
    """Return True when base is an ancestor of head in the remote repository."""
    result = run(
        ["gh", "api", f"repos/{repo.owner_repo}/compare/{base}...{head}", "--jq", ".status"],
        timeout=30,
    )
    return result in ("ahead", "identical")


def detect_deploy_status(repo: Repo, prs: list[dict]) -> tuple[dict[int, str], list[str]]:
    """Determine deployment status for merged PRs.

    Returns (deploy_info, warnings) where deploy_info maps PR number to status.
    """
    merged = [p for p in prs if p.get("state") == "MERGED" and p.get("mergeCommit")]
    if not merged:
        return {}, []

    repo_data, warnings = fetch_repo_deploy_data(repo)
    if not repo_data:
        return {p["number"]: "unknown" for p in merged}, warnings

    release_oid = (((repo_data.get("release") or {}).get("target") or {}).get("oid"))
    develop_oid = (((repo_data.get("develop") or {}).get("target") or {}).get("oid"))

    if release_oid and develop_oid:
        last_prod = release_oid
        last_preprod = develop_oid
    else:
        last_preprod, last_prod, ci_warnings = find_deploy_markers_graphql(repo_data)
        warnings.extend(ci_warnings)
        if last_preprod is None and last_prod is None:
            return {p["number"]: "prod" for p in merged}, warnings

    deploy_info = {}
    for pr in merged:
        sha = (pr.get("mergeCommit") or {}).get("oid")
        num = pr["number"]
        if not sha:
            continue
        if last_prod and compare_contains(repo, sha, last_prod):
            deploy_info[num] = "prod"
        elif last_preprod and compare_contains(repo, sha, last_preprod):
            deploy_info[num] = "preprod"
        elif not last_preprod and not last_prod:
            deploy_info[num] = "unknown"
        else:
            deploy_info[num] = "merged"
            base = pr.get("baseRefName", "")
            if base not in ("develop", "main", "master", ""):
                warnings.append(f"#{num}: merged into {base}")

    return deploy_info, warnings


# ============================================================
# Formatting
# ============================================================

TICKET_RE = re.compile(r"([A-Z]{2,}-\d+)", re.IGNORECASE)


def extract_ticket(title: str) -> Optional[str]:
    m = TICKET_RE.search(title)
    return m.group(1).upper() if m else None


def strip_ticket(title: str) -> str:
    title = TICKET_RE.sub("", title)
    title = re.sub(r"\(\)\s*", "", title)
    title = re.sub(r"\[\]\s*", "", title)
    return title.strip().lstrip(":").lstrip("-").strip()


def get_review_info(pr: dict) -> dict:
    """Build per-reviewer summary with combined icons. Excludes PR author."""
    reviews = pr.get("reviews") or []
    requests = pr.get("reviewRequests") or []
    pr_author = (pr.get("author") or {}).get("login", "")

    reviewer_states: dict[str, set[str]] = {}
    for r in reviews:
        author = (r.get("author") or {}).get("login", "")
        state = r.get("state", "")
        if not author or author == pr_author or author == "copilot-pull-request-reviewer":
            continue
        if author not in reviewer_states:
            reviewer_states[author] = set()
        if state in ("APPROVED", "CHANGES_REQUESTED", "COMMENTED"):
            reviewer_states[author].add(state)

    pending_set: set[str] = set()
    for rr in requests:
        login = rr.get("login", "") or rr.get("name", "")
        if login and login != pr_author:
            pending_set.add(login)
            if login not in reviewer_states:
                reviewer_states[login] = set()

    entries = []
    has_approval = False
    has_changes = False
    for login, states in reviewer_states.items():
        icons = []
        if "APPROVED" in states:
            icons.append(f"{GREEN}✅{NC}")
            has_approval = True
        if "CHANGES_REQUESTED" in states:
            icons.append(f"{RED}🔴{NC}")
            has_changes = True
        if "COMMENTED" in states:
            icons.append("💬")
        if login in pending_set:
            icons.append(f"{DIM}⏳{NC}")
        if icons:
            entries.append(" ".join(icons) + " " + login)

    return {
        "entries": entries,
        "has_approval": has_approval,
        "has_changes": has_changes,
        "has_pending": len(pending_set) > 0,
        "has_comments": any(
            "COMMENTED" in s or "CHANGES_REQUESTED" in s
            for s in reviewer_states.values()
        ),
    }


def get_ci_status(pr: dict) -> tuple[Optional[str], list[str]]:
    checks = pr.get("statusCheckRollup") or []
    checks = [c for c in checks if c.get("name")]
    if not checks:
        return None, []
    failed = [c["name"] for c in checks if c.get("conclusion") == "FAILURE"]
    pending = [c["name"] for c in checks if c.get("status") not in ("COMPLETED",) and c.get("name")]
    if failed:
        return "fail", failed
    if pending:
        return "pending", pending
    return "pass", []


@dataclass
class StatusInfo:
    emoji: str
    label: str
    color: str
    review_entries: list[str] = field(default_factory=list)
    ci_status: Optional[str] = None
    ci_detail: list[str] = field(default_factory=list)


def format_status(
    pr: dict,
    deploy_info: dict[str, dict[int, str]],
    check_deploy: bool,
) -> StatusInfo:
    state = pr.get("state", "")
    is_draft = pr.get("isDraft", False)

    if state == "CLOSED":
        return StatusInfo("🚫", "closed", DIM)

    if state == "MERGED":
        if not check_deploy:
            return StatusInfo("✅", "merged", GREEN)
        repo = pr["_repo"]
        num = pr["number"]
        status = deploy_info.get(repo, {}).get(num, "unknown")
        emoji_map = {
            "prod": ("✅", "prod", GREEN),
            "preprod": ("⬆️", "preprod", YELLOW),
            "merged": ("📦", "merged", BLUE),
        }
        e, l, c = emoji_map.get(status, ("❓", "merged", DIM))
        return StatusInfo(e, l, c)

    # Open PR
    ri = get_review_info(pr)
    ci, ci_detail = get_ci_status(pr)

    if is_draft:
        emoji, label, color = "📝", "draft", DIM
    elif ri["has_changes"]:
        emoji, label, color = "🔴", "changes", RED
    elif ri["has_approval"]:
        emoji, label, color = "✅", "approved", GREEN
    elif ri["has_pending"]:
        emoji, label, color = "👀", "review", YELLOW
    elif ri["has_comments"]:
        emoji, label, color = "✏️", "revise", CYAN
    else:
        emoji, label, color = "👀", "review", YELLOW

    return StatusInfo(
        emoji=emoji, label=label, color=color,
        review_entries=ri["entries"],
        ci_status=ci, ci_detail=ci_detail,
    )


# ============================================================
# Rendering
# ============================================================

ANSI_RE = re.compile(r"\033\[[^m]*m")
OSC8_RE = re.compile(r"\033\]8;;.*?\033\\")


def strip_formatting(text: str) -> str:
    """Remove terminal formatting sequences when measuring visible width."""
    return ANSI_RE.sub("", OSC8_RE.sub("", text))


def visible_len(text: str) -> int:
    return len(strip_formatting(text))


def truncate_text(text: str, max_len: int) -> str:
    if max_len <= 0:
        return ""
    if len(text) <= max_len:
        return text
    if max_len <= 3:
        return "." * max_len
    return text[: max_len - 3] + "..."


def current_terminal_width(slack: bool) -> int:
    if slack or not sys.stdout.isatty():
        return 120
    return max(30, shutil.get_terminal_size(fallback=(120, 24)).columns)


def render(
    all_prs: list[dict],
    repos: list[Repo],
    deploy_info: dict[str, dict[int, str]],
    check_deploy: bool,
    slack: bool,
    width: Optional[int] = None,
) -> list[str]:
    """Render all PRs into output lines."""
    lines: list[str] = []
    width = width or current_terminal_width(slack)
    repo_names = [r.name for r in repos]
    repo_short = {r.name: r.short_name for r in repos}
    repo_color = {r.name: r.color for r in repos}
    max_repo_len = max((len(s) for s in repo_short.values()), default=10) + 1
    repo_order = {name: i for i, name in enumerate(sorted(repo_names))}

    status_alias = {
        "review": "review",
        "approved": "approve",
        "changes": "changes",
        "draft": "draft",
        "revise": "revise",
        "merged": "merged",
        "preprod": "preprod",
        "prod": "prod",
        "closed": "closed",
    }
    status_short = {
        "review": "rev",
        "approved": "ok",
        "changes": "chg",
        "draft": "drf",
        "revise": "edit",
        "merged": "mrg",
        "preprod": "pre",
        "prod": "prod",
        "closed": "cls",
    }
    status_tiny = {
        "review": "r",
        "approved": "a",
        "changes": "c",
        "draft": "d",
        "revise": "e",
        "merged": "m",
        "preprod": "p+",
        "prod": "p",
        "closed": "x",
    }

    def status_text(label: str) -> str:
        if width < 52:
            return status_tiny.get(label, label[:1])
        if width < 84:
            return status_short.get(label, label[:3])
        if width < 104:
            return status_alias.get(label, label)
        return label

    def repo_text(name: str) -> str:
        if width < 52:
            return truncate_text(name, 8)
        if width < 72:
            return truncate_text(name, 10)
        if width < 90:
            return truncate_text(name, 12)
        return name

    # Group by ticket
    groups: OrderedDict[str, list[dict]] = OrderedDict()
    ungrouped: list[dict] = []
    active = [pr for pr in all_prs if pr.get("state") != "CLOSED"]

    for pr in active:
        ticket = extract_ticket(pr.get("title", ""))
        if ticket:
            groups.setdefault(ticket, []).append(pr)
        else:
            ungrouped.append(pr)

    # Sort: open first, then by recency
    open_g = [(t, p) for t, p in groups.items() if any(pr["state"] == "OPEN" for pr in p)]
    done_g = [(t, p) for t, p in groups.items() if not any(pr["state"] == "OPEN" for pr in p)]
    open_g.sort(key=lambda kv: max(pr.get("createdAt", "") for pr in kv[1]), reverse=True)
    done_g.sort(key=lambda kv: max(pr.get("mergedAt") or pr.get("createdAt", "") for pr in kv[1]), reverse=True)
    sorted_groups = open_g + done_g
    ungrouped.sort(key=lambda p: p.get("mergedAt") or p.get("createdAt", ""), reverse=True)

    def render_pr(pr: dict) -> list[str]:
        repo = pr["_repo"]
        short = repo_text(repo_short.get(repo, repo))
        color = repo_color.get(repo, "")
        num = pr["number"]
        url = pr.get("url", "")
        title = strip_ticket(pr.get("title", ""))

        s = format_status(pr, deploy_info, check_deploy)
        label = status_text(s.label)
        label_width = max(1, min(7, max(len(status_text(v)) for v in status_alias)))
        padded_label = label.ljust(label_width)
        repo_width = max(4, min(max_repo_len, max(len(repo_text(v)) for v in repo_short.values()) + 1))
        repo_pad = short.ljust(repo_width)

        detail_parts = []
        if s.review_entries:
            if slack:
                plain = [strip_formatting(e) for e in s.review_entries]
                detail_parts.append("  ".join(plain))
            else:
                detail_parts.append("  ".join(s.review_entries))
        if s.ci_status == "fail":
            names = ", ".join(s.ci_detail[:2])
            if slack:
                detail_parts.append(f"CI: {names}")
            else:
                detail_parts.append(f"{RED}CI:{NC} {names}")
        elif s.ci_status == "pending":
            if slack:
                detail_parts.append("CI pending")
            else:
                detail_parts.append(f"{YELLOW}CI pending{NC}")
        detail = "  ".join(detail_parts)

        if slack:
            line = f"{s.emoji} `{padded_label}| {repo_pad}|`  {title}  [#{num}]({url})"
            if detail:
                line += f"  {detail}"
            return [line]

        pr_link = osc8(url, f"#{num}")
        term_status = f"{s.color}{s.emoji} {padded_label}{NC}" if s.color else f"{s.emoji} {padded_label}"
        meta = f"  {term_status}  {color}{repo_pad}{NC}  {pr_link}"
        detail_plain = strip_formatting(detail)

        if width < 72:
            title_indent = "      " if width >= 52 else "    "
            title_budget = max(12, width - len(title_indent))
            lines = [meta, f"{title_indent}{DIM}{truncate_text(title, title_budget)}{NC}"]
            if detail_plain:
                detail_indent = title_indent
                detail_budget = max(10, width - len(detail_indent))
                lines.append(f"{detail_indent}{truncate_text(detail_plain, detail_budget)}")
            return lines

        base_prefix = f"  {term_status}  {color}{repo_pad}{NC}  "
        base_suffix = f"  {pr_link}"
        available = width - visible_len(base_prefix) - visible_len(base_suffix)

        if width < 96:
            title_budget = max(16, available)
            shown_title = truncate_text(title, title_budget)
            lines = [f"{base_prefix}{DIM}{shown_title}{NC}{base_suffix}"]
            if detail_plain:
                detail_indent = "      "
                detail_budget = max(12, width - len(detail_indent))
                lines.append(f"{detail_indent}{truncate_text(detail_plain, detail_budget)}")
            return lines

        title_budget = max(18, available)
        detail_budget = 0
        if detail_plain and available > 30:
            title_budget = max(18, int(available * 0.58))
            detail_budget = max(0, available - title_budget - 2)

        shown_title = truncate_text(title, title_budget)
        shown_detail = ""
        if detail_plain and detail_budget > 0:
            shown_detail = truncate_text(detail_plain, detail_budget)

        line = f"{base_prefix}{DIM}{shown_title}{NC}{base_suffix}"
        if shown_detail:
            line += f"  {shown_detail}"
        return [line]

    def render_header(ticket: str, title: str) -> list[str]:
        if slack:
            return ["", f"*{ticket}: {title}*"]
        return ["", f"{BOLD}{ticket}: {title}{NC}"]

    for ticket, prs in sorted_groups:
        prs.sort(key=lambda p: (repo_order.get(p["_repo"], 99), 0 if p["state"] == "OPEN" else 1))

        # Header from oldest PR in top-priority repo
        top_repo = prs[0]["_repo"]
        top_prs = sorted(
            [p for p in prs if p["_repo"] == top_repo],
            key=lambda p: p.get("createdAt") or p.get("mergedAt", ""),
        )
        header_title = strip_ticket(top_prs[0]["title"])
        if not slack:
            header_budget = max(20, width - len(ticket) - 4)
            header_title = truncate_text(header_title, header_budget)
        elif len(header_title) > 70:
            header_title = header_title[:67] + "..."

        lines.extend(render_header(ticket, header_title))

        # Collapse sections where every PR is deployed to prod
        if check_deploy and all(
            deploy_info.get(p["_repo"], {}).get(p["number"]) == "prod"
            for p in prs
        ):
            pr_refs = []
            for pr in prs:
                short = repo_short.get(pr["_repo"], pr["_repo"])
                num = pr["number"]
                url = pr.get("url", "")
                if slack:
                    pr_refs.append(f"{short} [#{num}]({url})")
                else:
                    pr_refs.append(f"{repo_color.get(pr['_repo'], '')}{short}{NC} {osc8(url, f'#{num}')}")
            ref_str = "  ".join(pr_refs)
            if slack:
                lines.append(f"✅ All in prod: {ref_str}")
            else:
                summary = f"  {GREEN}✅  All in prod{NC}  {ref_str}"
                if visible_len(summary) > width:
                    summary = (
                        f"  {GREEN}✅  All in prod{NC}  "
                        f"{truncate_text(strip_formatting(ref_str), max(10, width - 18))}"
                    )
                lines.append(summary)
        else:
            for pr in prs:
                lines.extend(render_pr(pr))

    if ungrouped:
        lines.append("")
        if slack:
            lines.append("*Other*")
        else:
            lines.append(f"{BOLD}Other{NC}")

        # Collapse "Other" too if all prod
        if check_deploy and all(
            deploy_info.get(p["_repo"], {}).get(p["number"]) == "prod"
            for p in ungrouped
        ):
            pr_refs = []
            for pr in ungrouped:
                short = repo_short.get(pr["_repo"], pr["_repo"])
                num = pr["number"]
                url = pr.get("url", "")
                if slack:
                    pr_refs.append(f"{short} [#{num}]({url})")
                else:
                    pr_refs.append(f"{repo_color.get(pr['_repo'], '')}{short}{NC} {osc8(url, f'#{num}')}")
            ref_str = "  ".join(pr_refs)
            if slack:
                lines.append(f"✅ All in prod: {ref_str}")
            else:
                summary = f"  {GREEN}✅  All in prod{NC}  {ref_str}"
                if visible_len(summary) > width:
                    summary = (
                        f"  {GREEN}✅  All in prod{NC}  "
                        f"{truncate_text(strip_formatting(ref_str), max(10, width - 18))}"
                    )
                lines.append(summary)
        else:
            for pr in ungrouped:
                lines.extend(render_pr(pr))

    if slack:
        lines = [f"> {line}" if line.strip() else line for line in lines]

    return lines


# ============================================================
# Notifications (for watch mode)
# ============================================================


def notify(title: str, message: str) -> None:
    """Send a system notification. Tries terminal-notifier, falls back to osascript."""
    if shutil.which("terminal-notifier"):
        subprocess.run(
            ["terminal-notifier", "-title", title, "-message", message,
             "-sound", "default", "-group", "pr-status"],
            capture_output=True,
        )
    elif shutil.which("osascript"):
        script = f'display notification "{message}" with title "{title}"'
        subprocess.run(["osascript", "-e", script], capture_output=True)
    elif shutil.which("notify-send"):
        subprocess.run(["notify-send", title, message], capture_output=True)


def _ci_summary(pr: dict) -> tuple[Optional[str], list[str]]:
    """Extract CI status from a PR snapshot: ('pass'|'fail'|'pending'|None, [failed names])."""
    checks = pr.get("statusCheckRollup") or []
    checks = [c for c in checks if c.get("name")]
    if not checks:
        return None, []
    failed = [c["name"] for c in checks if c.get("conclusion") == "FAILURE"]
    if failed:
        return "fail", failed
    pending = [c for c in checks if c.get("status") not in ("COMPLETED",)]
    if pending:
        return "pending", []
    return "pass", []


def _review_set(pr: dict) -> set[tuple[str, str]]:
    """Extract (author, state) pairs from reviews, ignoring bots."""
    return {
        (r.get("author", {}).get("login", ""), r.get("state", ""))
        for r in (pr.get("reviews") or [])
        if r.get("author", {}).get("login")
        and r.get("author", {}).get("login") != "copilot-pull-request-reviewer"
    }


def diff_and_notify(
    old_prs: list[dict],
    new_prs: list[dict],
    old_deploy: dict[str, dict[int, str]],
    new_deploy: dict[str, dict[int, str]],
) -> None:
    """Compare two snapshots and send system notifications on changes."""
    old_by_key = {(p["_repo"], p["number"]): p for p in old_prs}
    new_by_key = {(p["_repo"], p["number"]): p for p in new_prs}

    changes: list[str] = []

    for key, new_pr in new_by_key.items():
        old_pr = old_by_key.get(key)
        title = strip_ticket(new_pr.get("title", ""))
        if len(title) > 50:
            title = title[:47] + "..."

        if not old_pr:
            if "review_requested" in set(new_pr.get("_sources") or []):
                changes.append(f"👀 Review requested: {title}")
            continue

        old_sources = set(old_pr.get("_sources") or [])
        new_sources = set(new_pr.get("_sources") or [])
        if "review_requested" in new_sources and "review_requested" not in old_sources:
            changes.append(f"👀 Review requested: {title}")

        old_state = old_pr.get("state")
        new_state = new_pr.get("state")

        # PR merged or closed
        if old_state != new_state:
            if new_state == "MERGED":
                changes.append(f"✅ Merged: {title}")
            elif new_state == "CLOSED":
                changes.append(f"🚫 Closed: {title}")
            continue

        # Only check open PRs for review/CI changes
        if new_state != "OPEN":
            continue

        # CI status changes
        old_ci, _ = _ci_summary(old_pr)
        new_ci, new_failed = _ci_summary(new_pr)
        if old_ci != new_ci:
            if new_ci == "fail":
                names = ", ".join(new_failed[:2])
                changes.append(f"❌ CI failed ({names}): {title}")
            elif new_ci == "pass" and old_ci == "fail":
                changes.append(f"🟢 CI fixed: {title}")

        # New reviews
        old_reviews = _review_set(old_pr)
        new_reviews = _review_set(new_pr)
        added = new_reviews - old_reviews
        new_approvals = [login for login, state in added if state == "APPROVED"]
        new_change_reqs = [login for login, state in added if state == "CHANGES_REQUESTED"]
        new_comments = [login for login, state in added if state == "COMMENTED"]
        if new_approvals:
            changes.append(f"✅ {', '.join(new_approvals)} approved: {title}")
        if new_change_reqs:
            changes.append(f"🔴 {', '.join(new_change_reqs)} requested changes: {title}")
        if new_comments and not new_approvals and not new_change_reqs:
            changes.append(f"💬 {', '.join(new_comments)} commented: {title}")

    # Deploy status changes (merged PRs moving through environments)
    for key, new_pr in new_by_key.items():
        if new_pr.get("state") != "MERGED":
            continue
        repo = new_pr["_repo"]
        num = new_pr["number"]
        old_status = old_deploy.get(repo, {}).get(num, "")
        new_status = new_deploy.get(repo, {}).get(num, "")
        if old_status != new_status and new_status in ("prod", "preprod"):
            title = strip_ticket(new_pr.get("title", ""))
            if len(title) > 50:
                title = title[:47] + "..."
            if new_status == "prod":
                changes.append(f"🚀 Deployed to prod: {title}")
            elif new_status == "preprod" and old_status != "prod":
                changes.append(f"⬆️ Deployed to preprod: {title}")

    if changes:
        notify("pr-status", "\n".join(changes[:5]))


# ============================================================
# Main
# ============================================================


@dataclass
class Snapshot:
    prs: list[dict]
    deploy: dict[str, dict[int, str]]


def render_snapshot(snapshot: Snapshot, args: argparse.Namespace) -> list[str]:
    repos = build_repo_index(snapshot.prs)
    return render(snapshot.prs, repos, snapshot.deploy, args.deploy, args.slack)


def run_once(
    args: argparse.Namespace,
    enrich_cache: dict[tuple[str, int], tuple[str, dict]],
) -> tuple[Snapshot, list[str]]:
    """Run one full cycle. Returns a snapshot for diffing."""
    since = (datetime.now(timezone.utc) - timedelta(days=args.days)).strftime(
        "%Y-%m-%dT%H:%M:%SZ"
    )

    # Phase 1: Discover and enrich PRs
    t0 = time.monotonic()
    print(f"{DIM}Searching GitHub for relevant PRs...{NC}", file=sys.stderr)
    pr_stubs = discover_prs(args.author, since)

    all_prs: list[dict] = []
    pending: list[dict] = []
    for pr_stub in pr_stubs:
        key = (pr_stub["_repo"], pr_stub["number"])
        cached = enrich_cache.get(key)
        if cached and cached[0] == pr_stub.get("updatedAt", ""):
            pr = dict(cached[1])
            pr["_sources"] = list(pr_stub.get("_sources") or [])
            all_prs.append(pr)
        else:
            pending.append(pr_stub)

    if pending:
        print(f"{DIM}Fetching PR details for {len(pending)} PRs...{NC}", file=sys.stderr)
        with ThreadPoolExecutor(max_workers=min(8, len(pending))) as pool:
            futures = {pool.submit(enrich_pr, pr_stub): pr_stub for pr_stub in pending}
            for future in as_completed(futures):
                pr_stub = futures[future]
                pr = future.result()
                if not pr:
                    continue
                all_prs.append(pr)
                enrich_cache[(pr_stub["_repo"], pr_stub["number"])] = (
                    pr_stub.get("updatedAt", ""),
                    dict(pr),
                )

    t1 = time.monotonic()

    repos = build_repo_index(all_prs)

    # Phase 2: Deploy detection in parallel
    deploy_info: dict[str, dict[int, str]] = {}
    warnings: dict[str, list[str]] = {}

    if args.deploy and repos:
        print(f"{DIM}Checking deployment status...{NC}", file=sys.stderr)

        repo_prs: dict[str, list[dict]] = {}
        for pr in all_prs:
            if "authored_merged" in set(pr.get("_sources") or []):
                repo_prs.setdefault(pr["_repo"], []).append(pr)

        deploy_repos = [repo for repo in repos if repo_prs.get(repo.owner_repo)]
        if deploy_repos:
            with ThreadPoolExecutor(max_workers=min(8, len(deploy_repos))) as pool:
                futures = {
                    pool.submit(detect_deploy_status, repo, repo_prs[repo.owner_repo]): repo
                    for repo in deploy_repos
                }
                for future in as_completed(futures):
                    repo = futures[future]
                    info, warns = future.result()
                    deploy_info[repo.owner_repo] = info
                    if warns:
                        warnings[repo.owner_repo] = warns

    t2 = time.monotonic()

    for repo_name, warns in warnings.items():
        for w in warns:
            print(f"{YELLOW}  ⚠ {repo_name}: {w}{NC}", file=sys.stderr)

    print(
        f"{DIM}Done (discover: {t1 - t0:.0f}s, deploy: {t2 - t1:.0f}s){NC}",
        file=sys.stderr,
    )

    snapshot = Snapshot(prs=all_prs, deploy=deploy_info)
    lines = render_snapshot(snapshot, args)

    return snapshot, lines


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="pr-status",
        description="Show status of your recent PRs across multiple GitHub repos.",
        add_help=False,
    )
    parser.add_argument("--days", type=int, default=30)
    parser.add_argument("--author", default="@me")
    parser.add_argument("--no-deploy", dest="deploy", action="store_false", default=True)
    parser.add_argument("--slack", action="store_true")
    parser.add_argument("--watch", nargs="?", const=60, type=int, metavar="SECS")
    parser.add_argument("--help", "-h", action="store_true")

    args = parser.parse_args()

    if args.help:
        print(__doc__.strip())
        return

    enrich_cache: dict[tuple[str, int], tuple[str, dict]] = {}

    def draw(lines: list[str]) -> None:
        if args.watch is not None:
            os.system("clear")
        for line in lines:
            print(line)

    resized = False

    def on_resize(signum, frame) -> None:
        nonlocal resized
        resized = True

    if hasattr(signal, "SIGWINCH"):
        signal.signal(signal.SIGWINCH, on_resize)

    if args.watch is None:
        snapshot, lines = run_once(args, enrich_cache)
        draw(lines)
    else:
        prev: Optional[Snapshot] = None
        current_snapshot: Optional[Snapshot] = None
        current_lines: list[str] = []
        while True:
            try:
                current_snapshot, current_lines = run_once(args, enrich_cache)
            except KeyboardInterrupt:
                break
            except Exception as e:
                print(f"{RED}Error: {e}{NC}", file=sys.stderr)
                current_snapshot, current_lines = None, []

            draw(current_lines)
            resized = False

            if prev and current_snapshot:
                diff_and_notify(prev.prs, current_snapshot.prs, prev.deploy, current_snapshot.deploy)
            if current_snapshot:
                prev = current_snapshot

            deadline = time.monotonic() + args.watch
            try:
                while True:
                    remaining = deadline - time.monotonic()
                    if remaining <= 0:
                        break
                    if resized and current_snapshot:
                        current_lines = render_snapshot(current_snapshot, args)
                        draw(current_lines)
                        resized = False
                    time.sleep(min(0.2, remaining))
            except KeyboardInterrupt:
                break


if __name__ == "__main__":
    main()
